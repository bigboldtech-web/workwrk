# ──────────────────────────────────────────────────────────────
# WorkwrK — environment variables
# Copy to `.env` for local dev. In production, set these in your
# hosting provider's dashboard (Vercel, AWS, Railway, etc.).
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
# Postgres connection string. Neon / Supabase / RDS / local.
DATABASE_URL="postgresql://user:password@localhost:5432/workwrk?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────
# Secret for signing JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── AI Engine ────────────────────────────────────────────────
# Required for /api/ai, AI signals, KRA/SOP generation.
# Enterprise agreement with Anthropic — zero-retention, zero-training.
ANTHROPIC_API_KEY=""

# ─── Google SSO (optional) ────────────────────────────────────
# Enable Google sign-in on /login. Create at console.cloud.google.com
# Authorized redirect: $NEXTAUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe billing (optional) ────────────────────────────────
# Required for self-serve subscription billing. Get from stripe.com.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs — create in Stripe dashboard matching the pricing on /pricing.
STRIPE_PRICE_GROWTH_PER_USER=""
STRIPE_PRICE_TEAM_FLAT=""
STRIPE_PRICE_GROWTH_FLAT=""
STRIPE_PRICE_SCALE_FLAT=""

# ─── Cron secret ──────────────────────────────────────────────
# Shared secret between the scheduler and the cron endpoints:
#   POST /api/tasks/run-sla-check  (every 15 min)
#   POST /api/cron/webhook-retry   (every 5 min)
# Sent as header: X-Cron-Secret or Authorization: Bearer <value>
CRON_SECRET=""

# ─── Email delivery (optional but recommended) ────────────────
# The app falls back to console.log when these aren't set.
EMAIL_FROM="WorkwrK <hi@workwrk.com>"
# Resend (recommended) — https://resend.com
RESEND_API_KEY=""
# Or SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ─── Storage (optional) ───────────────────────────────────────
# Required for Scribe screenshot uploads + avatars. S3-compatible.
# Works with Linode Object Storage, Cloudflare R2, AWS S3, B2 etc.
#
# Linode Chennai example:
#   S3_BUCKET=workwrk
#   S3_REGION=in-maa-1
#   S3_ENDPOINT=https://in-maa-1.linodeobjects.com
# AWS S3: leave S3_ENDPOINT empty.
# Cloudflare R2: set S3_ENDPOINT and S3_FORCE_PATH_STYLE=true.
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="in-maa-1"
S3_ENDPOINT="https://in-maa-1.linodeobjects.com"
S3_FORCE_PATH_STYLE=""

# ─── External integrations (wire on demand) ───────────────────
# Razorpay — for KPI push + payroll sync
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Keka HRMS
KEKA_API_URL=""
KEKA_API_KEY=""

# HubSpot
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# QuickBooks Online — register at developer.intuit.com.
# Redirect URI:  $NEXTAUTH_URL/api/integrations/quickbooks/callback
# Scopes wired in src/lib/integrations/quickbooks.ts (accounting + openid)
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# Xero — register at developer.xero.com.
# Redirect URI:  $NEXTAUTH_URL/api/integrations/xero/callback
# Scopes wired in src/lib/integrations/xero.ts (accounting.* + offline_access)
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# ─── Feature flags ────────────────────────────────────────────
# Set to "true" to expose experimental features to all tenants.
NEXT_PUBLIC_FLAG_SCRIBE="false"
NEXT_PUBLIC_FLAG_PROCESS_FLOWS="false"
