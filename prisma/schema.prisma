  @@index([sessionId])
}

// ==========================================
// COMPLIANCE & CONSENT
// ==========================================

/// Records user consent for cookies/tracking. GDPR/UK-GDPR require proof
/// of consent including timestamp, method, scope, and text version.
/// Never delete records — retain per legal retention policy.
model ConsentRecord {
  id               String    @id @default(cuid())
  userId           String?   // null for pre-auth visitors
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?   // anonymous cookie identifier
  organizationId   String?   // when consent tied to a tenant

  // Consent scope
  necessary        Boolean   @default(true)   // always true, but logged for record
  preferences      Boolean   @default(false)
  analytics        Boolean   @default(false)
  marketing        Boolean   @default(false)
  doNotSell        Boolean   @default(false)  // CCPA/CPRA opt-out flag

  // Legal basis / region at time of consent
  region           String?   // e.g. "EU", "UK", "US-CA", "BR", "IN", "ROW"
  country          String?   // ISO 3166-1 alpha-2
  policyVersion    String    // ties to versioned policy text
  method           String    // "banner", "settings", "api", "withdrawn"

  // Evidence
  ipAddress        String?
  userAgent        String?

  withdrawnAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([organizationId])
  @@index([createdAt])
}

// ==========================================
// Public API — keys, webhooks, deliveries
// ==========================================

model ApiKey {
  id             String    @id @default(cuid())
  // Display name chosen by the admin — e.g. "Production · Backend"
  name           String
  // First 8 chars of the plaintext key, used for display + lookup hint.
  // Full key is only shown once at creation time.
  prefix         String
  // SHA-256 hash of the plaintext key. We never store the raw key.
  hashedKey      String    @unique
  // Scopes granted to this key. READ = GET endpoints only.
  // WRITE adds create/update. ADMIN is full control including key mgmt.
  scopes         ApiKeyScope[] @default([READ])
  // Windowed limits (requests / minute, day). Enforced in middleware.
  rateLimitPerMinute Int    @default(120)
  rateLimitPerDay    Int    @default(50000)
  // Usage telemetry
  lastUsedAt     DateTime?
  lastUsedIp     String?
  requestCount   Int       @default(0)
  revokedAt      DateTime?
  // Ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  rateLimitBuckets ApiKeyRateBucket[]

  @@index([organizationId])
  @@index([hashedKey])
  @@index([prefix])
}

enum ApiKeyScope {
  READ
  WRITE
  ADMIN
}

/// Rolling-window rate limiter bucket. One row per (apiKey, windowKey).
/// windowKey is a compact epoch-minute or epoch-day string.
model ApiKeyRateBucket {
  id         String  @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  windowKind RateWindow
  windowKey  String
  count      Int     @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([apiKeyId, windowKind, windowKey])
  @@index([apiKeyId])
}

enum RateWindow {
  MINUTE
  DAY
}

/// Customer-registered webhook endpoint. Workwrk POSTs events to `url`
/// with an HMAC-SHA256 signature in X-Workwrk-Signature.
model WebhookSubscription {
  id             String    @id @default(cuid())
  url            String
  // Event types this subscription is interested in (e.g. "kudos.created",
  // "review.completed"). Wildcard "*" subscribes to everything.
  events         String[]
  // HMAC secret — generated at creation, shown once, hashed in storage.
  secretHash     String
  secretPrefix   String    // First 8 chars for identification (shown in UI).
  status         WebhookStatus @default(ACTIVE)
  // Rolling failure counter — deliveries auto-pause after too many 5xx.
  failureCount   Int       @default(0)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User      @relation("WebhookCreator", fields: [createdById], references: [id])
  deliveries     WebhookDelivery[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

/// Audit log + retry queue for individual webhook attempts.
model WebhookDelivery {
  id             String    @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         DeliveryStatus @default(PENDING)
  httpStatus     Int?
  responseBody   String?
  attemptCount   Int       @default(0)
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([status, nextAttemptAt])
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ==========================================
// DIMENSIONAL TAGS (Worktags equivalent)
// ==========================================
// Polymorphic tagging — any entity (User, Task, KRA, OKR, Expense…)
// can carry one or more tags. The intended use is for cost-center /
// business-unit / region / project slicing on reports and budgets,
// without bespoke schema per dimension. Modeled after Workday's
// Worktags: a single tag travels across HR, Finance, and Planning
// records so the CFO can drill down by region or project without
// schema gymnastics.
//
// `entityType` + `entityId` is intentionally polymorphic. We trade
// referential integrity for flexibility — adding a new taggable
// entity (e.g. Phase 2 ATS Candidate) just adds a new enum value.
// Cleanup of orphans is handled by a periodic cron, not the DB.

model Tag {
  id             String         @id @default(cuid())
  name           String
  type           TagType        @default(CUSTOM)
  color          String?        // hex, optional UX
  description    String?
  archived       Boolean        @default(false)

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignments    TagAssignment[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, type, name])
  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, archived])
}

model TagAssignment {
  id             String         @id @default(cuid())
  tagId          String
  tag            Tag            @relation(fields: [tagId], references: [id], onDelete: Cascade)

  entityType     TagEntityType
  entityId       String

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedById   String?        // User.id — null on system-applied tags

  createdAt      DateTime       @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([organizationId, entityType])
  @@index([tagId])
}

enum TagType {
  COST_CENTER
  BUSINESS_UNIT
  LOCATION
  REGION
  PROJECT
  FUNCTION
  CUSTOM
}

enum TagEntityType {
  USER
  TASK
  KRA
  KPI
  OKR
  SOP
  REVIEW
  REVIEW_CYCLE
  ASSET
  EXPENSE
  MEETING
}

// ==========================================
// EXPENSES (Phase 2)
// ==========================================
// Employee expense submission + approval flow. Single-currency per
// org for v1 (reporting in `currency`). Multi-currency, FX rates,
// auto-routing, and OCR all sit behind this — schema doesn't preclude
// them. Cost-center / project attribution rides the polymorphic
// TagAssignment system rather than direct FKs, so adding a new
// dimension (e.g. Fund) doesn't require a schema change here.
//
// Decimal(12,2) for `amount`: 10 digits of dollars + 2 cents. Float
// is wrong for money — at Fortune-500 volume the rounding bites.

model Expense {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  reporterId     String
  reporter       User          @relation("ExpenseReporter", fields: [reporterId], references: [id])

  description    String        // short headline visible in lists
  notes          String?       // longer context, only on detail
  category       ExpenseCategory

  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD") // ISO 4217

  expenseDate    DateTime
  receiptUrl     String?       // S3 URL after upload

  status         ExpenseStatus @default(DRAFT)
  submittedAt    DateTime?

  approverId     String?
  approver       User?         @relation("ExpenseApprover", fields: [approverId], references: [id])
  decisionAt     DateTime?
  decisionNote   String?       // why approved / rejected

  reimbursedAt   DateTime?     // future: link to a Payment row when payroll lands

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, expenseDate])
  @@index([reporterId, status])
  @@index([approverId, status])
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  LODGING
  TRANSPORT
  SUPPLIES
  SUBSCRIPTION
  EQUIPMENT
  CLIENT_ENTERTAINMENT
  TRAINING
  OTHER
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

// ==========================================
// COMPENSATION CYCLES (Phase 2)
// ==========================================
// Annual / biannual comp review. Managers propose merit + bonus per
// direct report; HR finalizes. Salary bands and PDF letter generation
// land in v2. Equity grants are a separate v3 surface.
//
// Comp data is the single most sensitive record in the org —
// authorization on every read goes through CompensationDecision's
// (subjectId, proposedById, decidedById) triangle: subject sees their
// own row, proposer (manager) sees rows for their reports, HR sees
// everything.

model CompensationCycle {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name              String
  description       String?
  status            CompCycleStatus @default(DRAFT)
  startDate         DateTime
  endDate           DateTime

  // Optional org-wide budget guidance for managers — e.g. "stay under
  // 5% across the team." Stored as percent, signed Decimal(5,2).
  budgetPct         Decimal?       @db.Decimal(5, 2)
  reportingCurrency String         @default("USD")

  closedAt          DateTime?
  decisions         CompensationDecision[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, startDate])
}

model CompensationDecision {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  cycleId         String
  cycle           CompensationCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  subjectId       String
  subject         User                @relation("CompDecisionSubject", fields: [subjectId], references: [id])
  proposedById    String?
  proposedBy      User?               @relation("CompDecisionProposer", fields: [proposedById], references: [id])

  currentSalary   Decimal?            @db.Decimal(12, 2)
  proposedSalary  Decimal?            @db.Decimal(12, 2)
  currency        String              @default("USD")
  // Signed so we can encode pay cuts (rare but legal). Two decimals
  // avoids float surprises — 5.50% vs 5.499999%.
  changePct       Decimal?            @db.Decimal(6, 2)
  bonusAmount     Decimal?            @db.Decimal(12, 2)
  reasoning       String?

  status          CompDecisionStatus  @default(DRAFT)
  decisionNote    String?
  // Audit fields without relations — HR ops can swap who finalized
  // without rewiring rows. The id should resolve via User lookup.
  decidedById     String?
  decidedAt       DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([cycleId, subjectId])
  @@index([organizationId, status])
  @@index([cycleId, status])
  @@index([subjectId])
  @@index([proposedById])
}

enum CompCycleStatus {
  DRAFT
  OPEN
  CLOSED
}

enum CompDecisionStatus {
  DRAFT
  PROPOSED
  APPROVED
  REJECTED
}

// ==========================================
// TIME OFF (Phase 2)
// ==========================================
// Org-defined leave policies (PTO, sick, parental, bereavement…) and
// per-employee requests. Balances are computed lazily from policy
// allowance minus approved/pending hours — no separate Balance table
// to drift out of sync. Carryover and accrual lookbacks live in the
// computation, not the schema.
//
// Timesheets (clock-in/out, hours per task) are a separate surface
// that lands in v2 — they need a different UX (calendar grid + timer)
// and different permission rules.

model TimeOffPolicy {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String
  type             TimeOffType    @default(PTO)
  color            String?
  description      String?

  annualHours      Decimal        @db.Decimal(8, 2)
  carryoverHours   Decimal        @default(0) @db.Decimal(8, 2)
  requiresApproval Boolean        @default(true)
  archived         Boolean        @default(false)

  requests         TimeOffRequest[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, archived])
}

model TimeOffRequest {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId           String
  user             User           @relation("TimeOffSubject", fields: [userId], references: [id])

  policyId         String
  policy           TimeOffPolicy  @relation(fields: [policyId], references: [id], onDelete: Restrict)

  startDate        DateTime
  endDate          DateTime
  // Explicit so partial-day requests (e.g. 4-hour afternoon doctor
  // visit) work — we don't infer days × 8 server-side.
  hours            Decimal        @db.Decimal(6, 2)
  reason           String?

  status           TimeOffStatus  @default(PENDING)
  approverId       String?
  approver         User?          @relation("TimeOffApprover", fields: [approverId], references: [id])
  decisionAt       DateTime?
  decisionNote     String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([approverId, status])
  @@index([userId, startDate])
}

enum TimeOffType {
  PTO
  SICK
  PERSONAL
  BEREAVEMENT
  PARENTAL
  UNPAID
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ==========================================
// TIME TRACKING / TIMESHEETS (Phase 2)
// ==========================================
// Two-mode: knowledge workers fill a weekly grid (web entry); hybrid /
// hourly workers click clock-in/clock-out and the system computes the
// minutes. Both produce TimeEntry rows owned by a weekly Timesheet
// envelope that goes through manager approval.
//
// Cost-center / project attribution rides the polymorphic
// TagAssignment table (entityType=TIME_ENTRY would extend the enum
// later — for v1 we tag at the Timesheet level for weekly rollup, and
// optionally link individual entries to a Task).
//
// Mobile, kiosks, and jurisdictional overtime rules (CA daily OT,
// meal-break attestation, etc.) all sit behind this — schema doesn't
// preclude them but UX is v2/v3.

model Timesheet {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId          String
  user            User            @relation("TimesheetSubject", fields: [userId], references: [id])

  // Week anchor — Monday 00:00 UTC of the week. Single canonical
  // representation; the UI handles display in user's locale.
  weekStartDate   DateTime

  status          TimesheetStatus @default(DRAFT)
  submittedAt     DateTime?

  approverId      String?
  approver        User?           @relation("TimesheetApprover", fields: [approverId], references: [id])
  decisionAt      DateTime?
  decisionNote    String?

  entries         TimeEntry[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, weekStartDate])
  @@index([organizationId, status])
  @@index([userId, weekStartDate])
  @@index([approverId, status])
}

model TimeEntry {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  timesheetId     String
  timesheet       Timesheet       @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  // Denormalized for cheap "is user currently clocked in" lookups
  // without a join. Always equal to timesheet.userId.
  userId          String
  user            User            @relation("TimeEntrySubject", fields: [userId], references: [id])

  // Day this entry counts toward — 00:00 UTC. An overnight shift may
  // straddle two days; v1 anchors to the day the punch *started*.
  day             DateTime

  // Set on save. For active punches, hours is null until clockedOutAt
  // arrives, then computed.
  hours           Decimal?        @db.Decimal(5, 2)

  clockedInAt     DateTime?
  clockedOutAt    DateTime?

  description     String?
  source          TimeEntrySource @default(WEB)

  // Optional link to an existing Task (the "what was I working on").
  // Cost-center / business-unit / project tagging rides on the parent
  // Timesheet via TagAssignment.
  taskId          String?
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId, day])
  @@index([userId, day])
  @@index([timesheetId])
  // Hot index for "is this user clocked in right now?" — used on
  // every page load by the topbar's active-punch widget.
  @@index([userId, clockedOutAt])
  @@index([taskId])
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimeEntrySource {
  WEB
  PUNCH
  MOBILE
  KIOSK
  IMPORT
}

// ==========================================
// ATS / RECRUITING (Phase 2)
// ==========================================
// Three core entities — Job (the requisition), Candidate (the person),
// Application (the pipeline state of one candidate against one job).
// Public career-page applications, structured scorecards, interview
// scheduling, and offer-letter generation all sit downstream of this
// minimal triangle.
//
// Email uniqueness on Candidate is org-scoped on purpose — Fortune
// 500 conglomerates run separate hiring orgs across regions / business
// units and the same person legitimately applies through more than
// one. Cross-org dedup happens at the user-account layer when they're
// hired, not at the candidate layer.

model Job {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  status          JobStatus    @default(DRAFT)
  employmentType  EmploymentType @default(FULL_TIME)
  // Location can be a city, "Remote", or "Hybrid - SF". v2 splits to
  // a structured location relation; for v1 free text is enough.
  location        String?

  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  hiringManagerId String?
  hiringManager   User?        @relation("JobHiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)

  // Optional posted salary range. Two separate Decimals so an "at
  // least" or "at most" range works without a sentinel.
  salaryMin       Decimal?     @db.Decimal(12, 2)
  salaryMax       Decimal?     @db.Decimal(12, 2)
  salaryCurrency  String       @default("USD")

  openings        Int          @default(1)
  publishedAt     DateTime?
  closedAt        DateTime?

  applications    Application[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@index([hiringManagerId])
}

model Candidate {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  email           String
  phone           String?
  resumeUrl       String?
  source          String?      // free text, e.g. "LinkedIn", "Referral - Mary G."
  notes           String?

  // Once a candidate is hired we link them to the User they became.
  // Set by the HIRED transition; null otherwise.
  hiredUserId     String?
  hiredUser       User?        @relation("CandidateHiredUser", fields: [hiredUserId], references: [id], onDelete: SetNull)

  applications    Application[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([hiredUserId])
}

model Application {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  jobId           String
  job             Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId     String
  candidate       Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  stage           ApplicationStage @default(APPLIED)
  rejectionReason String?
  source          String?      // optional, mirrors Candidate.source for per-app variation

  recruiterId     String?
  recruiter       User?        @relation("ApplicationRecruiter", fields: [recruiterId], references: [id], onDelete: SetNull)

  notes           String?

  interviews      Interview[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([jobId, candidateId])
  @@index([organizationId, stage])
  @@index([jobId, stage])
  @@index([recruiterId, stage])
  @@index([candidateId])
}

enum JobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

// ==========================================
// ENTERPRISE IDENTITY (SSO / SCIM)
// ==========================================
// One IdentityProvider row per (org, type). Multiple orgs can sit on
// the same vendor (Okta, Azure AD, Google Workspace, OneLogin) but
// each tenant's config is private. SCIM tokens are per-org bearer
// credentials that an IT admin pastes into their IdP — they auth all
// /scim/v2/* endpoints. The token bytes are hashed at rest;
// `tokenPrefix` (first 8 chars) is kept plaintext for UI display
// without enabling reuse.

model IdentityProvider {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type            IdpType  @default(SAML)
  enabled         Boolean  @default(false)

  // SAML fields. OIDC support adds more columns later.
  issuer          String?  // IdP entity ID
  ssoUrl          String?  // IdP login endpoint (HTTP-Redirect or HTTP-POST)
  sloUrl          String?  // logout endpoint
  certificate     String?  // base64-encoded x509, used to verify assertions

  // Attribute mapping — where to pull email / firstName / lastName /
  // (optional) department / accessLevel from the SAML assertion.
  // Defaults match Okta's standard mapping. Stored as JSON for
  // flexibility on per-tenant tweaks.
  attributeMap    Json     @default("{\"email\":\"NameID\",\"firstName\":\"firstName\",\"lastName\":\"lastName\"}")

  // Just-in-time provision: create User on first SAML login if email
  // doesn't exist in the org. Companies running SCIM usually disable
  // this so all account creation is centralized.
  jitProvision    Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, type])
  @@index([organizationId])
}

model ScimToken {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String   // human label, e.g. "Okta production"
  // sha-256 of the raw token bytes; the raw token is shown exactly
  // once at creation and never stored. Lookup on auth = hash incoming
  // bearer and find the row.
  tokenHash       String   @unique
  // First 8 chars of the raw token, e.g. "wkw_a4b2…", so the UI can
  // disambiguate multiple tokens without exposing the full secret.
  tokenPrefix     String

  createdById     String?  // User.id of the admin who minted it
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?

  createdAt       DateTime @default(now())

  @@index([organizationId, revokedAt])
  @@index([tokenHash])
}

enum IdpType {
  SAML
  OIDC
}

// ==========================================
// PROCUREMENT / AP (Phase 3)
// ==========================================
// Vendor → PurchaseOrder → Invoice triangle. Single-line POs in v1
// (one description, one amount, one cost-center tag); multi-line items
// + three-way matching (PO + Goods Receipt + Invoice) come in v2.
// Cost-center attribution via the polymorphic TagAssignment so
// finance can roll spend up by region / project / business unit.

model Vendor {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String
  email           String?
  contactName     String?
  phone           String?
  taxId           String?         // EIN / VAT / GSTIN — free text in v1
  paymentTermsDays Int            @default(30)
  archived        Boolean         @default(false)

  purchaseOrders  PurchaseOrder[]
  invoices        Invoice[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, archived])
}

model PurchaseOrder {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Auto-generated, org-scoped sequential. The DB-side default makes
  // it cheap; we increment and fall back to cuid on collision.
  number          String

  vendorId        String
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  requesterId     String
  requester       User            @relation("POrequester", fields: [requesterId], references: [id])
  approverId      String?
  approver        User?           @relation("POapprover", fields: [approverId], references: [id])

  description     String
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("USD")

  status          PurchaseOrderStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  receivedAt      DateTime?
  submittedAt     DateTime?
  decisionAt      DateTime?
  decisionNote    String?

  invoices        Invoice[]
  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([vendorId, status])
  @@index([requesterId, status])
  @@index([approverId, status])
}

model Invoice {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  vendorId        String
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // Optional link to a PO. Some vendors (utilities, subscriptions) bill
  // without a matching PO — we accept that for v1.
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  invoiceNumber   String          // vendor-supplied identifier
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("USD")

  issueDate       DateTime
  dueDate         DateTime
  status          InvoiceStatus   @default(PENDING)
  paidAt          DateTime?
  decisionAt      DateTime?
  decisionNote    String?

  approverId      String?
  approver        User?           @relation("InvoiceApprover", fields: [approverId], references: [id])

  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, vendorId, invoiceNumber])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([vendorId, status])
  @@index([purchaseOrderId])
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SENT
  RECEIVED
  CLOSED
}

enum InvoiceStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ==========================================
// WORKFORCE PLANNING (Phase 3)
// ==========================================
// Headcount + salary-budget planning per department per period.
// Compared at view-time against live User.departmentId counts and
// (when comp data is available) against the active comp cycle's
// proposed salaries. Multi-scenario plans (Optimistic / Tight) are
// v2 — add a `scenarioName` column when the time comes.

model HeadcountPlan {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  departmentId     String?
  department       Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Free-form period token. Org picks granularity: "2026", "2026-Q1",
  // "2026-H1", "FY27", etc. Treated opaquely server-side; the UI
  // sorts asciibetically which matches lexical year/quarter ordering.
  period           String

  plannedHeadcount Int
  plannedBudget    Decimal?      @db.Decimal(14, 2)
  budgetCurrency   String        @default("USD")
  notes            String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([organizationId, departmentId, period])
  @@index([organizationId, period])
}

// ==========================================
// INTERVIEW SCHEDULING (Phase 2 v2 — extends ATS)
// ==========================================
// One Interview row per scheduled session against an Application.
// Multi-interviewer rounds in v3; for v1 a single interviewer
// suffices for SMB/mid-market hiring loops. Scorecard is a numeric
// score + notes; structured per-competency rubric is v2.

model Interview {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  applicationId   String
  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  interviewerId   String
  interviewer     User            @relation("InterviewInterviewer", fields: [interviewerId], references: [id])

  scheduledAt     DateTime
  durationMinutes Int             @default(30)
  type            InterviewType   @default(SCREEN)
  // Free-text — meeting URL, room name, or on-site address. Linking
  // to the Meeting model is v2.
  location        String?

  status          InterviewStatus @default(SCHEDULED)

  // Post-interview scorecard. 1-5 numeric; notes free-text. v2
  // expands to per-competency rubric.
  score           Int?
  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId, status])
  @@index([applicationId, status])
  @@index([interviewerId, scheduledAt])
}

enum InterviewType {
  SCREEN
  TECHNICAL
  BEHAVIORAL
  ONSITE
  FINAL
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ==========================================
// Payroll (Phase 4)
//
// Two-layer design: native records here capture every pay-period
// fact (gross/net/taxes/deductions/GL postings) so the org keeps
// the source of truth even if the org switches payroll vendors.
// A pluggable provider adapter (CheckHQ today, Gusto/ADP/Rippling
// later) handles tax calc + filing + direct deposit and writes
// results back into Payslip / PayslipLine. This split means we
// can swap vendors without losing history.
// ==========================================

model PayGroup {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  country        String   @default("US")
  currency       String   @default("USD")
  frequency      PayFrequency @default(BIWEEKLY)
  // First-period anchor — every subsequent period start is derived
  // from this date plus N×frequency. Stored explicitly so DST and
  // calendar drift don't compound.
  anchorDate     DateTime
  // Days after period end that paychecks land. Bank cutoff buffer.
  payOffsetDays  Int      @default(3)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payRuns        PayRun[]
  payslips       Payslip[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum PayFrequency {
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
  MONTHLY
}

model PayRun {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payGroupId     String
  payGroup       PayGroup @relation(fields: [payGroupId], references: [id], onDelete: Cascade)
  periodStart    DateTime
  periodEnd      DateTime
  payDate        DateTime
  status         PayRunStatus @default(DRAFT)
  // Totals are derived from Payslip rows but cached here so list
  // views don't N+1. Recomputed on transition to CALCULATED.
  totalGross     Decimal  @default(0) @db.Decimal(14, 2)
  totalNet       Decimal  @default(0) @db.Decimal(14, 2)
  totalTax       Decimal  @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal @default(0) @db.Decimal(14, 2)
  // Vendor reference — opaque id from the provider (CheckHQ run id,
  // etc.) so we can reconcile filings.
  providerRef    String?
  notes          String?
  calculatedAt   DateTime?
  postedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payslips       Payslip[]

  @@unique([payGroupId, periodStart])
  @@index([organizationId, status])
  @@index([payDate])
}

enum PayRunStatus {
  DRAFT       // open for adjustments
  CALCULATING // provider crunching numbers
  CALCULATED  // ready for review
  POSTED      // funds released; immutable
  CANCELLED
}

// Earnings catalog — regular hours, overtime, bonus, commission.
// Each org can extend with custom codes. taxable + W2 box mapping
// captured here so a payroll run knows how to classify each line.
model EarningCode {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String   // e.g. "REG", "OT", "BONUS"
  name           String
  taxable        Boolean  @default(true)
  // GL account hint — final mapping lives in the integration adapter.
  glAccount      String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  payslipLines   PayslipLine[] @relation("PayslipLineEarning")

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Deductions catalog — pre-tax (401k, medical, HSA) vs post-tax
// (Roth 401k, garnishment). preTax flag drives tax base calc.
model DeductionCode {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String   // e.g. "401K", "MED", "DEN"
  name           String
  preTax         Boolean  @default(false)
  // Optional cap per pay period or per year — null means no cap.
  perPeriodCap   Decimal? @db.Decimal(12, 2)
  annualCap      Decimal? @db.Decimal(12, 2)
  glAccount      String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  payslipLines   PayslipLine[] @relation("PayslipLineDeduction")

  @@unique([organizationId, code])
  @@index([organizationId])
}

// One paystub for one employee for one pay period. Lines roll up
// into the totals on the parent. Stored even after the run is
// POSTED so the employee can always reprint.
model Payslip {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payRunId       String
  payRun         PayRun   @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  payGroupId     String
  payGroup       PayGroup @relation(fields: [payGroupId], references: [id], onDelete: Restrict)
  subjectId      String
  subject        User     @relation("PayslipSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  // Cached totals — sum of lines. Recomputed when lines change.
  gross          Decimal  @default(0) @db.Decimal(12, 2)
  net            Decimal  @default(0) @db.Decimal(12, 2)
  tax            Decimal  @default(0) @db.Decimal(12, 2)
  deductions     Decimal  @default(0) @db.Decimal(12, 2)
  hoursWorked    Decimal  @default(0) @db.Decimal(8, 2)
  // Provider reference (CheckHQ paystub id) — null until posted.
  providerRef    String?
  // Where the paid funds went — stored for the employee record. Last
  // 4 digits only; full account info lives at the provider.
  payMethod      PayMethod @default(DIRECT_DEPOSIT)
  bankLast4      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines          PayslipLine[]

  @@unique([payRunId, subjectId])
  @@index([organizationId, subjectId])
  @@index([payGroupId])
}

enum PayMethod {
  DIRECT_DEPOSIT
  CHECK
  WIRE
  MANUAL
}

// One line on a paystub. Either an earning OR a deduction OR a tax
// — exactly one of those three id columns is non-null. Discriminated
// by `kind` for fast filtering.
model PayslipLine {
  id              String   @id @default(cuid())
  payslipId       String
  payslip         Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  kind            PayslipLineKind
  // For EARNING lines:
  earningCodeId   String?
  earningCode     EarningCode? @relation("PayslipLineEarning", fields: [earningCodeId], references: [id], onDelete: Restrict)
  hours           Decimal? @db.Decimal(8, 2)
  rate            Decimal? @db.Decimal(10, 4)
  // For DEDUCTION lines:
  deductionCodeId String?
  deductionCode   DeductionCode? @relation("PayslipLineDeduction", fields: [deductionCodeId], references: [id], onDelete: Restrict)
  // For TAX lines: human-readable label only. Provider does the math.
  taxLabel        String?
  amount          Decimal  @db.Decimal(12, 2)
  // YTD running total at the moment this line was generated. Used
  // for cap enforcement + W-2 reconciliation.
  ytdAmount       Decimal? @db.Decimal(12, 2)

  @@index([payslipId])
  @@index([earningCodeId])
  @@index([deductionCodeId])
}

enum PayslipLineKind {
  EARNING
  DEDUCTION
  TAX
}

// ==========================================
// Benefits (Phase 4)
//
// Plan catalog → open-enrollment windows → per-employee elections
// → pay-period deduction lines. Dependents and life events drive
// off-cycle changes (marriage, birth, qualifying event).
// ==========================================

model BenefitPlan {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           BenefitType
  name           String
  carrier        String?
  description    String?
  // Default tier costs per pay period — can be overridden per
  // BenefitTier row for richer plans.
  employeeCost   Decimal  @default(0) @db.Decimal(10, 2)
  employerCost   Decimal  @default(0) @db.Decimal(10, 2)
  // Effective window — outside this range the plan can't be elected.
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tiers          BenefitTier[]
  enrollments    BenefitEnrollment[]
  enrollmentsInOpen OpenEnrollmentPlan[]

  @@unique([organizationId, name])
  @@index([organizationId, type])
}

enum BenefitType {
  MEDICAL
  DENTAL
  VISION
  LIFE
  DISABILITY_SHORT
  DISABILITY_LONG
  RETIREMENT_401K
  RETIREMENT_ROTH
  HSA
  FSA
  COMMUTER
  OTHER
}

model BenefitTier {
  id             String   @id @default(cuid())
  benefitPlanId  String
  benefitPlan    BenefitPlan @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)
  // Coverage tier label — "Employee", "Employee + Spouse",
  // "Employee + Children", "Family", or org-custom strings.
  tier           String
  employeeCost   Decimal  @db.Decimal(10, 2)
  employerCost   Decimal  @db.Decimal(10, 2)

  enrollments    BenefitEnrollment[]

  @@unique([benefitPlanId, tier])
}

model OpenEnrollment {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Window during which employees can submit elections.
  startDate      DateTime
  endDate        DateTime
  // When the elections take effect (typically Jan 1).
  effectiveDate  DateTime
  status         OpenEnrollmentStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  plans          OpenEnrollmentPlan[]
  enrollments    BenefitEnrollment[]

  @@index([organizationId, status])
}

enum OpenEnrollmentStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

// Junction — which plans are offered in a given OE window.
model OpenEnrollmentPlan {
  id               String   @id @default(cuid())
  openEnrollmentId String
  openEnrollment   OpenEnrollment @relation(fields: [openEnrollmentId], references: [id], onDelete: Cascade)
  benefitPlanId    String
  benefitPlan      BenefitPlan @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)

  @@unique([openEnrollmentId, benefitPlanId])
}

// One employee's election for one plan. Always linked to the OE
// window that produced it (or the LifeEvent for off-cycle changes).
// Status moves DRAFT → SUBMITTED → ACTIVE → ENDED.
model BenefitEnrollment {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          User     @relation("BenefitEnrollmentSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  benefitPlanId    String
  benefitPlan      BenefitPlan @relation(fields: [benefitPlanId], references: [id], onDelete: Restrict)
  benefitTierId    String?
  benefitTier      BenefitTier? @relation(fields: [benefitTierId], references: [id], onDelete: Restrict)
  openEnrollmentId String?
  openEnrollment   OpenEnrollment? @relation(fields: [openEnrollmentId], references: [id], onDelete: SetNull)
  lifeEventId      String?
  lifeEvent        LifeEvent? @relation(fields: [lifeEventId], references: [id], onDelete: SetNull)
  // Per-pay-period cost snapshot at time of election. Pulling from
  // BenefitTier directly would lose history when tier costs change.
  employeeCost     Decimal  @db.Decimal(10, 2)
  employerCost     Decimal  @db.Decimal(10, 2)
  effectiveStart   DateTime
  effectiveEnd     DateTime?
  status           EnrollmentStatus @default(DRAFT)
  notes            String?
  // Provider reference (carrier confirmation id) — null until the
  // adapter has acknowledged the election.
  providerRef      String?
  submittedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, subjectId])
  @@index([benefitPlanId, status])
  @@index([openEnrollmentId])
  @@index([lifeEventId])
}

enum EnrollmentStatus {
  DRAFT
  SUBMITTED
  ACTIVE
  ENDED
  CANCELLED
}

model Dependent {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User     @relation("DependentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  relationship   DependentRelationship
  dateOfBirth    DateTime?
  // Last 4 only — full SSN never stored at app layer; vendor handles.
  ssnLast4       String?
  // Whether this dependent currently appears on any benefit
  // election. Maintained by the adapter when carriers confirm.
  coveredOnPlan  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, ownerId])
}

enum DependentRelationship {
  SPOUSE
  DOMESTIC_PARTNER
  CHILD
  STEPCHILD
  OTHER
}

// Qualifying life event — opens an off-cycle election window for
// the affected employee. The benefits team approves before it
// becomes actionable.
model LifeEvent {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        User     @relation("LifeEventSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  type           LifeEventType
  eventDate      DateTime
  status         LifeEventStatus @default(REPORTED)
  // 60-day default window — adjustable per type / jurisdiction.
  electionWindowEnd DateTime?
  notes          String?
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollments    BenefitEnrollment[]

  @@index([organizationId, subjectId])
  @@index([status])
}

enum LifeEventType {
  MARRIAGE
  DIVORCE
  BIRTH
  ADOPTION
  DEATH
  GAIN_COVERAGE
  LOSS_COVERAGE
  DEPENDENT_LOSS
  ADDRESS_CHANGE
  OTHER
}

enum LifeEventStatus {
  REPORTED
  APPROVED
  REJECTED
  ENROLLED
}

// ==========================================
// Core Financials (Phase 5)
//
// Native double-entry GL. Chart of accounts is per-org so a
// scaling SaaS doesn't enforce a US-only hierarchy on a Dubai
// customer. Journal entries are immutable once posted; reversals
// happen via offsetting entries, never via mutation. Reports
// (P&L, balance sheet, trial balance) read from JournalLine
// aggregates; we never cache balances in a separate Account.balance
// column because they always drift.
// ==========================================

// Chart-of-accounts entry. type drives report classification:
//   ASSET / LIABILITY / EQUITY → balance sheet
//   REVENUE / EXPENSE          → P&L
// `parentId` lets the org build a hierarchy (e.g. Operating Expenses
// → Salaries → US Salaries → Engineering Salaries).
model GlAccount {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Account code — typically a 4-6 digit number (4000-Revenue,
  // 6000-Expense, etc). Unique per org.
  code           String
  name           String
  type           GlAccountType
  parentId       String?
  parent         GlAccount? @relation("GlAccountParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       GlAccount[] @relation("GlAccountParent")
  // Currency the account is denominated in. Multi-currency orgs run
  // separate accounts per currency and consolidate via FX entries.
  currency       String   @default("USD")
  description    String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  debitLines     JournalLine[] @relation("JournalLineDebit")
  creditLines    JournalLine[] @relation("JournalLineCredit")

  @@unique([organizationId, code])
  @@index([organizationId, type])
  @@index([parentId])
}

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// Cost centers / business units. Optional dimension on every
// journal line so reports can filter by department, branch, etc.
model CostCenter {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  journalLines   JournalLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Fiscal year container — one per org per year. Some orgs run
// non-calendar years (Apr-Mar in India) so the start month is
// configurable.
model FiscalYear {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Human label — "FY2026", "FY27" — distinct from the date range.
  label          String
  startDate      DateTime
  endDate        DateTime
  status         FiscalYearStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime @default(now())

  periods        AccountingPeriod[]

  @@unique([organizationId, label])
  @@index([organizationId, status])
}

enum FiscalYearStatus {
  OPEN
  CLOSED
}

// Accounting period — usually monthly, sometimes 4-4-5 retail
// calendar. Posting to a CLOSED period is rejected at the API
// layer.
model AccountingPeriod {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fiscalYearId   String
  fiscalYear     FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  label          String   // "2026-01", "Jan 2026", etc.
  startDate      DateTime
  endDate        DateTime
  status         AccountingPeriodStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime @default(now())

  journalEntries JournalEntry[]

  @@unique([fiscalYearId, label])
  @@index([organizationId, status])
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

// One journal entry — a self-balancing set of debit/credit lines.
// Multiple sources auto-post here: payroll runs, AP invoices, AR
// invoices, expense reimbursements. Manual entries are also
// supported. Total debits MUST equal total credits — enforced at
// the API layer because Prisma can't express the constraint.
model JournalEntry {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodId       String
  period         AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  // Sequential per-org reference (JE-000123). Generated server-side.
  reference      String
  // Ledger date — drives which period the entry hits. Distinct from
  // createdAt (when the row was inserted) to handle back-dated
  // adjustments inside an open period.
  postedAt       DateTime
  description    String
  // Origin of the entry. Auto-posted entries record the upstream
  // entity in `sourceType` + `sourceId` so we can trace lineage.
  source         JournalSource @default(MANUAL)
  sourceType     String?
  sourceId       String?
  status         JournalStatus @default(DRAFT)
  // Manual entries above an org-defined threshold need a second
  // approver before posting. APPROVED → POSTED is irreversible.
  postedById     String?
  postedBy       User? @relation("JournalEntryPostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  approvedById   String?
  approvedBy     User? @relation("JournalEntryApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines          JournalLine[]

  @@unique([organizationId, reference])
  @@index([organizationId, postedAt])
  @@index([periodId, status])
  @@index([sourceType, sourceId])
}

enum JournalSource {
  MANUAL
  PAYROLL
  AP_INVOICE      // bills from vendors (Procurement.Invoice)
  AR_INVOICE      // customer invoices (future Sales module)
  EXPENSE
  PURCHASE_ORDER
  ADJUSTMENT      // period close adjustments
  OPENING_BALANCE
  REVERSAL
}

enum JournalStatus {
  DRAFT
  PENDING        // submitted, awaiting approval
  APPROVED
  POSTED         // immutable
  REVERSED       // a reversal entry exists referencing this one
  VOIDED         // never posted; cancelled while still in draft/pending
}

// One side of a balanced entry. A line is EITHER a debit OR a
// credit — both columns nullable, but the API enforces exactly one
// non-null. amount is always positive; the side is in the column
// choice.
model JournalLine {
  id             String   @id @default(cuid())
  entryId        String
  entry          JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  debitAccountId String?
  debitAccount   GlAccount? @relation("JournalLineDebit", fields: [debitAccountId], references: [id], onDelete: Restrict)
  creditAccountId String?
  creditAccount  GlAccount? @relation("JournalLineCredit", fields: [creditAccountId], references: [id], onDelete: Restrict)
  amount         Decimal  @db.Decimal(14, 2)
  // Optional dimensions for reporting.
  costCenterId   String?
  costCenter     CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  description    String?
  // Multi-currency: amount is in the entry's reporting currency;
  // these capture the original transaction currency + rate.
  txnCurrency    String?
  txnAmount      Decimal? @db.Decimal(14, 2)
  txnFxRate      Decimal? @db.Decimal(14, 8)

  @@index([entryId])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([costCenterId])
}
