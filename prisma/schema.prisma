generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// MULTI-TENANCY & AUTH
// ==========================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  domain    String?
  plan      Plan     @default(STARTER)
  status    OrgStatus @default(ACTIVE)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  departments  Department[]
  roles        Role[]
  kras         KRA[]
  kpis         KPI[]
  tasks        Task[]
  sops         SOP[]
  reviewCycles ReviewCycle[]
  meetings     Meeting[]
  aiQueries    AIQuery[]
  invitations  Invitation[]
  onboardingTemplates OnboardingTemplate[]
  trainingCourses     TrainingCourse[]
  integrations        Integration[]
  subscription        Subscription?
  apiKeys             ApiKey[]
  webhookSubscriptions WebhookSubscription[]
  webhookDeliveries   WebhookDelivery[]
  employeeOfMonths    EmployeeOfMonth[]
  ideas               Idea[]
  offices             Office[]
  sopCategories       SOPCategory[]
  kraCategories       KraCategory[]
  announcements       Announcement[]
  policies            Policy[]
  okrs                OKR[]
  pulseSurveys        PulseSurvey[]
  tools               Tool[]
  assets              Asset[]
  candorSessions      CandorSession[]
  taskLabels          TaskLabel[]
  sopFolders          SOPFolder[]
  secrets             OrgSecret[]
  tags                Tag[]
  tagAssignments      TagAssignment[]
  expenses            Expense[]
  compensationCycles    CompensationCycle[]
  compensationDecisions CompensationDecision[]
  timeOffPolicies     TimeOffPolicy[]
  timeOffRequests     TimeOffRequest[]
  timesheets          Timesheet[]
  timeEntries         TimeEntry[]
  jobs                Job[]
  candidates          Candidate[]
  applications        Application[]
  identityProviders   IdentityProvider[]
  scimTokens          ScimToken[]
  vendors             Vendor[]
  purchaseOrders      PurchaseOrder[]
  invoices            Invoice[]
  headcountPlans      HeadcountPlan[]
  interviews          Interview[]
  payGroups           PayGroup[]
  payRuns             PayRun[]
  earningCodes        EarningCode[]
  deductionCodes      DeductionCode[]
  payslips            Payslip[]
  benefitPlans        BenefitPlan[]
  openEnrollments     OpenEnrollment[]
  enrollments         BenefitEnrollment[]
  dependents          Dependent[]
  lifeEvents          LifeEvent[]
  glAccounts          GlAccount[]
  fiscalYears         FiscalYear[]
  accountingPeriods   AccountingPeriod[]
  journalEntries      JournalEntry[]
  costCenters         CostCenter[]

  @@index([slug])
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

// ==========================================
// Billing + subscriptions
// ==========================================

/// AppSumo lifetime-deal codes.
///
/// AppSumo customers don't pay through Stripe — they redeem a code on
/// the AppSumo marketplace and receive a string they paste into our
/// /redeem page. Each code maps to a plan tier (Tier 1 = 5 seats,
/// Tier 2 = 25 seats, Tier 3 = unlimited, by convention) and is
/// single-use.
///
/// Codes are bulk-imported by WorkwrK staff via the admin panel
/// (CSV from AppSumo merchant dashboard). On redemption we set the
/// org's Subscription plan to ENTERPRISE / SCALE etc., set
/// `stripeCustomerId = null` (no Stripe), and stamp `redeemedById`
/// so refunds can be traced.
model AppsumoCode {
  id             String      @id @default(cuid())
  /// The redemption string the customer pastes in. Unique per code.
  code           String      @unique
  /// Plan tier this code grants. We map AppSumo "Tier 1/2/3" to our
  /// internal Plan enum values via the redemption handler.
  tier           Int         /// 1, 2, 3 — matches AppSumo Tier numbering
  plan           Plan        /// Plan to apply on redemption (e.g. SCALE)
  seats          Int         /// User cap (null-equivalent for unlimited tiers; we use a large int)
  /// Once redeemed, the code is locked. Refunds flip `refunded=true`
  /// without deleting the row so the AppSumo merchant dashboard
  /// reconciliation stays auditable.
  redeemedById   String?
  redeemedByOrg  String?
  redeemedAt     DateTime?
  refundedAt     DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([redeemedByOrg])
  @@index([redeemedAt])
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Canonical state
  plan               Plan
  status             SubscriptionStatus @default(TRIALING)
  billingMode        BillingMode        @default(PER_USER)
  seats              Int                @default(0)

  // Stripe (null on self-hosted / trial / manual invoicing)
  stripeCustomerId       String?        @unique
  stripeSubscriptionId   String?        @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  trialEndsAt        DateTime?
  canceledAt         DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BillingMode {
  PER_USER    // $4/user/month style
  FLAT_TIER   // $50/100/300 per-band flat
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

model User {
  id             String    @id @default(cuid())
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  avatar         String?
  phone          String?
  dateOfBirth    DateTime?
  officeId       String?
  office         Office?      @relation(fields: [officeId], references: [id])
  status         UserStatus @default(ACTIVE)
  joinDate       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String?
  role           Role?        @relation(fields: [roleId], references: [id])
  departmentId   String?
  department     Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id])
  accessLevel    AccessLevel  @default(EMPLOYEE)

  // Email verification — signup sets verifyToken; user confirms via /verify-email.
  emailVerifiedAt  DateTime?
  verifyToken      String?  @unique
  verifyExpiresAt  DateTime?

  // MFA — TOTP (Google Authenticator / Authy / 1Password).
  // Secret stored base32-encoded, only persisted when enrolment completes.
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String?
  mfaBackupCodes   String[] @default([])   // bcrypt-hashed one-time codes

  managerId      String?
  manager        User?    @relation("ManagerReports", fields: [managerId], references: [id])
  directReports  User[]   @relation("ManagerReports")

  skills         UserSkill[]
  certifications Certification[]
  kraAssignments KRAAssignment[]
  kpiRecords     KPIRecord[]
  tasks          Task[]   @relation("TaskAssignee")
  tasksEscalated Task[]   @relation("TaskEscalatedTo")
  sopComplianceRecords SOPCompliance[]
  sopAssignments       SOPAssignment[]
  reviewsAsSubject   Review[]       @relation("ReviewSubject")
  reviewsAsReviewer  Review[]       @relation("ReviewReviewer")
  feedbackGiven      PeerFeedback[] @relation("FeedbackGiver")
  feedbackReceived   PeerFeedback[] @relation("FeedbackReceiver")
  meetingAttendances MeetingAttendee[]
  actionItems        ActionItem[]
  checkIns           CheckIn[]
  aiQueries          AIQuery[]
  notifications      Notification[]
  consentRecords     ConsentRecord[]
  headOfDepartments  Department[] @relation("DepartmentHead")
  onboardingInstances OnboardingInstance[]
  buddyForOnboarding  OnboardingInstance[] @relation("OnboardingBuddy")
  courseEnrollments   CourseEnrollment[]
  externalData        ExternalData[]
  activityLogs        ActivityLog[]
  performanceScores   PerformanceScore[]
  kudosGiven          Kudos[] @relation("KudosGiver")
  kudosReceived       Kudos[] @relation("KudosReceiver")
  kudosReactions      KudosReaction[] @relation("KudosReactionUser")
  employeeOfMonthWins EmployeeOfMonth[]
  ideasSubmitted      Idea[] @relation("IdeaSubmitter")
  ideasReviewed       Idea[] @relation("IdeaReviewer")
  ideaVotes           IdeaVote[]
  ideaComments        IdeaComment[]
  assignedAssets      Asset[]  @relation("AssetAssignee")
  apiKeysCreated      ApiKey[] @relation("ApiKeyCreator")
  webhooksCreated     WebhookSubscription[] @relation("WebhookCreator")
  taskComments        TaskComment[] @relation("TaskCommentAuthor")
  calendarSubscriptions CalendarSubscription[] @relation("CalendarSubscriptionUser")
  sopFolderAccess     SOPFolderAccess[] @relation("SOPFolderAccessUser")
  expensesReported    Expense[] @relation("ExpenseReporter")
  expensesApproved    Expense[] @relation("ExpenseApprover")
  compDecisionsAsSubject  CompensationDecision[] @relation("CompDecisionSubject")
  compDecisionsProposed   CompensationDecision[] @relation("CompDecisionProposer")
  timeOffRequested        TimeOffRequest[] @relation("TimeOffSubject")
  timeOffApproved         TimeOffRequest[] @relation("TimeOffApprover")
  timesheetsAsSubject     Timesheet[] @relation("TimesheetSubject")
  timesheetsApproved      Timesheet[] @relation("TimesheetApprover")
  timeEntriesAsSubject    TimeEntry[] @relation("TimeEntrySubject")
  jobsAsHiringManager     Job[] @relation("JobHiringManager")
  applicationsAsRecruiter Application[] @relation("ApplicationRecruiter")
  candidateRecord         Candidate[] @relation("CandidateHiredUser")
  purchaseOrdersRequested PurchaseOrder[] @relation("POrequester")
  purchaseOrdersApproved  PurchaseOrder[] @relation("POapprover")
  invoicesApproved        Invoice[] @relation("InvoiceApprover")
  interviewsAsInterviewer Interview[] @relation("InterviewInterviewer")
  payslips                Payslip[] @relation("PayslipSubject")
  benefitEnrollments      BenefitEnrollment[] @relation("BenefitEnrollmentSubject")
  dependents              Dependent[] @relation("DependentOwner")
  lifeEvents              LifeEvent[] @relation("LifeEventSubject")
  journalEntriesPosted    JournalEntry[] @relation("JournalEntryPostedBy")
  journalEntriesApproved  JournalEntry[] @relation("JournalEntryApprovedBy")

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([managerId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  PROBATION
  PIP
  NOTICE_PERIOD
}

enum AccessLevel {
  SUPER_ADMIN
  COMPANY_ADMIN
  C_LEVEL
  VP
  DIRECTOR
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  AGENT
  HR
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  accessLevel    AccessLevel @default(EMPLOYEE)
  token          String   @unique
  expiresAt      DateTime
  accepted       Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  roleId         String?
  managerId      String?
  officeId       String?
  createdAt      DateTime @default(now())

  @@index([token])
  @@index([organizationId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ==========================================
// MODULE 1: ORGANIZATION STRUCTURE
// ==========================================

model Department {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String?
  parentId        String?
  parent          Department?  @relation("SubDepartments", fields: [parentId], references: [id])
  subDepartments  Department[] @relation("SubDepartments")
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  headId          String?
  head            User?        @relation("DepartmentHead", fields: [headId], references: [id])
  members         User[]       @relation("DepartmentMembers")
  roles           Role[]
  goals           DepartmentGoal[]
  jobs            Job[]
  headcountPlans  HeadcountPlan[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
}

model DepartmentGoal {
  id           String     @id @default(cuid())
  title        String
  description  String?
  targetValue  Float?
  currentValue Float?     @default(0)
  unit         String?
  deadline     DateTime?
  status       GoalStatus @default(ON_TRACK)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum GoalStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
}

model Role {
  id             String   @id @default(cuid())
  title          String
  description    String?
  level          AccessLevel @default(EMPLOYEE)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  users          User[]
  kraTemplates   KRA[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([title, organizationId])
  @@index([organizationId])
}

// ==========================================
// MODULE 2: PEOPLE PROFILES
// ==========================================

model UserSkill {
  id            String @id @default(cuid())
  name          String
  selfRating    Int    @default(0)
  managerRating Int?
  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, userId])
}

model Certification {
  id          String    @id @default(cuid())
  name        String
  issuer      String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  documentUrl String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

// ==========================================
// MODULE 3: KRA & KPI ENGINE
// ==========================================

model KRA {
  id             String   @id @default(cuid())
  name           String
  description    String?
  category       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String?
  role           Role?    @relation(fields: [roleId], references: [id])
  assignments    KRAAssignment[]
  kpis           KPI[]
  tasks          Task[]
  sops           SOP[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model KRAAssignment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kraId      String
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  weightage  Float    @default(0)
  period     String   @default("ongoing")
  status     KRAStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, kraId])
  @@index([userId])
}

enum KRAStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model KPI {
  id             String   @id @default(cuid())
  name           String
  description    String?
  type           KPIType  @default(QUANTITATIVE)
  unit           String?
  frequency      Frequency @default(MONTHLY)
  targetValue    Float?
  targetLabel    String?
  lowerIsBetter  Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kraId          String?
  kra            KRA?     @relation(fields: [kraId], references: [id])
  records        KPIRecord[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([kraId])
}

enum KPIType {
  QUANTITATIVE
  QUALITATIVE
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model KPIRecord {
  id          String   @id @default(cuid())
  kpiId       String
  kpi         KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period      String
  targetValue Float
  actualValue Float?
  score       Float?
  notes       String?
  managerNotes String?
  evidence    String?
  status      KPIRecordStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([kpiId, userId, period])
  @@index([userId])
  @@index([kpiId])
}

enum KPIRecordStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

// ==========================================
// MODULE 4: TASKS (Calendar Work Items)
// ==========================================

model Task {
  id               String     @id @default(cuid())
  title            String
  description      String?

  // ── Scheduling ──
  // `date` is the legacy day-level anchor (kept for backwards compat).
  // `startAt` / `endAt` are the full timestamps for hour-precise or
  // multi-day tasks. `allDay` mirrors Google Calendar semantics —
  // when true, time-of-day is ignored and the task renders as a pill.
  date             DateTime
  startAt          DateTime?
  endAt            DateTime?
  allDay           Boolean    @default(true)
  estimateHours    Float?
  hoursSpent       Float?
  completedAt      DateTime?
  category         String?
  incompleteReason String?
  recurringGroupId String?
  status           TaskStatus @default(PLANNED)

  // ── Sub-tasks ──
  // One level deep only — validated at API layer. Sub-tasks roll up
  // into the parent's Gantt bar and complete the parent when all children
  // are done.
  parentTaskId     String?
  parent           Task?      @relation("TaskSubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks         Task[]     @relation("TaskSubTasks")

  // ── External calendar sync ──
  // `externalId` + `externalSource` form the idempotency key for
  // two-way sync. Null on Workwrk-native tasks.
  externalId       String?
  externalSource   String?
  syncedAt         DateTime?

  // ── SLA + escalation ──
  // If set, task is considered overdue `slaHours` after `date`.
  // Null = no SLA enforcement. Used by the escalation cron.
  slaHours         Int?
  priority         TaskPriority @default(NORMAL)
  escalatedAt      DateTime?
  escalatedToId    String?
  escalatedTo      User?      @relation("TaskEscalatedTo", fields: [escalatedToId], references: [id])
  // Source = how this task was spawned.
  source           TaskSource @default(MANUAL)
  sourceRef        String?    // opaque ID of the source (e.g. sopId, reviewId)

  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assigneeId       String
  assignee         User       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  kraId            String?
  kra              KRA?       @relation(fields: [kraId], references: [id])

  comments         TaskComment[]
  labels           TaskLabelOnTask[]
  timeEntries      TimeEntry[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([organizationId])
  @@index([assigneeId])
  @@index([date])
  @@index([escalatedToId])
  @@index([organizationId, status, date])
  @@index([parentTaskId])
  @@index([externalSource, externalId])
  @@index([organizationId, assigneeId, startAt])
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("TaskCommentAuthor", fields: [authorId], references: [id])
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([taskId])
  @@index([authorId])
}

model TaskLabel {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String   @default("#d4ff2e")
  createdAt      DateTime @default(now())

  tasks          TaskLabelOnTask[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TaskLabelOnTask {
  taskId   String
  task     Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId  String
  label    TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model CalendarSubscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("CalendarSubscriptionUser", fields: [userId], references: [id], onDelete: Cascade)
  provider        String   // "GOOGLE" | "ICS_EXPORT"
  // Foreign calendar identifier (Google calendar ID, etc.). Null for
  // ICS_EXPORT subscriptions — those use a per-user signed feed token.
  externalCalendarId String?
  // Whether the user opted in to sharing event titles with their
  // manager. When false, events come through as generic "Busy" pills.
  shareTitles     Boolean  @default(false)
  // OAuth credentials for providers that need them. Encrypted at rest
  // is future work; for now, only accessible via this model.
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  // Google's incremental sync token — lets us pull deltas only.
  syncToken       String?
  lastSyncAt      DateTime?
  // "IN" = pull events into Workwrk, "OUT" = push Workwrk tasks to the
  // provider, "BOTH" = two-way. ICS_EXPORT is always OUT.
  direction       String   @default("BOTH")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider, externalCalendarId])
  @@index([userId])
}

enum TaskStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  SOP
  REVIEW
  OKR
  AI
}

// ==========================================
// MODULE 5: SOP MANAGEMENT
// ==========================================

model SOPVersion {
  id          String   @id @default(cuid())
  sopId       String
  sop         SOP      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  description String?
  content     Json
  publishedBy String?
  createdAt   DateTime @default(now())

  @@index([sopId])
  @@index([version])
}

model KraCategory {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
}

model SOPCategory {
  id             String          @id @default(cuid())
  name           String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subcategories  SOPSubcategory[]
  createdAt      DateTime        @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
}

model SOPSubcategory {
  id         String      @id @default(cuid())
  name       String
  categoryId String
  category   SOPCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@unique([name, categoryId])
  @@index([categoryId])
}

model SOP {
  id             String    @id @default(cuid())
  title          String
  description    String?
  // Legacy taxonomy — kept for backwards compatibility and safe rollback
  // after the unification migration. New code should read folder + tags.
  // Values are mirrored on write so old reads keep working until we drop
  // the columns in a later migration.
  category       String?
  subcategory    String?
  sopType        SOPType   @default(WRITTEN)
  kraId          String?
  kra            KRA?     @relation(fields: [kraId], references: [id])
  // Folder is now the single primary taxonomy. NULL = unfoldered (visible
  // to everyone in the org). Non-null = visibility scoped by the folder's
  // access list, inherited from ancestors when not set explicitly.
  folderId       String?
  folder         SOPFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // Cross-cutting tags. Free-form, multi-value, no access control —
  // useful for things that don't map to folder structure (e.g.
  // "Compliance", "Q2-2026", "Onboarding").
  tags           String[]  @default([])
  content        Json
  version        Int       @default(1)
  status         SOPStatus @default(DRAFT)
  shareToken     String?   @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  compliance     SOPCompliance[]
  versions       SOPVersion[]
  assignments    SOPAssignment[]
  processRuns    ProcessRun[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime?

  @@index([organizationId])
  @@index([category])
  @@index([shareToken])
  @@index([folderId])
  @@index([tags], type: Gin)
}

/// Per-organization secrets (BYOK — bring your own key).
///
/// Holds encrypted credentials owned by the customer. Today we only
/// use this for Anthropic API keys (provider="anthropic"), but the
/// shape is provider-keyed so adding OpenAI / Bedrock later is a
/// new row, not a migration.
///
/// Encryption: the `encryptedKey` blob is AES-256-GCM ciphertext
/// produced by src/lib/secrets-crypto.ts using the
/// `SECRETS_ENCRYPTION_KEY` env var as the master key. Plain keys
/// never hit Prisma.
model OrgSecret {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String       // "anthropic" today; future: "openai", "bedrock"
  // The decoded structure stored as { ciphertext, iv, tag, version }.
  encryptedKey   Json
  // Last 4 chars of the plaintext key, for the Settings UI to show
  // which key is currently in use ("…sk-Bw8q") without decrypting.
  keyHint        String?
  // What the customer typed for "Test connection" — only set after a
  // successful test. Drives the green checkmark.
  lastUsedAt     DateTime?
  // Optional model preference. Ignored if null.
  preferredModel String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
}

/// SOP access-scoping unit and primary taxonomy. Folders form a tree
/// (parentId points to the parent). An org admin creates a folder
/// (e.g. "Marketing"), optionally nests sub-folders ("Marketing /
/// Email Campaigns"), drops SOPs into it, and assigns which users
/// can see/contribute via SOPFolderAccess. If a folder has no
/// explicit access list, it inherits the parent's. Admins see every
/// folder regardless of assignment.
model SOPFolder {
  id             String    @id @default(cuid())
  name           String
  color          String?
  icon           String?
  description    String?
  parentId       String?
  parent         SOPFolder?  @relation("SOPFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       SOPFolder[] @relation("SOPFolderTree")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sops           SOP[]
  access         SOPFolderAccess[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Sibling folders (same parent + same org) must have unique names.
  // Postgres treats NULLs as distinct in unique constraints, so the
  // top-level case is also enforced via a partial unique index added
  // in the migration SQL.
  @@unique([organizationId, parentId, name])
  @@index([organizationId])
  @@index([parentId])
}

/// Join table: which users can see and contribute to a given folder.
/// Admins aren't in here — they see all folders implicitly.
model SOPFolderAccess {
  folderId   String
  folder     SOPFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation("SOPFolderAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedAt  DateTime  @default(now())

  @@id([folderId, userId])
  @@index([userId])
}

enum SOPType {
  WRITTEN
  RECORDED
  CHECKLIST
}

