  // 🆕 Phase D1 — Sidekick chat
  chatSessions         ChatSession[]
  // 🆕 Whiteboards (Excalidraw-powered canvases)
  whiteboards          Whiteboard[]
  // 🆕 User-created dashboards (the "+" menu → Dashboard)
  dashboards           Dashboard[]
  // 🆕 Phase 4 — universal Doc + version history. Polymorphic; can
  // attach to any entity (task, ticket, board row) OR stand alone.
  docs                 Doc[]
  // 🆕 Phase 5 — universal Updates feed + Activity log.
  itemUpdates          ItemUpdate[]
  itemActivities       ItemActivity[]
  // 🆕 Phase 7 — polymorphic time-tracking sessions.
  timerSessions        TimerSession[]
  // 🆕 Phase E7 — WorkwrK Helpdesk
  helpdeskCustomers    SupportCustomer[]
  helpdeskTickets      SupportTicket[]
  helpdeskMacros       SupportMacro[]
  // 🆕 Workspaces — per-(org,product) named spaces for "Sales Team A"
  // vs "Sales Team B" customization, the foundation for Studio + the
  // "teams build their own town" vision pillar.
  workspaces           Workspace[]
  // 🆕 Studio boards — user-built tables/kanbans scoped to a workspace.
  // 🆕 Templates this org has published to the marketplace.
  // 🆕 Files primitive — generic drive surface where users compose
  // their own structure (folders + uploaded files). Used by /files
  // and embeddable in any block-based doc / page.
  fileFolders          FileFolder[]
  fileEntries          FileEntry[]
  // 🆕 Forms primitive — user-built forms (any team), submissions
  // pile up in an inbox + can target a Studio board for row inserts.
  formDefinitions      FormDefinition[]
  formSubmissions      FormSubmission[]
  // 🆕 Tables primitive — lightweight Airtable-style data tables.
  // No workspace/permission friction, embeddable in any doc.
  dataTables           DataTable[]
  dataTableRows        DataTableRow[]
  // 🆕 Phase 1 shell — ClickUp parity substrate
  folders              Folder[]
  preference           OrgPreference?
  hrSegments           HRSegment[]
  // 🆕 Phase 5 — weekly review heartbeat
  weeklyReviews        WeeklyReview[]
  // 🆕 Phase 7 — universal polymorphic graph edges
  entityLinks          EntityLink[]

  @@index([slug])
}

// ─────────────────────────────────────────────────────────────────
// Files primitive — Lego block for any team that wants a drive.
// Folders nest. Files live in a folder or at the root. Sharing v1
// is org-wide read; per-folder ACLs are v2 (and follow the
// SOPFolderAccess pattern when needed).
// ─────────────────────────────────────────────────────────────────
model FileFolder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  parentId       String?
  parent         FileFolder?  @relation("FileFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       FileFolder[] @relation("FileFolderTree")
  files          FileEntry[]
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, parentId])
}

model FileEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String // display name (original filename)
  mimeType       String
  size           Int // bytes
  url            String // resolvable URL: /api/uploads/<key> or S3
  folderId       String?
  folder         FileFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // 🆕 Phase 20 — Optional Space anchor so an attachment uploaded from
  // a Board/Item inside a Space is filterable + restorable in the
  // right context. Org-wide uploads (Library tab without a Space chip
  // selected) leave this null.
  spaceId        String?
  uploadedById   String
  // Light, optional metadata — text caption, color tag for sorting.
  description    String?
  starred        Boolean      @default(false)
  // 🆕 AI-generated summary (Claude) — populated on demand from
  // /api/files/[id]/summarize. Null until first run. Pairs with
  // `summarizedAt` so callers can show "summarized 2 days ago".
  summary        String?
  summarizedAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, folderId])
  @@index([uploadedById])
  @@index([organizationId, spaceId])
}

// ─────────────────────────────────────────────────────────────────
// Forms primitive — composable data collection.
// `fields` is a JSON array of question definitions (type, label,
// required, options...). Submissions store one Json blob keyed by
// field id. Same Lego philosophy as Files: a form is a thing users
// build, embed anywhere via the Form block.
// ─────────────────────────────────────────────────────────────────
model FormDefinition {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  fields         Json             @default("[]")
  // Public form = anyone with the link can submit (no login needed).
  isPublic       Boolean          @default(false)
  // Optional Studio-board target — submissions add a row there.
  targetBoardId  String?
  // Optional DataTable target — submissions add a row there (independent
  // of targetBoardId; both can be set, in which case both get a row).
  targetTableId  String?
  // Explicit per-form-field → target-column mapping. Shape:
  //   { board?: { [formFieldId]: boardFieldKey },
  //     table?: { [formFieldId]: tableColumnId } }
  // When absent for a given form field, the submission handler falls
  // back to case-insensitive label matching.
  fieldMappings  Json             @default("{}")
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  submissions    FormSubmission[]

  @@index([organizationId])
  @@index([createdById])
}

model FormSubmission {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formId         String
  form           FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)
  // { fieldId: value, ... } — schema enforced at write time against
  // the form's current `fields` definition.
  data           Json           @default("{}")
  // Submitter is nullable for public forms.
  submittedById  String?
  submittedAt    DateTime       @default(now())

  @@index([organizationId, formId])
  @@index([formId, submittedAt])
}

// DataTable — lightweight Airtable-style flexible table. Anyone in
// the org can create one; no workspace / permission scoping. Embeds
// cleanly into any block-based doc via the data_table block kind.
//
// `columns` shape: { id, type, label, options?: string[] }[]
// Types: short_text, long_text, number, select, multi_select, date,
//        checkbox, url, email
model DataTable {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  columns        Json           @default("[]")
  // Public tables are readable without auth via /embed/tables/[id] —
  // mirrors how Forms expose a public responder. Org members still see
  // the full editor; outside viewers get a read-only grid.
  isPublic       Boolean        @default(false)
  // 🆕 Phase 32 — Optional Space anchor so a table created from inside
  // a Space (via the SpaceCreatePopover Database row, or auto-tagged
  // from a board's drawer) shows under the right Space chip in /library.
  // Org-wide tables (Library create with no Space chip selected) leave
  // this null and stay visible to everyone in the org.
  spaceId        String?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  rows           DataTableRow[]

  @@index([organizationId])
  @@index([organizationId, spaceId])
  @@index([createdById])
}

model DataTableRow {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tableId        String
  table          DataTable    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  // { columnId: value } — value type matches the column's declared type.
  values         Json         @default("{}")
  position       Int          @default(0)
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tableId, position])
  @@index([organizationId])
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

// ==========================================
// Billing + subscriptions
// ==========================================

/// AppSumo lifetime-deal codes.
///
/// AppSumo customers don't pay through Stripe — they redeem a code on
/// the AppSumo marketplace and receive a string they paste into our
/// /redeem page. Each code maps to a plan tier (Tier 1 = 5 seats,
/// Tier 2 = 25 seats, Tier 3 = unlimited, by convention) and is
/// single-use.
///
/// Codes are bulk-imported by WorkwrK staff via the admin panel
/// (CSV from AppSumo merchant dashboard). On redemption we set the
/// org's Subscription plan to ENTERPRISE / SCALE etc., set
/// `stripeCustomerId = null` (no Stripe), and stamp `redeemedById`
/// so refunds can be traced.
model AppsumoCode {
  id            String    @id @default(cuid())
  /// The redemption string the customer pastes in. Unique per code.
  code          String    @unique
  /// Plan tier this code grants. We map AppSumo "Tier 1/2/3" to our
  /// internal Plan enum values via the redemption handler.
  tier          Int /// 1, 2, 3 — matches AppSumo Tier numbering
  plan          Plan /// Plan to apply on redemption (e.g. SCALE)
  seats         Int /// User cap (null-equivalent for unlimited tiers; we use a large int)
  /// Once redeemed, the code is locked. Refunds flip `refunded=true`
  /// without deleting the row so the AppSumo merchant dashboard
  /// reconciliation stays auditable.
  redeemedById  String?
  redeemedByOrg String?
  redeemedAt    DateTime?
  refundedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([redeemedByOrg])
  @@index([redeemedAt])
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Canonical state
  plan        Plan
  status      SubscriptionStatus @default(TRIALING)
  billingMode BillingMode        @default(PER_USER)
  seats       Int                @default(0)

  // Stripe (null on self-hosted / trial / manual invoicing)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  trialEndsAt DateTime?
  canceledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BillingMode {
  PER_USER // $4/user/month style
  FLAT_TIER // $50/100/300 per-band flat
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  email        String
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  phone        String?
  dateOfBirth  DateTime?
  officeId     String?
  office       Office?    @relation(fields: [officeId], references: [id])
  status       UserStatus @default(ACTIVE)
  joinDate     DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String?
  role           Role?        @relation(fields: [roleId], references: [id])
  departmentId   String?
  department     Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id])
  accessLevel    AccessLevel  @default(EMPLOYEE)

  // Email verification — signup sets verifyToken; user confirms via /verify-email.
  emailVerifiedAt DateTime?
  verifyToken     String?   @unique
  verifyExpiresAt DateTime?

  // MFA — TOTP (Google Authenticator / Authy / 1Password).
  // Secret stored base32-encoded, only persisted when enrolment completes.
  mfaEnabled     Boolean  @default(false)
  mfaSecret      String?
  mfaBackupCodes String[] @default([]) // bcrypt-hashed one-time codes

  managerId     String?
  manager       User?   @relation("ManagerReports", fields: [managerId], references: [id])
  directReports User[]  @relation("ManagerReports")

  skills                  UserSkill[]
  certifications          Certification[]
  kraAssignments          KRAAssignment[]
  kpiRecords              KPIRecord[]
  tasks                   Task[]                       @relation("TaskAssignee")
  tasksEscalated          Task[]                       @relation("TaskEscalatedTo")
  sopComplianceRecords    SOPCompliance[]
  sopAssignments          SOPAssignment[]
  // 🆕 Workspaces — which per-product workspaces this user belongs to.
  workspaceMemberships    WorkspaceMember[]
  reviewsAsSubject        Review[]                     @relation("ReviewSubject")
  reviewsAsReviewer       Review[]                     @relation("ReviewReviewer")
  feedbackGiven           PeerFeedback[]               @relation("FeedbackGiver")
  feedbackReceived        PeerFeedback[]               @relation("FeedbackReceiver")
  meetingAttendances      MeetingAttendee[]
  actionItems             ActionItem[]
  checkIns                CheckIn[]
  aiQueries               AIQuery[]
  notifications           Notification[]
  consentRecords          ConsentRecord[]
  headOfDepartments       Department[]                 @relation("DepartmentHead")
  onboardingInstances     OnboardingInstance[]
  buddyForOnboarding      OnboardingInstance[]         @relation("OnboardingBuddy")
  courseEnrollments       CourseEnrollment[]
  externalData            ExternalData[]
  activityLogs            ActivityLog[]
  performanceScores       PerformanceScore[]
  kudosGiven              Kudos[]                      @relation("KudosGiver")
  kudosReceived           Kudos[]                      @relation("KudosReceiver")
  kudosReactions          KudosReaction[]              @relation("KudosReactionUser")
  employeeOfMonthWins     EmployeeOfMonth[]
  ideasSubmitted          Idea[]                       @relation("IdeaSubmitter")
  ideasReviewed           Idea[]                       @relation("IdeaReviewer")
  ideaVotes               IdeaVote[]
  ideaComments            IdeaComment[]
  assignedAssets          Asset[]                      @relation("AssetAssignee")
  apiKeysCreated          ApiKey[]                     @relation("ApiKeyCreator")
  webhooksCreated         WebhookSubscription[]        @relation("WebhookCreator")
  taskComments            TaskComment[]                @relation("TaskCommentAuthor")
  calendarSubscriptions   CalendarSubscription[]       @relation("CalendarSubscriptionUser")
  sopFolderAccess         SOPFolderAccess[]            @relation("SOPFolderAccessUser")
  expensesReported        Expense[]                    @relation("ExpenseReporter")
  expensesApproved        Expense[]                    @relation("ExpenseApprover")
  compDecisionsAsSubject  CompensationDecision[]       @relation("CompDecisionSubject")
  compDecisionsProposed   CompensationDecision[]       @relation("CompDecisionProposer")
  timeOffRequested        TimeOffRequest[]             @relation("TimeOffSubject")
  timeOffApproved         TimeOffRequest[]             @relation("TimeOffApprover")
  timesheetsAsSubject     Timesheet[]                  @relation("TimesheetSubject")
  timesheetsApproved      Timesheet[]                  @relation("TimesheetApprover")
  timeEntriesAsSubject    TimeEntry[]                  @relation("TimeEntrySubject")
  jobsAsHiringManager     Job[]                        @relation("JobHiringManager")
  applicationsAsRecruiter Application[]                @relation("ApplicationRecruiter")
  candidateRecord         Candidate[]                  @relation("CandidateHiredUser")
  purchaseOrdersRequested PurchaseOrder[]              @relation("POrequester")
  purchaseOrdersApproved  PurchaseOrder[]              @relation("POapprover")
  invoicesApproved        Invoice[]                    @relation("InvoiceApprover")
  interviewsAsInterviewer Interview[]                  @relation("InterviewInterviewer")
  payslips                Payslip[]                    @relation("PayslipSubject")
  benefitEnrollments      BenefitEnrollment[]          @relation("BenefitEnrollmentSubject")
  dependents              Dependent[]                  @relation("DependentOwner")
  lifeEvents              LifeEvent[]                  @relation("LifeEventSubject")
  journalEntriesPosted    JournalEntry[]               @relation("JournalEntryPostedBy")
  journalEntriesApproved  JournalEntry[]               @relation("JournalEntryApprovedBy")
  announcementAcks        AnnouncementAcknowledgment[] @relation("AnnouncementAckUser")
  organizationMemberships OrganizationMembership[]     @relation("OrgMembershipUser")

  // 🆕 Phase 1 shell — ClickUp parity substrate
  preference             UserPreference?
  spaceMemberships       SpaceMember[]
  // 🆕 Phase 23 — per-board access overrides
  boardMemberships       BoardMember[] @relation("BoardMemberUser")
  dottedLineToManagers   UserDottedLine[] @relation("DottedLineFromUser")
  dottedLineFromReports  UserDottedLine[] @relation("DottedLineToManager")
