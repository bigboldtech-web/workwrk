  name           String
  description    String?
  url            String?
  icon           String?      // emoji or URL
  category       String?      // "Communication", "Design", "Development", "Finance", "HR", "Marketing", "Sales", "Other"
  credentials    Json?        // { username, password, apiKey, notes } — encrypted at rest
  addedBy        String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shares         ToolShare[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model ToolShare {
