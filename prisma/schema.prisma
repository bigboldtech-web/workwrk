// ==========================================
// 🆕 PHASE D1 · Sidekick (real AI chat)
// Persisted multi-turn conversations with Claude. Each session belongs
// to one user; messages stamp the role + token/cost telemetry from the
// Anthropic SDK response. Tools live in a separate JSON field so we
// can experiment with tool calling without schema changes.
// ==========================================

model ChatSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String // the person whose chat this is
  title          String? // auto-derived from first user message (truncated)
  pinned         Boolean      @default(false)
  archivedAt     DateTime?
  // Optional agent this session is scoped to. Null = general Sidekick.
  // When set, /api/sidekick/chat uses that agent's systemPrompt instead.
  agentId        String?
  agent          Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  // Board-level context — when the session was opened from inside an
  // app surface (e.g. clicking the Sidekick link on /crm/pipeline),
  // we stash the product slug and the active board key here. The chat
  // runtime uses these to (a) light up the product's tools even
  // without an agent and (b) augment the system prompt with "user is
  // currently viewing X". Frees the AI from having to ask "which board
  // do you mean?" — it already knows.
  productContext String?
  boardContext   String?
  // Last assistant model used for this session — handy for "the model
  // changed mid-thread" diagnostics + cost analytics.
  lastModel      String?
  totalTokensIn  Int          @default(0)
  totalTokensOut Int          @default(0)
  totalCostCents Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  messages ChatMessage[]

  @@index([organizationId, userId, updatedAt])
  @@index([userId, pinned, updatedAt])
  @@index([agentId])
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         ChatRole
  content      String      @db.Text
  // Anthropic SDK response telemetry. Null on user/system messages.
  modelUsed    String?
  tokensIn     Int?
  tokensOut    Int?
  costCents    Int?
  // Future: tool calls + tool results. For now stored as opaque JSON.
  toolCalls    Json?
  finishReason String? // "stop_reason" from the SDK response
  createdAt    DateTime    @default(now())

  @@index([sessionId, createdAt])
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

// ==========================================
// 🆕 Whiteboards — Excalidraw-powered infinite canvas
// Mind maps, diagrams, brainstorming, retros, flow charts. Each board
// is one row; the `scene` JSON holds the full Excalidraw scene
// (elements + appState). Lightweight + auditable: who created, who
// last touched, when, and a thumbnail for the listing page.
// ==========================================

model Whiteboard {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?      @db.Text
  // The Excalidraw scene serialized — { elements: [...], appState: {...},
  // files: {...} }. Opaque to us; round-tripped to/from the client.
  scene          Json         @default("{}")
  // Optional preview image (data URL or S3 key) generated on save so the
  // listing page can show what's inside without loading the full scene.
  thumbnail      String?      @db.Text
  // Owner is the creator. Edit access is org-wide by default; share
  // policies (public links, granular permissions) come in a follow-up.
  ownerId        String?
  lastEditedById String?
  lastEditedAt   DateTime?
  archivedAt     DateTime?
  // Optional pinning to a Space or Product so it shows under the right
  // surface (e.g. a brainstorm tied to /marketing or /dev).
  spaceId        String?
  productSlug    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, archivedAt])
  @@index([organizationId, ownerId])
  @@index([spaceId])
  @@index([productSlug])
}

// User-created dashboards (the sidebar "+" menu → Dashboard). v1 stores
// the widget list as opaque JSON; the widget-canvas renderer lands with
// the Dashboard view phase (docs/plans/views-catalog.md §B).
model Dashboard {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?      @db.Text
  // Widget list — [{ id, type, config }] — opaque to the server.
  widgets        Json         @default("[]")
  // Owner is the creator. Org-wide visibility by default, mirroring
  // Whiteboard; granular sharing is a follow-up.
  ownerId        String?
  archivedAt     DateTime?
  // Optional pinning to a Space so it shows under that surface.
  spaceId        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, archivedAt])
  @@index([organizationId, ownerId])
  @@index([spaceId])
}

// ==========================================
// 🆕 PHASE E7 · WorkwrK Helpdesk
// External customer support — distinct from ITSM (internal IT). The
// requester is a customer (not an internal User), conversations
// stretch over multiple channels, and macros + CSAT are first-class.
// Buyer story: Customer Support Manager.
// ==========================================

model SupportCustomer {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String?
  email           String
  companyName     String?
  phone           String?
  // Optional CRM Account link — when a support customer matches a CRM
  // account by domain or name, we surface the relationship.
  linkedAccountId String?
  notes           String?      @db.Text
  customFields    Json         @default("{}")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tickets SupportTicket[]

  @@unique([organizationId, email])
  @@index([organizationId, companyName])
  @@index([linkedAccountId])
}

model SupportTicket {
  id                 String              @id @default(cuid())
  organizationId     String
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subject            String
  body               String?             @db.Text
  customerId         String
  customer           SupportCustomer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel            SupportChannel      @default(EMAIL)
  status             SupportTicketStatus @default(NEW)
  priority           SupportPriority     @default(NORMAL)
  category           String? // "Billing" | "Product" | "Bug" | "Feature Request" | "Onboarding"
  assigneeId         String? // internal support agent
  // SLA driven by tier: free customers get longer SLAs than enterprise.
  slaTier            String? // "Free" | "Standard" | "Premium" | "Enterprise"
  firstResponseDueAt DateTime?
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  // CSAT (0-5) collected after resolution.
  csatScore          Int?
  csatComment        String?             @db.Text
  // Tags for filtering (e.g. "shipping-bug", "v2024.11-issue").
  tags               Json                @default("[]")
  customFields       Json                @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, assigneeId])
  @@index([organizationId, customerId])
  @@index([organizationId, priority])
  @@index([firstResponseDueAt])
}

enum SupportTicketStatus {
  NEW
  OPEN
  PENDING_CUSTOMER
  PENDING_INTERNAL
  RESOLVED
  CLOSED
  SPAM
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportChannel {
  EMAIL
  CHAT
  PHONE
  PORTAL
  SOCIAL
  IN_APP
}

model SupportMacro {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Short trigger name (e.g. "refund-policy") that an agent types or
  // pastes to insert this canned response.
  slug           String
  title          String
  body           String       @db.Text
  category       String? // "Billing" | "Product" | "Onboarding" | ...
  // If true, applying this macro also moves the ticket to RESOLVED.
  resolves       Boolean      @default(false)
  archivedAt     DateTime?
  usageCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, category])
}

// ════════════════════════════════════════════════════════════════════
// Universal Doc + version history — Phase 4 of the monday polish.
// ════════════════════════════════════════════════════════════════════
//
// A Doc is a rich-text document that can either stand alone (a note
// the user wrote) or be attached to any other entity via the
// polymorphic (entityType, entityId) pair — task description, ticket
// resolution write-up, contract redline notes, board row Doc cell.
//
// Critical guarantee: every save creates a new DocVersion row,
// immutable. Restore = create a new version with old content. No
// hard delete on either Doc or DocVersion — only `archivedAt` on Doc.
// This is how we keep the user's promise: data can never be lost.

model Doc {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title   String
  // TipTap JSON document. Starts as empty doc; every save updates.
  content Json    @default("{}")
  // Plain-text excerpt for search/list previews — derived on save.
  excerpt String? @db.Text

  // Polymorphic owner. Both null = standalone doc.
  entityType String? // "TASK" | "TICKET" | "BOARD_ROW" | …
  entityId   String?

  // Notion-style page tree (standalone notes only). A note may live inside
  // another note or a folder; `isFolder` marks pure containers. `position`
  // orders siblings (fractional so drag-inserts don't renumber the list).
  parentId String?
  parent   Doc?    @relation("DocTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Doc[]   @relation("DocTree")
  isFolder Boolean @default(false)
  position Float   @default(0)

  createdById String?
  archivedAt  DateTime? // soft-archive only; never hard-delete

  // 🆕 AI-generated summary (Claude) — populated on demand from
  // /api/docs/[id]/summarize. Useful in list views to show what a
  // doc is about without opening it.
  summary      String?   @db.Text
  summarizedAt DateTime?

  versions DocVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdById])
  @@index([parentId])
}

model DocVersion {
  id    String @id @default(cuid())
  docId String
  doc   Doc    @relation(fields: [docId], references: [id], onDelete: Cascade)

  // Monotonically incremented per Doc. Doc.versions[0] = v1.
  version Int
  title   String
  // Frozen snapshot of TipTap JSON at this version.
  content Json

  // Who saved this version. Null only for system-generated snapshots
  // (e.g. an import or a migration).
  authorId String?

  createdAt DateTime @default(now())

  @@unique([docId, version])
  @@index([docId])
  @@index([createdAt])
}

// ════════════════════════════════════════════════════════════════════
// Item Updates + Activity log — Phase 5 of the monday polish.
// ════════════════════════════════════════════════════════════════════
//
// Both are polymorphic on (entityType, entityId) — attach to any row
// in any module. ItemUpdate is user-authored ("Customer escalated to
// priority 1"); ItemActivity is auto-emitted ("Status changed from
// OPEN to RESOLVED by @alice").
//
// Updates: soft-archive only. Activity: immutable, no archive.

model ItemUpdate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entityType String // "TASK" | "LEAD" | "TICKET" | "CONTRACT" | …
  entityId   String

  authorId String?
  body     String  @db.Text // rich HTML — TipTap output

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, entityType, entityId])
  @@index([authorId])
}

model ItemActivity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entityType String
  entityId   String

  actorId String? // null = system-emitted (cron, webhook)
  action  String // "CREATED" | "STATUS_CHANGED" | "ASSIGNED" | …
  // Arbitrary detail — e.g. { from: "OPEN", to: "RESOLVED" } for
  // status changes, { field: "priority", from: "LOW", to: "HIGH" }
  // for field edits. Renderable client-side per `action` kind.
  meta    Json    @default("{}")

  createdAt DateTime @default(now())

  @@index([organizationId, entityType, entityId])
  @@index([createdAt])
  @@index([actorId])
}

// ════════════════════════════════════════════════════════════════════
// Time-tracking — Phase 7 of the monday polish.
// ════════════════════════════════════════════════════════════════════
//
// One row per Start/Stop session. The accumulated time on an entity
// is SUM(durationMs) across all stopped sessions plus the in-flight
// session (if any). Per-user — multiple people can have concurrent
// timers on the same ticket without conflict.

model TimerSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entityType String // "TICKET" | "TASK" | "LEAD" | …
  entityId   String

  userId     String
  startedAt  DateTime  @default(now())
  stoppedAt  DateTime? // null = currently running
  // Cached so list views don't have to compute it. Set on stop.
  durationMs Int       @default(0)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, entityType, entityId])
  @@index([userId, stoppedAt])
  @@index([organizationId, userId])
}

// ════════════════════════════════════════════════════════════════════
// Phase 7 · EntityLink — the universal connective tissue.
// ════════════════════════════════════════════════════════════════════
//
// Any-to-any polymorphic links between entities in the system. A Task
// links 3 Notes + 1 Whiteboard; an SOP embeds its source Doc; a KRA
// references a strategy Whiteboard; a board row pulls in a Note.
//
// We deliberately avoid hard FK columns per relationship — every
// "linkable" entity declares its participation by string type, and
// EntityLink rows store the graph. This is what lets new entity kinds
// join the graph without schema changes per pair.
//
// Symmetry: a link is directed (source → target) but lookups are
// indexed in both directions so "what does X link to" and "what
// links to X" are both fast.
//
// relationKind lets the same pair carry different semantics:
//   LINKED            — generic association ("see also")
//   EMBEDDED          — target is rendered inline inside the source
//   REQUIRED_READING  — target must be acknowledged before completion
//   REFERENCES        — citation/footnote-style backlink

model EntityLink {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  sourceType EntityLinkType
  sourceId   String
  targetType EntityLinkType
  targetId   String

  relationKind EntityLinkRelation @default(LINKED)

  // Optional ordering for "embedded" links (so a doc with 5 embedded
  // whiteboards renders them in user-chosen order).
  position Int @default(0)

  // Optional context note ("Why is this linked?"). Plain text.
  context String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceType, sourceId, targetType, targetId, relationKind])
  @@index([organizationId, sourceType, sourceId])
  @@index([organizationId, targetType, targetId])
  @@index([organizationId, relationKind])
}

enum EntityLinkType {
  TASK
  BOARD
  BOARD_ITEM
  SPACE
  FOLDER
  KRA
  KPI
  KPI_PROMPT
  SOP
  OKR
  KEY_RESULT
  REVIEW
  REVIEW_CYCLE
  WEEKLY_REVIEW
  NOTE
  DOC
  WHITEBOARD
  FILE
  FORM
  TABLE
  USER
  DEPARTMENT
  ROLE
  ANNOUNCEMENT
  KUDOS
  CANDOR
  SURVEY
  CONTRACT
  CANDIDATE
  JOB
}

enum EntityLinkRelation {
  LINKED
  EMBEDDED
  REQUIRED_READING
  REFERENCES
}
