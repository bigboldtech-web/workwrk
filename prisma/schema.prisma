  status          PrivacyRequestStatus @default(RECEIVED)
  subjectEmail    String
  subjectName     String?
  subjectId       String? // optional User id if matched to an internal account
  // The legal framework the request was filed under (drives the SLA).
  jurisdiction    String? // "GDPR" | "CCPA" | "LGPD" | "PIPEDA" | "Other"
  // Verification status — anti-fraud measure. Identity must be verified
  // before fulfilling Access/Deletion requests.
  verifiedAt      DateTime?
  receivedAt      DateTime             @default(now())
  dueAt           DateTime? // computed from jurisdiction SLA
  completedAt     DateTime?
  assigneeId      String?
  notes           String?              @db.Text
  resolutionNotes String?              @db.Text
  customFields    Json                 @default("{}")
  createdAt       DateTime             @default(now())
