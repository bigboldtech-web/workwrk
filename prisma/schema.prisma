  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
}

enum AssetType {
  LAPTOP
  DESKTOP
  MONITOR
  PHONE
  TABLET
  KEYBOARD
  MOUSE
  HEADSET
  WEBCAM
  CHAIR
  DESK
