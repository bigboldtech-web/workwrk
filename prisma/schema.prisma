generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// MULTI-TENANCY & AUTH
// ==========================================

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logo      String?
  domain    String?
  plan      Plan      @default(STARTER)
  status    OrgStatus @default(ACTIVE)
  settings  Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users                 User[]
  departments           Department[]
  roles                 Role[]
  kras                  KRA[]
  kpis                  KPI[]
  tasks                 Task[]
  sops                  SOP[]
  reviewCycles          ReviewCycle[]
  meetings              Meeting[]
  aiQueries             AIQuery[]
  invitations           Invitation[]
  onboardingTemplates   OnboardingTemplate[]
  trainingCourses       TrainingCourse[]
  integrations          Integration[]
  subscription          Subscription?
  apiKeys               ApiKey[]
  webhookSubscriptions  WebhookSubscription[]
  webhookDeliveries     WebhookDelivery[]
  employeeOfMonths      EmployeeOfMonth[]
  ideas                 Idea[]
  offices               Office[]
  sopCategories         SOPCategory[]
  kraCategories         KraCategory[]
  announcements         Announcement[]
  policies              Policy[]
  okrs                  OKR[]
  pulseSurveys          PulseSurvey[]
  tools                 Tool[]
  assets                Asset[]
  candorSessions        CandorSession[]
  taskLabels            TaskLabel[]
  sopFolders            SOPFolder[]
  secrets               OrgSecret[]
  tags                  Tag[]
  tagAssignments        TagAssignment[]
  expenses              Expense[]
  compensationCycles    CompensationCycle[]
  compensationDecisions CompensationDecision[]
  timeOffPolicies       TimeOffPolicy[]
  timeOffRequests       TimeOffRequest[]
  timesheets            Timesheet[]
  timeEntries           TimeEntry[]
  jobs                  Job[]
  candidates            Candidate[]
  applications          Application[]
  identityProviders     IdentityProvider[]
  scimTokens            ScimToken[]
  vendors               Vendor[]
  purchaseOrders        PurchaseOrder[]
  invoices              Invoice[]
  headcountPlans        HeadcountPlan[]
  interviews            Interview[]
  payGroups             PayGroup[]
  payRuns               PayRun[]
  earningCodes          EarningCode[]
  deductionCodes        DeductionCode[]
  payslips              Payslip[]
  benefitPlans          BenefitPlan[]
  openEnrollments       OpenEnrollment[]
  enrollments           BenefitEnrollment[]
  dependents            Dependent[]
  lifeEvents            LifeEvent[]
  glAccounts            GlAccount[]
  fiscalYears           FiscalYear[]
  accountingPeriods     AccountingPeriod[]
  journalEntries        JournalEntry[]
  costCenters           CostCenter[]
  salaryBands           SalaryBand[]
  plans                 BudgetPlan[]
  planScenarios         PlanScenario[]
  planLines             PlanLine[]
  planDrivers           PlanDriver[]
  workflows             Workflow[]
  workflowRuns          WorkflowRun[]
  overtimePolicies      OvertimePolicy[]
  memberships           OrganizationMembership[] @relation("OrgMembershipOrg")

  // 🆕 Phase A — universal primitives
  productInstallations ProductInstallation[]
  spaces               Space[]
  boards               Board[]
  items                Item[]
  agents               Agent[]
  apps                 App[]
  // 🆕 Phase E2 — WorkwrK CRM
  crmLeads             Lead[]
  crmAccounts          Account[]
  crmOpportunities     Opportunity[]
  pipelineStages       PipelineStage[]
  // 🆕 Phase E3 — WorkwrK ITSM
  itsmTickets          Ticket[]
  itsmIncidents        Incident[]
  itsmKbArticles       KbArticle[]
  // 🆕 Phase E4 — WorkwrK Marketing
  mktCampaigns         Campaign[]
  mktContentItems      ContentItem[]
  mktEventBriefs       EventBrief[]
  // 🆕 Phase E5 — WorkwrK Dev
  devSprints           Sprint[]
  devReleases          Release[]
  devRoadmapItems      RoadmapItem[]
  // 🆕 Phase E6 — WorkwrK Legal
  legalContracts       Contract[]
  legalPrivacyRequests PrivacyRequest[]
