  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([sopId])
  @@index([assigneeId])
  @@index([organizationId])
  @@index([shareToken])
  @@index([status])
}

enum ProcessRunStatus {
