// ==========================================
// IDEAS BOARD
// ==========================================

model Idea {
  id             String        @id @default(cuid())
  title          String
  description    String
  category       String?
  status         IdeaStatus    @default(SUBMITTED)
  submitterId    String
  submitter      User          @relation("IdeaSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  reviewerId     String?
  reviewer       User?         @relation("IdeaReviewer", fields: [reviewerId], references: [id])
  reviewNotes    String?
  rewardType     String?
  rewardValue    String?
  rewardedAt     DateTime?
  // Manual sort within (organizationId, status). Lower = higher in
  // the priority list. The reorder API writes a batch of positions
  // in a single transaction so the list is consistent at rest.
  position       Int           @default(0)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  votes          IdeaVote[]
  comments       IdeaComment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([submitterId])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId, status, position])
}

enum IdeaStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  REWARDED
}

model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
}

model IdeaComment {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([ideaId])
}

// ==========================================
// ANNOUNCEMENTS
// ==========================================

model Announcement {
  id                  String                       @id @default(cuid())
  title               String
  content             String
  type                String                       @default("INFO") // INFO, WARNING, CELEBRATION, POLICY, EVENT
  priority            String                       @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  pinned              Boolean                      @default(false)
  // When true, the feed surfaces a banner until every targeted user
  // posts an Acknowledgment row. Admins see a "who hasn't acked" list.
  mustAcknowledge     Boolean                      @default(false)
  publishedAt         DateTime?
  // Set by the scheduled-publish cron the first time a deferred post
  // crosses its publishedAt boundary. Null means the notify/email
  // blast has not yet fired. The cron uses (publishedAt <= now AND
  // notificationsSentAt IS NULL) as its work-queue filter.
  notificationsSentAt DateTime?
  expiresAt           DateTime?
  targetAudience      Json?
  authorId            String
  organizationId      String
  organization        Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dismissals          AnnouncementDismissal[]
  acknowledgments     AnnouncementAcknowledgment[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([organizationId])
  @@index([publishedAt])
  // Cron-queue index: surfaces pending scheduled posts cheaply.
  @@index([publishedAt, notificationsSentAt])
}

model AnnouncementDismissal {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  dismissedAt    DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}

/// Records that a user has explicitly acknowledged a must-acknowledge
/// announcement. Mirrors PolicyAcknowledgment — same shape, different
/// source. Unique (announcementId, userId) so a user cannot
/// double-ack a single post.
model AnnouncementAcknowledgment {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("AnnouncementAckUser", fields: [userId], references: [id])
  acknowledgedAt DateTime     @default(now())
  ipAddress      String?

  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

// ==========================================
// COMPANY POLICIES & BYLAWS
// ==========================================

model Policy {
  id              String                 @id @default(cuid())
  title           String
  content         String
  category        String? // "HR", "Security", "Compliance", "Operations", "Code of Conduct", "Leave", "Expense"
  version         Int                    @default(1)
  status          String                 @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  requiresAck     Boolean                @default(true) // Requires employee acknowledgment
  effectiveDate   DateTime?
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acknowledgments PolicyAcknowledgment[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([organizationId])
  @@index([status])
}

model PolicyAcknowledgment {
  id             String   @id @default(cuid())
  policyId       String
  policy         Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  userId         String
  acknowledgedAt DateTime @default(now())
  ipAddress      String?

  @@unique([policyId, userId])
  @@index([userId])
  @@index([policyId])
}

// ==========================================
// OKR (OBJECTIVES & KEY RESULTS)
// ==========================================

model OKR {
  id             String       @id @default(cuid())
  title          String
  description    String?
  level          String       @default("INDIVIDUAL") // COMPANY, TEAM, INDIVIDUAL
  status         String       @default("ON_TRACK") // ON_TRACK, AT_RISK, BEHIND, COMPLETED
  progress       Int          @default(0) // 0-100
  startDate      DateTime?
  endDate        DateTime?
  quarter        String? // "Q2 2026"
  // Check-in rhythm. Drives the reminder cron + the "stale" badge on
  // the personal hero. Defaults to weekly because that's what most
  // teams settle on.
  checkInCadence String       @default("WEEKLY") // WEEKLY, BIWEEKLY, MONTHLY
  ownerId        String?
  departmentId   String?
  parentId       String?
  parent         OKR?         @relation("OKRChildren", fields: [parentId], references: [id])
  children       OKR[]        @relation("OKRChildren")
  keyResults     KeyResult[]
  // Manual sort within (organizationId, ownerId, quarter). Lower =
  // higher on the owner's OKR list. Defaults to 0 so legacy rows
  // appear at the top until explicitly reordered.
  position       Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([ownerId])
  @@index([parentId])
  @@index([level])
  @@index([quarter])
  @@index([organizationId, ownerId, position])
}

model KeyResult {
  id             String      @id @default(cuid())
  title          String
  unit           String? // %, count, $, etc.
  startValue     Float       @default(0)
  targetValue    Float
  currentValue   Float       @default(0)
  progress       Int         @default(0) // 0-100 auto-calculated
  // When we last fired a "you haven't checked in lately" reminder for
  // this KR. Used to avoid spamming the owner — see scripts/api
  // /api/cron/okr-reminders.
  lastReminderAt DateTime?
  okrId          String
  okr            OKR         @relation(fields: [okrId], references: [id], onDelete: Cascade)
  checkIns       KRCheckIn[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([okrId])
}

model KRCheckIn {
  id          String    @id @default(cuid())
  keyResultId String
  keyResult   KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  value       Float
  note        String?
  userId      String
  createdAt   DateTime  @default(now())

  @@index([keyResultId])
}

// ==========================================
// 9-BOX GRID (TALENT CALIBRATION)
// ==========================================

model TalentAssessment {
  id             String   @id @default(cuid())
  userId         String
  period         String // "Q2 2026"
  performance    Int // 1-3 (Low, Medium, High)
  potential      Int // 1-3 (Low, Medium, High)
  boxPosition    String // "1-1", "1-2", etc.
  action         String? // "Promote", "Develop", "Retain", "Coach", "PIP", "Exit"
  notes          String?
  assessedBy     String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, period, organizationId])
  @@index([organizationId])
  @@index([period])
}

// ==========================================
// PULSE SURVEYS
// ==========================================

model PulseSurvey {
  id             String           @id @default(cuid())
  title          String
  questions      Json // [{id, text, type: "rating"|"text"|"nps"}]
  status         String           @default("DRAFT") // DRAFT, ACTIVE, CLOSED
  frequency      String? // WEEKLY, MONTHLY, QUARTERLY
  audienceType   String           @default("ALL") // ALL, OFFICES, DEPARTMENTS, USERS
  officeIds      String[]         @default([])
  departmentIds  String[]         @default([])
  userIds        String[]         @default([])
  // When true, responses are visible to managers in aggregate only — no
  // respondent name, no individual attribution. Default true to preserve
  // existing survey trust assumptions. Managers can opt a survey into
  // attributed mode at create time when the context calls for it (e.g.
  // post-review pulse tied to a 1:1 follow-up).
  anonymous      Boolean          @default(true)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses      SurveyResponse[]
  createdAt      DateTime         @default(now())
  closedAt       DateTime?
  // Hard deadline for collecting responses. When set, the rotate cron
  // auto-closes the survey at this time and — if `frequency` is set —
  // spawns the next cycle. A reminder email to anyone in the audience
  // who hasn't responded goes out ~24h before.
  closesAt       DateTime?
  reminderSentAt DateTime?
  // When a survey was spawned by the rotate cron as the next cycle of
  // a recurring template, `parentSurveyId` points back to the most
  // recent prior cycle. Null for one-off surveys and for the first
  // cycle of any recurrence.
  parentSurveyId String?
  parent         PulseSurvey?     @relation("PulseSurveyRecurrence", fields: [parentSurveyId], references: [id], onDelete: SetNull)
  children       PulseSurvey[]    @relation("PulseSurveyRecurrence")

  @@index([organizationId])
  @@index([status])
  @@index([status, closesAt])
  @@index([parentSurveyId])
}

model SurveyResponse {
  id        String      @id @default(cuid())
  surveyId  String
  survey    PulseSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId    String
  answers   Json // [{questionId, value}]
  createdAt DateTime    @default(now())

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ==========================================
// 1:1 MEETING TEMPLATES
// ==========================================

model MeetingTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?
  type           String   @default("ONE_ON_ONE") // ONE_ON_ONE, TEAM_STANDUP, QUARTERLY_REVIEW
  agendaItems    Json // [{title, description, timeMinutes, type: "discussion"|"action"|"review"}]
  isDefault      Boolean  @default(false)
  organizationId String? // null = system template
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

