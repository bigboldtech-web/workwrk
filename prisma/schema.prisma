/// One row per (user, organization) that the user can act inside. Today
/// every user has exactly one membership matching `User.organizationId`
/// (backfilled by the migration). The model exists so the org-switcher
/// flow has somewhere to grow: invite a user into a second org, add a
/// row here, and the topbar dropdown surfaces it. `isPrimary` marks
/// which one matches the user's User.organizationId — the rest are
/// secondary memberships the user can switch into.
model OrganizationMembership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation("OrgMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation("OrgMembershipOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  role           AccessLevel  @default(EMPLOYEE)
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  PROBATION
  PIP
  NOTICE_PERIOD
}

enum AccessLevel {
  SUPER_ADMIN
  COMPANY_ADMIN
  C_LEVEL
  VP
  DIRECTOR
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  AGENT
  HR
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  accessLevel    AccessLevel  @default(EMPLOYEE)
  token          String       @unique
  expiresAt      DateTime
  accepted       Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  roleId         String?
  managerId      String?
  officeId       String?
  // Role-definition gate (the vision's KRA/KPI/SOP entry rule):
  // an admin can't issue an invite without first picking at least one
  // KRA and one SOP for the role. These arrays carry the selection so
  // accept-invite POST can fan them out into KRAAssignment +
  // SOPAssignment rows when the invitee signs up. KPIs are derived
  // from KRAs (KPI.kraId), so picking KRAs implicitly assigns the
  // KPIs underneath — no separate kpiIds array needed.
  kraIds         String[]     @default([])
  sopIds         String[]     @default([])
  // 🆕 Phase 18 — Space-targeted invitation. When `spaceId` is set the
  // accept flow ALSO creates a SpaceMember row (role = spaceRole) so
  // the invitee lands inside the Space they were invited to. The
  // KRA/SOP gate is bypassed for this code path — joining a Space is
  // a lighter intent than full org-onboarding.
  spaceId        String?
  spaceRole      SpaceRole?
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([organizationId])
  @@index([spaceId])
}

// Workspace — a named space inside a product (e.g. "Sales Team A" /
// "Sales Team B" inside WorkwrK CRM). Multi-workspace is the vision
// pillar "teams build their own town inside their app": each team gets
// its own boards / dashboards / customizations under the same product.
//
// First cut is naming-only: a Workspace exists per (org, productSlug)
// and a switcher in AppWorkspaceNav lets users hop between them. Data
// scoping (workspaceId on Opportunity, Lead, Ticket, …) lands in a
// follow-up — only Studio-built boards will be workspace-scoped at
// first, so we don't have to migrate every existing row to a default
// workspace.
//
// Conventions:
// - `slug` is unique within (organizationId, productSlug) — the URL
//   reads /crm/<board>?ws=<slug> when we wire workspace-scoped data.
// - Exactly one workspace per (org, productSlug) flagged `isDefault`.
//   Created on first access via `ensureDefaultWorkspace`.
model Workspace {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productSlug    String // workwrk-crm, workwrk-dev, workwrk-itsm, …
  name           String // "Sales Team A", "Main workspace"
  slug           String // url-safe, unique within (org, product)
  isDefault      Boolean      @default(false)
  // Optional visual accent so two workspaces inside the same product
  // can be distinguished in the switcher at a glance.
  color          String?
  // Free-form description; reasoned shown in the workspace switcher
  // tooltip when someone hovers over a workspace name.
  description    String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members      WorkspaceMember[]

  @@unique([organizationId, productSlug, slug])
  @@index([organizationId, productSlug])
}

// WorkspaceMember — which users belong to a given workspace and what
// they can do inside it. v1 supports OWNER / EDITOR / VIEWER; we may
// add CUSTOM scopes later when Studio lands per-board permissions.
model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceMemberRole @default(EDITOR)
  createdAt   DateTime            @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

enum WorkspaceMemberRole {
  OWNER
  EDITOR
  VIEWER
}

// StudioBoard — a user-built board inside a workspace. The "teams
// build their own town" vision pillar. Unlike the canonical
// product-board routes (e.g. /crm/pipeline), a StudioBoard's columns
// are defined per-board and stored on the row itself, not in a Prisma
// model. That trades query power for instant customization.
//
// Conventions:
// - `fields` is an array of { key, label, type, options? } objects.
//   Types reuse the BoardView field-type vocabulary so the existing
//   <BoardView> renderer can drive Studio boards too.
// - `layout` controls the default view (TABLE / KANBAN). Other views
//   can still be picked inside the renderer.
// - `productSlug` is the host app the board appears under (used to
//   color the workspace nav consistently with the surrounding app).
//   Null = a free-standing Studio board not nested under any product.

// Reusable "create task" presets. A snapshot of the create-task modal's
// configuration (type, status, priority, tags, checklist, subtasks, …)
// stored as a JSON blob so applying one just re-hydrates the modal.
// Org-shared; created by any member.
model ItemTemplate {
  id             String   @id @default(cuid())
  organizationId String
  createdById    String
  name           String
  config         Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// Template Center (ClickUp parity) — one reusable template store for any
// kind of artifact. Mirrors ItemTemplate's no-relation FK style.
//   payload shape by kind:
//     TASK  → create-task modal config snapshot { status, priority, tags, checklist, subtasks, description, taskType }
//     LIST  → { statuses[], fields[], views[], items[], defaultView }
//     SPACE → { workflow{ statuses[], views[], modules[], defaultView }, lists[] }
//   organizationId = null + builtIn = true → ships with the app (global library row).
model Template {
  id             String              @id @default(cuid())
  organizationId String? // null = built-in/global library row
  createdById    String?
  kind           TemplateKind
  name           String
  description    String?
  complexity     TemplateComplexity?
  category       String?
  useCases       String[]            @default([])
  tags           String[]            @default([])
  builtIn        Boolean             @default(false)
  payload        Json                @default("{}")
  usedCount      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, kind])
  @@index([kind, builtIn])
}

enum TemplateKind {
  TASK
  LIST
  SPACE
  FOLDER
  DOC
  VIEW
  WHITEBOARD
}

enum TemplateComplexity {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ── Task Types (ClickUp parity) ────────────────────────────────────
// An org-level, presentational re-skin of an Item (Task / Milestone /
// Bug / Deal …). Item.itemTypeId points here. NOT a replacement for our
// first-class OKR/KRA/KPI/User models — those stay dedicated; an Item
// may *link* to them via EntityLink rather than being re-typed into them.
model ItemType {
  id             String   @id @default(cuid())
  organizationId String
  singular       String
  plural         String
  icon           String   @default("CircleDot") // lucide icon name
  description    String?
  category       String?
  isDefault      Boolean  @default(false) // the org's default type for new tasks
  builtIn        Boolean  @default(false) // seeded (Task/Milestone/Form Response/Meeting Note)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

