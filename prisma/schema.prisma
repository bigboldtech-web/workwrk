  reviews        Review[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

enum ReviewType {
  MONTHLY_PULSE
  QUARTERLY
  ANNUAL
  PROBATION
  PIP_REVIEW
}

enum CycleStatus {
  DRAFT
  ACTIVE
  IN_CALIBRATION
  COMPLETED
  CANCELLED
}

model Review {
  id              String         @id @default(cuid())
  cycleId         String
  cycle           ReviewCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  subjectId       String
  subject         User           @relation("ReviewSubject", fields: [subjectId], references: [id])
  reviewerId      String
  reviewer        User           @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  kpiScore        Float?
  managerRating   Float?
  overallScore    Float?
  strengths       String?
  improvements    String?
  managerComments String?
  selfAssessment  String?
  outcome         ReviewOutcome?
  status          ReviewStatus   @default(PENDING)
  submittedAt     DateTime?

  // Structured self-assessment data
  selfRatings        Json? // {kraRatings: [{kraId, kraName, rating, achievements}], reflection: {wentWell, couldImprove, goals}}
  // Structured manager review data
  managerAssessment  Json? // {kraRatings: [{kraId, kraName, rating, comments}], behavioral: {quality, reliability, collaboration, initiative, growth}, overallComments, recommendation}
  // Auto-calculated metrics
  sopComplianceScore Float?
  peerRating         Float?
  compositeScore     Float?
  // Calibration
  calibratedScore    Float?
  calibrationNotes   String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  peerFeedback PeerFeedback[]

  @@unique([cycleId, subjectId, reviewerId])
  @@index([subjectId])
  @@index([cycleId])
  @@index([cycleId, status])
  @@index([reviewerId])
}

enum ReviewOutcome {
  PROMOTION_ELIGIBLE
  HIKE_ELIGIBLE
  STATUS_QUO
  PIP_REQUIRED
  EXIT_RECOMMENDATION
}

enum ReviewStatus {
  PENDING
  SELF_ASSESSMENT
  MANAGER_REVIEW
  CALIBRATION
  COMPLETED
}

// ──────────────────────────────────────────────────────────────────
// 🆕 PHASE 5 — Weekly review (heartbeat cadence).
// Different from the cycle-bound Review above: this is a recurring
// per-week submission. Every IC fills one in each Friday (kpi numbers,
// kra progress, blockers, plan); their manager approves or requests
// changes; rollups bubble up the reporting tree. The single load-
// bearing stickiness mechanism of the AI-OS vision (Decision D3).
//
// Uniqueness on (userId, periodStart) means an IC has at most one
// WeeklyReview per ISO-week-start (Monday 00:00 UTC). The cron that
// auto-creates DRAFT rows for the current week reuses upsert against
// that unique constraint.
// ──────────────────────────────────────────────────────────────────

model WeeklyReview {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("WeeklyReviewSubject", fields: [userId], references: [id], onDelete: Cascade)

  // ISO week start — Monday 00:00 UTC of the week this review covers.
  periodStart DateTime

  // Subject's body — JSON blobs for forward-compat.
  // kpiSnapshots: [{ kpiId, value: number, note?: string }]
  // kraProgress:  [{ kraId, progressPct: 0-100, note?: string }]
  kpiSnapshots Json    @default("[]")
  kraProgress  Json    @default("[]")
  highlights   String? @db.Text // wins from the week
  blockers     String? @db.Text // what's stuck / asks
  plan         String? @db.Text // next week's plan

  status      WeeklyReviewStatus @default(DRAFT)
  submittedAt DateTime?

  // Manager loop (Phase 5b fills these in).
  managerId     String?
  manager       User?                @relation("WeeklyReviewManager", fields: [managerId], references: [id])
  managerStatus ManagerReviewStatus?
  managerNotes  String?              @db.Text
  reviewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, periodStart])
  @@index([organizationId, periodStart])
  @@index([managerId, status])
  @@index([userId, status])
}

enum WeeklyReviewStatus {
  DRAFT // auto-created on Monday, IC hasn't touched yet (or saved partial)
  SUBMITTED // IC has submitted for manager review
  ACKNOWLEDGED // manager has acted on it (approved or requested changes)
}

enum ManagerReviewStatus {
  PENDING // submitted but not yet looked at
  APPROVED // manager approved as-is
  CHANGES_REQUESTED // manager wants the IC to revise + resubmit
}

model PeerFeedback {
  id                  String   @id @default(cuid())
  reviewId            String
  review              Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  giverId             String
  giver               User     @relation("FeedbackGiver", fields: [giverId], references: [id])
  receiverId          String
  receiver            User     @relation("FeedbackReceiver", fields: [receiverId], references: [id])
  rating              Float?
  comments            String?
  strengths           String?
  improvements        String?
  collaborationRating Float?
  anonymous           Boolean  @default(true)
  status              String   @default("PENDING") // PENDING, SUBMITTED
  createdAt           DateTime @default(now())
}

