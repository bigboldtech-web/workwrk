generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// MULTI-TENANCY & AUTH
// ==========================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  domain    String?
  plan      Plan     @default(STARTER)
  status    OrgStatus @default(ACTIVE)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  departments  Department[]
  roles        Role[]
  kras         KRA[]
  kpis         KPI[]
  tasks        Task[]
  sops         SOP[]
  reviewCycles ReviewCycle[]
  meetings     Meeting[]
  aiQueries    AIQuery[]
  invitations  Invitation[]
  onboardingTemplates OnboardingTemplate[]
  trainingCourses     TrainingCourse[]
  integrations        Integration[]
  subscription        Subscription?
  apiKeys             ApiKey[]
  webhookSubscriptions WebhookSubscription[]
  webhookDeliveries   WebhookDelivery[]
  employeeOfMonths    EmployeeOfMonth[]
  ideas               Idea[]
  offices             Office[]
  sopCategories       SOPCategory[]
  kraCategories       KraCategory[]
  announcements       Announcement[]
  policies            Policy[]
  okrs                OKR[]
  pulseSurveys        PulseSurvey[]
  tools               Tool[]
  assets              Asset[]
  candorSessions      CandorSession[]
  taskLabels          TaskLabel[]
  sopFolders          SOPFolder[]
  secrets             OrgSecret[]
  tags                Tag[]
  tagAssignments      TagAssignment[]

  @@index([slug])
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

// ==========================================
// Billing + subscriptions
// ==========================================

/// AppSumo lifetime-deal codes.
///
/// AppSumo customers don't pay through Stripe — they redeem a code on
/// the AppSumo marketplace and receive a string they paste into our
/// /redeem page. Each code maps to a plan tier (Tier 1 = 5 seats,
/// Tier 2 = 25 seats, Tier 3 = unlimited, by convention) and is
/// single-use.
///
/// Codes are bulk-imported by WorkwrK staff via the admin panel
/// (CSV from AppSumo merchant dashboard). On redemption we set the
/// org's Subscription plan to ENTERPRISE / SCALE etc., set
/// `stripeCustomerId = null` (no Stripe), and stamp `redeemedById`
/// so refunds can be traced.
model AppsumoCode {
  id             String      @id @default(cuid())
  /// The redemption string the customer pastes in. Unique per code.
  code           String      @unique
  /// Plan tier this code grants. We map AppSumo "Tier 1/2/3" to our
  /// internal Plan enum values via the redemption handler.
  tier           Int         /// 1, 2, 3 — matches AppSumo Tier numbering
  plan           Plan        /// Plan to apply on redemption (e.g. SCALE)
  seats          Int         /// User cap (null-equivalent for unlimited tiers; we use a large int)
  /// Once redeemed, the code is locked. Refunds flip `refunded=true`
  /// without deleting the row so the AppSumo merchant dashboard
  /// reconciliation stays auditable.
  redeemedById   String?
  redeemedByOrg  String?
  redeemedAt     DateTime?
  refundedAt     DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([redeemedByOrg])
  @@index([redeemedAt])
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Canonical state
  plan               Plan
  status             SubscriptionStatus @default(TRIALING)
  billingMode        BillingMode        @default(PER_USER)
  seats              Int                @default(0)

  // Stripe (null on self-hosted / trial / manual invoicing)
  stripeCustomerId       String?        @unique
  stripeSubscriptionId   String?        @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  trialEndsAt        DateTime?
  canceledAt         DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum BillingMode {
  PER_USER    // $4/user/month style
  FLAT_TIER   // $50/100/300 per-band flat
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

model User {
  id             String    @id @default(cuid())
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  avatar         String?
  phone          String?
  dateOfBirth    DateTime?
  officeId       String?
  office         Office?      @relation(fields: [officeId], references: [id])
  status         UserStatus @default(ACTIVE)
  joinDate       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String?
  role           Role?        @relation(fields: [roleId], references: [id])
  departmentId   String?
  department     Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id])
  accessLevel    AccessLevel  @default(EMPLOYEE)

  // Email verification — signup sets verifyToken; user confirms via /verify-email.
  emailVerifiedAt  DateTime?
  verifyToken      String?  @unique
  verifyExpiresAt  DateTime?

  // MFA — TOTP (Google Authenticator / Authy / 1Password).
  // Secret stored base32-encoded, only persisted when enrolment completes.
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String?
  mfaBackupCodes   String[] @default([])   // bcrypt-hashed one-time codes

  managerId      String?
  manager        User?    @relation("ManagerReports", fields: [managerId], references: [id])
  directReports  User[]   @relation("ManagerReports")

  skills         UserSkill[]
  certifications Certification[]
  kraAssignments KRAAssignment[]
  kpiRecords     KPIRecord[]
  tasks          Task[]   @relation("TaskAssignee")
  tasksEscalated Task[]   @relation("TaskEscalatedTo")
  sopComplianceRecords SOPCompliance[]
  sopAssignments       SOPAssignment[]
  reviewsAsSubject   Review[]       @relation("ReviewSubject")
  reviewsAsReviewer  Review[]       @relation("ReviewReviewer")
  feedbackGiven      PeerFeedback[] @relation("FeedbackGiver")
  feedbackReceived   PeerFeedback[] @relation("FeedbackReceiver")
  meetingAttendances MeetingAttendee[]
  actionItems        ActionItem[]
  checkIns           CheckIn[]
  aiQueries          AIQuery[]
  notifications      Notification[]
  consentRecords     ConsentRecord[]
  headOfDepartments  Department[] @relation("DepartmentHead")
  onboardingInstances OnboardingInstance[]
  buddyForOnboarding  OnboardingInstance[] @relation("OnboardingBuddy")
  courseEnrollments   CourseEnrollment[]
  externalData        ExternalData[]
  activityLogs        ActivityLog[]
  performanceScores   PerformanceScore[]
  kudosGiven          Kudos[] @relation("KudosGiver")
  kudosReceived       Kudos[] @relation("KudosReceiver")
  kudosReactions      KudosReaction[] @relation("KudosReactionUser")
  employeeOfMonthWins EmployeeOfMonth[]
  ideasSubmitted      Idea[] @relation("IdeaSubmitter")
  ideasReviewed       Idea[] @relation("IdeaReviewer")
  ideaVotes           IdeaVote[]
  ideaComments        IdeaComment[]
  assignedAssets      Asset[]  @relation("AssetAssignee")
  apiKeysCreated      ApiKey[] @relation("ApiKeyCreator")
  webhooksCreated     WebhookSubscription[] @relation("WebhookCreator")
  taskComments        TaskComment[] @relation("TaskCommentAuthor")
  calendarSubscriptions CalendarSubscription[] @relation("CalendarSubscriptionUser")
  sopFolderAccess     SOPFolderAccess[] @relation("SOPFolderAccessUser")

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([managerId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  PROBATION
  PIP
  NOTICE_PERIOD
}

enum AccessLevel {
  SUPER_ADMIN
  COMPANY_ADMIN
  C_LEVEL
  VP
  DIRECTOR
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  AGENT
  HR
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  accessLevel    AccessLevel @default(EMPLOYEE)
  token          String   @unique
  expiresAt      DateTime
  accepted       Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  roleId         String?
  managerId      String?
  officeId       String?
  createdAt      DateTime @default(now())

  @@index([token])
  @@index([organizationId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ==========================================
// MODULE 1: ORGANIZATION STRUCTURE
// ==========================================

model Department {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String?
  parentId        String?
  parent          Department?  @relation("SubDepartments", fields: [parentId], references: [id])
  subDepartments  Department[] @relation("SubDepartments")
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  headId          String?
  head            User?        @relation("DepartmentHead", fields: [headId], references: [id])
  members         User[]       @relation("DepartmentMembers")
  roles           Role[]
  goals           DepartmentGoal[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
}

model DepartmentGoal {
  id           String     @id @default(cuid())
  title        String
  description  String?
  targetValue  Float?
  currentValue Float?     @default(0)
  unit         String?
  deadline     DateTime?
  status       GoalStatus @default(ON_TRACK)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum GoalStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
}

model Role {
  id             String   @id @default(cuid())
  title          String
  description    String?
  level          AccessLevel @default(EMPLOYEE)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  users          User[]
  kraTemplates   KRA[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([title, organizationId])
  @@index([organizationId])
}

// ==========================================
// MODULE 2: PEOPLE PROFILES
// ==========================================

model UserSkill {
  id            String @id @default(cuid())
  name          String
  selfRating    Int    @default(0)
  managerRating Int?
  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, userId])
}

model Certification {
  id          String    @id @default(cuid())
  name        String
  issuer      String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  documentUrl String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

// ==========================================
// MODULE 3: KRA & KPI ENGINE
// ==========================================

model KRA {
  id             String   @id @default(cuid())
  name           String
  description    String?
  category       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String?
  role           Role?    @relation(fields: [roleId], references: [id])
  assignments    KRAAssignment[]
  kpis           KPI[]
  tasks          Task[]
  sops           SOP[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model KRAAssignment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kraId      String
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  weightage  Float    @default(0)
  period     String   @default("ongoing")
  status     KRAStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, kraId])
  @@index([userId])
}

enum KRAStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model KPI {
  id             String   @id @default(cuid())
  name           String
  description    String?
  type           KPIType  @default(QUANTITATIVE)
  unit           String?
  frequency      Frequency @default(MONTHLY)
  targetValue    Float?
  targetLabel    String?
  lowerIsBetter  Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kraId          String?
  kra            KRA?     @relation(fields: [kraId], references: [id])
  records        KPIRecord[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([kraId])
}

enum KPIType {
  QUANTITATIVE
  QUALITATIVE
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model KPIRecord {
  id          String   @id @default(cuid())
  kpiId       String
  kpi         KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period      String
  targetValue Float
  actualValue Float?
  score       Float?
  notes       String?
  managerNotes String?
  evidence    String?
  status      KPIRecordStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([kpiId, userId, period])
  @@index([userId])
  @@index([kpiId])
}

enum KPIRecordStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

// ==========================================
// MODULE 4: TASKS (Calendar Work Items)
// ==========================================

model Task {
  id               String     @id @default(cuid())
  title            String
  description      String?

  // ── Scheduling ──
  // `date` is the legacy day-level anchor (kept for backwards compat).
  // `startAt` / `endAt` are the full timestamps for hour-precise or
  // multi-day tasks. `allDay` mirrors Google Calendar semantics —
  // when true, time-of-day is ignored and the task renders as a pill.
  date             DateTime
  startAt          DateTime?
  endAt            DateTime?
  allDay           Boolean    @default(true)
  estimateHours    Float?
  hoursSpent       Float?
  completedAt      DateTime?
  category         String?
  incompleteReason String?
  recurringGroupId String?
  status           TaskStatus @default(PLANNED)

  // ── Sub-tasks ──
  // One level deep only — validated at API layer. Sub-tasks roll up
  // into the parent's Gantt bar and complete the parent when all children
  // are done.
  parentTaskId     String?
  parent           Task?      @relation("TaskSubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks         Task[]     @relation("TaskSubTasks")

  // ── External calendar sync ──
  // `externalId` + `externalSource` form the idempotency key for
  // two-way sync. Null on Workwrk-native tasks.
  externalId       String?
  externalSource   String?
  syncedAt         DateTime?

  // ── SLA + escalation ──
  // If set, task is considered overdue `slaHours` after `date`.
  // Null = no SLA enforcement. Used by the escalation cron.
  slaHours         Int?
  priority         TaskPriority @default(NORMAL)
  escalatedAt      DateTime?
  escalatedToId    String?
  escalatedTo      User?      @relation("TaskEscalatedTo", fields: [escalatedToId], references: [id])
  // Source = how this task was spawned.
  source           TaskSource @default(MANUAL)
  sourceRef        String?    // opaque ID of the source (e.g. sopId, reviewId)

  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assigneeId       String
  assignee         User       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  kraId            String?
  kra              KRA?       @relation(fields: [kraId], references: [id])

  comments         TaskComment[]
  labels           TaskLabelOnTask[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([organizationId])
  @@index([assigneeId])
  @@index([date])
  @@index([escalatedToId])
  @@index([organizationId, status, date])
  @@index([parentTaskId])
  @@index([externalSource, externalId])
  @@index([organizationId, assigneeId, startAt])
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("TaskCommentAuthor", fields: [authorId], references: [id])
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([taskId])
  @@index([authorId])
}

model TaskLabel {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  color          String   @default("#d4ff2e")
  createdAt      DateTime @default(now())

  tasks          TaskLabelOnTask[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TaskLabelOnTask {
  taskId   String
  task     Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId  String
  label    TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model CalendarSubscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("CalendarSubscriptionUser", fields: [userId], references: [id], onDelete: Cascade)
  provider        String   // "GOOGLE" | "ICS_EXPORT"
  // Foreign calendar identifier (Google calendar ID, etc.). Null for
  // ICS_EXPORT subscriptions — those use a per-user signed feed token.
  externalCalendarId String?
  // Whether the user opted in to sharing event titles with their
  // manager. When false, events come through as generic "Busy" pills.
  shareTitles     Boolean  @default(false)
  // OAuth credentials for providers that need them. Encrypted at rest
  // is future work; for now, only accessible via this model.
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  // Google's incremental sync token — lets us pull deltas only.
  syncToken       String?
  lastSyncAt      DateTime?
  // "IN" = pull events into Workwrk, "OUT" = push Workwrk tasks to the
  // provider, "BOTH" = two-way. ICS_EXPORT is always OUT.
  direction       String   @default("BOTH")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider, externalCalendarId])
  @@index([userId])
}

enum TaskStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  SOP
  REVIEW
  OKR
  AI
}

// ==========================================
// MODULE 5: SOP MANAGEMENT
// ==========================================

model SOPVersion {
  id          String   @id @default(cuid())
  sopId       String
  sop         SOP      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  description String?
  content     Json
  publishedBy String?
  createdAt   DateTime @default(now())

  @@index([sopId])
  @@index([version])
}

model KraCategory {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
}

model SOPCategory {
  id             String          @id @default(cuid())
  name           String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subcategories  SOPSubcategory[]
  createdAt      DateTime        @default(now())

  @@unique([name, organizationId])
  @@index([organizationId])
}

model SOPSubcategory {
  id         String      @id @default(cuid())
  name       String
  categoryId String
  category   SOPCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@unique([name, categoryId])
  @@index([categoryId])
}

model SOP {
  id             String    @id @default(cuid())
  title          String
  description    String?
  // Legacy taxonomy — kept for backwards compatibility and safe rollback
  // after the unification migration. New code should read folder + tags.
  // Values are mirrored on write so old reads keep working until we drop
  // the columns in a later migration.
  category       String?
  subcategory    String?
  sopType        SOPType   @default(WRITTEN)
  kraId          String?
  kra            KRA?     @relation(fields: [kraId], references: [id])
  // Folder is now the single primary taxonomy. NULL = unfoldered (visible
  // to everyone in the org). Non-null = visibility scoped by the folder's
  // access list, inherited from ancestors when not set explicitly.
  folderId       String?
  folder         SOPFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // Cross-cutting tags. Free-form, multi-value, no access control —
  // useful for things that don't map to folder structure (e.g.
  // "Compliance", "Q2-2026", "Onboarding").
  tags           String[]  @default([])
  content        Json
  version        Int       @default(1)
  status         SOPStatus @default(DRAFT)
  shareToken     String?   @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  compliance     SOPCompliance[]
  versions       SOPVersion[]
  assignments    SOPAssignment[]
  processRuns    ProcessRun[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime?

  @@index([organizationId])
  @@index([category])
  @@index([shareToken])
  @@index([folderId])
  @@index([tags], type: Gin)
}

/// Per-organization secrets (BYOK — bring your own key).
///
/// Holds encrypted credentials owned by the customer. Today we only
/// use this for Anthropic API keys (provider="anthropic"), but the
/// shape is provider-keyed so adding OpenAI / Bedrock later is a
/// new row, not a migration.
///
/// Encryption: the `encryptedKey` blob is AES-256-GCM ciphertext
/// produced by src/lib/secrets-crypto.ts using the
/// `SECRETS_ENCRYPTION_KEY` env var as the master key. Plain keys
/// never hit Prisma.
model OrgSecret {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String       // "anthropic" today; future: "openai", "bedrock"
  // The decoded structure stored as { ciphertext, iv, tag, version }.
  encryptedKey   Json
  // Last 4 chars of the plaintext key, for the Settings UI to show
  // which key is currently in use ("…sk-Bw8q") without decrypting.
  keyHint        String?
  // What the customer typed for "Test connection" — only set after a
  // successful test. Drives the green checkmark.
  lastUsedAt     DateTime?
  // Optional model preference. Ignored if null.
  preferredModel String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
}

/// SOP access-scoping unit and primary taxonomy. Folders form a tree
/// (parentId points to the parent). An org admin creates a folder
/// (e.g. "Marketing"), optionally nests sub-folders ("Marketing /
/// Email Campaigns"), drops SOPs into it, and assigns which users
/// can see/contribute via SOPFolderAccess. If a folder has no
/// explicit access list, it inherits the parent's. Admins see every
/// folder regardless of assignment.
model SOPFolder {
  id             String    @id @default(cuid())
  name           String
  color          String?
  icon           String?
  description    String?
  parentId       String?
  parent         SOPFolder?  @relation("SOPFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       SOPFolder[] @relation("SOPFolderTree")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sops           SOP[]
  access         SOPFolderAccess[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Sibling folders (same parent + same org) must have unique names.
  // Postgres treats NULLs as distinct in unique constraints, so the
  // top-level case is also enforced via a partial unique index added
  // in the migration SQL.
  @@unique([organizationId, parentId, name])
  @@index([organizationId])
  @@index([parentId])
}

/// Join table: which users can see and contribute to a given folder.
/// Admins aren't in here — they see all folders implicitly.
model SOPFolderAccess {
  folderId   String
  folder     SOPFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation("SOPFolderAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedAt  DateTime  @default(now())

  @@id([folderId, userId])
  @@index([userId])
}

enum SOPType {
  WRITTEN
  RECORDED
  CHECKLIST
}

// Process Run — tracks a single execution of a checklist SOP
model ProcessRun {
  id             String          @id @default(cuid())
  sopId          String
  sop            SOP             @relation(fields: [sopId], references: [id], onDelete: Cascade)
  title          String
  assigneeId     String?
  status         ProcessRunStatus @default(ACTIVE)
  progress       Int             @default(0)
  dueDate        DateTime?
  shareToken     String?         @unique
  completedSteps Json            @default("[]")  // Array of completed step IDs
  stepData       Json            @default("{}")   // {stepId: {completedAt, completedBy, notes, inputValues}}
  organizationId String
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([sopId])
  @@index([assigneeId])
  @@index([organizationId])
  @@index([shareToken])
  @@index([status])
}

enum ProcessRunStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
}

enum SOPStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

model SOPCompliance {
  id             String   @id @default(cuid())
  sopId          String
  sop            SOP      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period         String
  stepsTotal     Int
  stepsCompleted Int      @default(0)
  score          Float?
  notes          String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sopId])
  @@index([userId])
}

model SOPAssignment {
  id             String            @id @default(cuid())
  sopId          String
  sop            SOP               @relation(fields: [sopId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         SOPAssignmentStatus @default(ASSIGNED)
  mandatory      Boolean           @default(true)
  dueDate        DateTime?
  progress       Json?             // {completedSteps: [0, 2, 5], quizScore: 80}
  stepsTotal     Int               @default(0)
  stepsCompleted Int               @default(0)
  score          Float?
  completedAt    DateTime?
  assignedBy     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([sopId, userId])
  @@index([sopId])
  @@index([userId])
  @@index([status])
}

enum SOPAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

// ==========================================
// MODULE 6: PERFORMANCE REVIEWS
// ==========================================

model ReviewCycle {
  id             String      @id @default(cuid())
  name           String
  type           ReviewType
  startDate      DateTime
  endDate        DateTime
  status         CycleStatus @default(DRAFT)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviews        Review[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([organizationId])
}

enum ReviewType {
  MONTHLY_PULSE
  QUARTERLY
  ANNUAL
  PROBATION
  PIP_REVIEW
}

enum CycleStatus {
  DRAFT
  ACTIVE
  IN_CALIBRATION
  COMPLETED
  CANCELLED
}

model Review {
  id              String      @id @default(cuid())
  cycleId         String
  cycle           ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  subjectId       String
  subject         User        @relation("ReviewSubject", fields: [subjectId], references: [id])
  reviewerId      String
  reviewer        User        @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  kpiScore        Float?
  managerRating   Float?
  overallScore    Float?
  strengths       String?
  improvements    String?
  managerComments String?
  selfAssessment  String?
  outcome         ReviewOutcome?
  status          ReviewStatus @default(PENDING)
  submittedAt     DateTime?

  // Structured self-assessment data
  selfRatings     Json?       // {kraRatings: [{kraId, kraName, rating, achievements}], reflection: {wentWell, couldImprove, goals}}
  // Structured manager review data
  managerAssessment Json?     // {kraRatings: [{kraId, kraName, rating, comments}], behavioral: {quality, reliability, collaboration, initiative, growth}, overallComments, recommendation}
  // Auto-calculated metrics
  sopComplianceScore Float?
  peerRating      Float?
  compositeScore  Float?
  // Calibration
  calibratedScore Float?
  calibrationNotes String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  peerFeedback    PeerFeedback[]

  @@unique([cycleId, subjectId, reviewerId])
  @@index([subjectId])
  @@index([cycleId])
  @@index([cycleId, status])
  @@index([reviewerId])
}

enum ReviewOutcome {
  PROMOTION_ELIGIBLE
  HIKE_ELIGIBLE
  STATUS_QUO
  PIP_REQUIRED
  EXIT_RECOMMENDATION
}

enum ReviewStatus {
  PENDING
  SELF_ASSESSMENT
  MANAGER_REVIEW
  CALIBRATION
  COMPLETED
}

model PeerFeedback {
  id         String   @id @default(cuid())
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  giverId    String
  giver      User     @relation("FeedbackGiver", fields: [giverId], references: [id])
  receiverId String
  receiver   User     @relation("FeedbackReceiver", fields: [receiverId], references: [id])
  rating     Float?
  comments   String?
  strengths  String?
  improvements String?
  collaborationRating Float?
  anonymous  Boolean  @default(true)
  status     String   @default("PENDING") // PENDING, SUBMITTED
  createdAt  DateTime @default(now())
}

// ==========================================
// MODULE 8: MEETINGS & CHECK-INS
// ==========================================

model Meeting {
  id             String      @id @default(cuid())
  title          String
  type           MeetingType
  scheduledAt    DateTime
  duration       Int         @default(30)
  agenda         String?
  notes          String?
  decisions      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendees      MeetingAttendee[]
  actionItems    ActionItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([organizationId])
  @@index([scheduledAt])
}

enum MeetingType {
  DAILY_STANDUP
  WEEKLY_REVIEW
  ONE_ON_ONE
  QUARTERLY_REVIEW
  ANNUAL_PLANNING
  ADHOC
}

model MeetingAttendee {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  attended  Boolean @default(false)

  @@unique([meetingId, userId])
}

enum ActionItemStatus {
  NOT_STARTED
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  BLOCKED
  CANCELLED
}

model ActionItem {
  id          String     @id @default(cuid())
  title       String
  meetingId   String
  meeting     Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assigneeId  String
  assignee    User       @relation(fields: [assigneeId], references: [id])
  deadline    DateTime?
  status      ActionItemStatus @default(NOT_STARTED)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CheckIn {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime  @default(now())
  mood       Int?
  wentWell   String?
  challenges String?
  tomorrow   String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([date])
}

// ==========================================
// MODULE 7: AI INTELLIGENCE
// ==========================================

model AIQuery {
  id             String   @id @default(cuid())
  query          String
  response       String?
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ==========================================
// MODULE 9: ONBOARDING & TRAINING
// ==========================================

model OnboardingTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?
  roleId         String?
  departmentId   String?
  steps          Json     @default("[]")
  durationDays   Int      @default(30)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instances      OnboardingInstance[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model OnboardingInstance {
  id             String   @id @default(cuid())
  templateId     String
  template       OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  buddyId        String?
  buddy          User?    @relation("OnboardingBuddy", fields: [buddyId], references: [id])
  startDate      DateTime @default(now())
  targetDate     DateTime?
  completedAt    DateTime?
  progress       Json     @default("[]")
  status         OnboardingStatus @default(IN_PROGRESS)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model TrainingCourse {
  id             String   @id @default(cuid())
  title          String
  description    String?
  category       String?
  content        Json     @default("{}")
  duration       Int?
  mandatory      Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments    CourseEnrollment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model CourseEnrollment {
  id          String   @id @default(cuid())
  courseId    String
  course      TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress    Int      @default(0)
  score       Float?
  completedAt DateTime?
  startedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseId, userId])
  @@index([userId])
}

// ==========================================
// MODULE 10: INTEGRATIONS (HRMS, etc.)
// ==========================================

model Integration {
  id             String            @id @default(cuid())
  name           String            // e.g. "GreytHR", "BambooHR", "Zoho People", "Keka"
  type           IntegrationType
  status         IntegrationStatus @default(INACTIVE)
  config         Json              @default("{}")  // API keys, endpoints, mapping config
  lastSyncAt     DateTime?
  syncFrequency  String?           @default("daily") // daily, hourly, manual
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs       IntegrationSync[]
  webhookLogs    WebhookLog[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([type, organizationId])
  @@index([organizationId])
}

enum IntegrationType {
  HRMS
  SLACK
  GOOGLE_WORKSPACE
  MICROSOFT_365
  JIRA
  CUSTOM_WEBHOOK
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  SYNCING
}

model IntegrationSync {
  id            String    @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  type          String    // "attendance", "compensation", "employees"
  status        String    @default("pending") // pending, success, failed
  recordssynced Int       @default(0)
  errors        Json?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([integrationId])
}

// Imported data from external HRMS (read-only, used for performance scoring)
model ExternalData {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         String   // "greythr", "bamboohr", etc.
  dataType       String   // "attendance_summary", "compensation", "leave_summary"
  period         String   // "2026-03", "2026-Q1"
  data           Json     // flexible data structure from external system
  organizationId String
  importedAt     DateTime @default(now())

  @@unique([userId, source, dataType, period])
  @@index([userId])
  @@index([organizationId])
}

// ==========================================
// WEBHOOK SYSTEM
// ==========================================

model WebhookLog {
  id             String      @id @default(cuid())
  integrationId  String
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction      String      @default("outgoing") // "incoming" | "outgoing"
  event          String?     // e.g. "task_completed", "review_done", "test"
  payload        Json        @default("{}")
  status         String      @default("received") // received, processed, failed, sent
  error          String?
  responseCode   Int?
  createdAt      DateTime    @default(now())

  @@index([integrationId])
  @@index([createdAt])
}

// ==========================================
// EMAIL SYSTEM
// ==========================================

model EmailLog {
  id             String      @id @default(cuid())
  to             String
  subject        String
  template       String
  html           String?
  variables      Json        @default("{}")
  status         EmailStatus @default(QUEUED)
  error          String?
  attempts       Int         @default(0)
  organizationId String?
  createdAt      DateTime    @default(now())
  sentAt         DateTime?

  @@index([status])
  @@index([createdAt])
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

model EmailPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  kraNotifications    Boolean  @default(true)
  reviewNotifications Boolean  @default(true)
  sopNotifications    Boolean  @default(true)
  kudosNotifications  Boolean  @default(true)
  dailyDigest         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

// ==========================================
// PERFORMANCE SCORES (Auto-calculated)
// ==========================================

model PerformanceScore {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period         String   // "2026-03", "2026-Q1", etc.
  score          Float    // Composite score 0-100
  breakdown      Json     // {kpiScore, managerRating, peerRating, selfRating, sopCompliance, weights}
  calculatedAt   DateTime @default(now())
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, period])
  @@index([userId])
  @@index([organizationId])
  @@index([period])
}

// ==========================================
// KUDOS / RECOGNITION
// ==========================================

model Kudos {
  id             String   @id @default(cuid())
  message        String
  companyValue   String?  // e.g. "Customer First", "Ownership", "Teamwork"
  giverId        String
  giver          User     @relation("KudosGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiverId     String
  receiver       User     @relation("KudosReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime @default(now())
  reactions      KudosReaction[]

  @@index([organizationId])
  @@index([receiverId])
  @@index([giverId])
  @@index([createdAt])
}

model KudosReaction {
  id        String   @id @default(cuid())
  kudosId   String
  kudos     Kudos    @relation(fields: [kudosId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("KudosReactionUser", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([kudosId, userId, emoji])
  @@index([kudosId])
  @@index([userId])
}

// ==========================================
// ACTIVITY LOG
// ==========================================

model ActivityLog {
  id             String   @id @default(cuid())
  type           String   // task_completed, review_submitted, kra_assigned, sop_completed, meeting_created, person_added, checkin_submitted, etc.
  actorId        String
  actor          User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  targetId       String?  // ID of the affected entity
  targetType     String?  // "task", "review", "sop", "meeting", "user", etc.
  description    String
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  oldValue       Json?
  newValue       Json?
  severity       String   @default("info")  // info, warning, critical
  organizationId String
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
  @@index([severity])
}

// ==========================================
// OFFICES / LOCATIONS
// ==========================================

model Office {
  id             String   @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  country        String?
  timezone       String?
  isHeadquarters Boolean  @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        User[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// ==========================================
// EMPLOYEE OF THE MONTH
// ==========================================

model EmployeeOfMonth {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period         String
  score          Float
  breakdown      Json?
  method         String   @default("auto")
  overriddenBy   String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([period, organizationId])
  @@index([organizationId])
  @@index([userId])
}

// ==========================================
// IDEAS BOARD
// ==========================================

model Idea {
  id             String     @id @default(cuid())
  title          String
  description    String
  category       String?
  status         IdeaStatus @default(SUBMITTED)
  submitterId    String
  submitter      User       @relation("IdeaSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  reviewerId     String?
  reviewer       User?      @relation("IdeaReviewer", fields: [reviewerId], references: [id])
  reviewNotes    String?
  rewardType     String?
  rewardValue    String?
  rewardedAt     DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  votes          IdeaVote[]
  comments       IdeaComment[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([organizationId])
  @@index([submitterId])
  @@index([status])
  @@index([createdAt])
}

enum IdeaStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  REWARDED
}

model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ideaId, userId])
  @@index([ideaId])
}

model IdeaComment {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([ideaId])
}

// ==========================================
// ANNOUNCEMENTS
// ==========================================

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String
  type           String               @default("INFO")   // INFO, WARNING, CELEBRATION, POLICY, EVENT
  priority       String               @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  pinned         Boolean              @default(false)
  publishedAt    DateTime?
  expiresAt      DateTime?
  targetAudience Json?
  authorId       String
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dismissals     AnnouncementDismissal[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
  @@index([publishedAt])
}

model AnnouncementDismissal {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  dismissedAt    DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}

// ==========================================
// COMPANY POLICIES & BYLAWS
// ==========================================

model Policy {
  id              String              @id @default(cuid())
  title           String
  content         String
  category        String?             // "HR", "Security", "Compliance", "Operations", "Code of Conduct", "Leave", "Expense"
  version         Int                 @default(1)
  status          String              @default("DRAFT")  // DRAFT, PUBLISHED, ARCHIVED
  requiresAck     Boolean             @default(true)     // Requires employee acknowledgment
  effectiveDate   DateTime?
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acknowledgments PolicyAcknowledgment[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([organizationId])
  @@index([status])
}

model PolicyAcknowledgment {
  id        String   @id @default(cuid())
  policyId  String
  policy    Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  userId    String
  acknowledgedAt DateTime @default(now())
  ipAddress String?

  @@unique([policyId, userId])
  @@index([userId])
  @@index([policyId])
}

// ==========================================
// OKR (OBJECTIVES & KEY RESULTS)
// ==========================================

model OKR {
  id             String       @id @default(cuid())
  title          String
  description    String?
  level          String       @default("INDIVIDUAL")  // COMPANY, TEAM, INDIVIDUAL
  status         String       @default("ON_TRACK")    // ON_TRACK, AT_RISK, BEHIND, COMPLETED
  progress       Int          @default(0)             // 0-100
  startDate      DateTime?
  endDate        DateTime?
  quarter        String?      // "Q2 2026"
  // Check-in rhythm. Drives the reminder cron + the "stale" badge on
  // the personal hero. Defaults to weekly because that's what most
  // teams settle on.
  checkInCadence String       @default("WEEKLY")     // WEEKLY, BIWEEKLY, MONTHLY
  ownerId        String?
  departmentId   String?
  parentId       String?
  parent         OKR?         @relation("OKRChildren", fields: [parentId], references: [id])
  children       OKR[]        @relation("OKRChildren")
  keyResults     KeyResult[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([ownerId])
  @@index([parentId])
  @@index([level])
  @@index([quarter])
}

model KeyResult {
  id          String      @id @default(cuid())
  title       String
  unit        String?     // %, count, $, etc.
  startValue  Float       @default(0)
  targetValue Float
  currentValue Float      @default(0)
  progress    Int         @default(0)  // 0-100 auto-calculated
  // When we last fired a "you haven't checked in lately" reminder for
  // this KR. Used to avoid spamming the owner — see scripts/api
  // /api/cron/okr-reminders.
  lastReminderAt DateTime?
  okrId       String
  okr         OKR         @relation(fields: [okrId], references: [id], onDelete: Cascade)
  checkIns    KRCheckIn[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([okrId])
}

model KRCheckIn {
  id          String    @id @default(cuid())
  keyResultId String
  keyResult   KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  value       Float
  note        String?
  userId      String
  createdAt   DateTime  @default(now())

  @@index([keyResultId])
}

// ==========================================
// 9-BOX GRID (TALENT CALIBRATION)
// ==========================================

model TalentAssessment {
  id             String   @id @default(cuid())
  userId         String
  period         String   // "Q2 2026"
  performance    Int      // 1-3 (Low, Medium, High)
  potential       Int      // 1-3 (Low, Medium, High)
  boxPosition    String   // "1-1", "1-2", etc.
  action         String?  // "Promote", "Develop", "Retain", "Coach", "PIP", "Exit"
  notes          String?
  assessedBy     String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, period, organizationId])
  @@index([organizationId])
  @@index([period])
}

// ==========================================
// PULSE SURVEYS
// ==========================================

model PulseSurvey {
  id             String          @id @default(cuid())
  title          String
  questions      Json            // [{id, text, type: "rating"|"text"|"nps"}]
  status         String          @default("DRAFT")  // DRAFT, ACTIVE, CLOSED
  frequency      String?         // WEEKLY, MONTHLY, QUARTERLY
  audienceType   String          @default("ALL")    // ALL, OFFICES, DEPARTMENTS, USERS
  officeIds      String[]        @default([])
  departmentIds  String[]        @default([])
  userIds        String[]        @default([])
  // When true, responses are visible to managers in aggregate only — no
  // respondent name, no individual attribution. Default true to preserve
  // existing survey trust assumptions. Managers can opt a survey into
  // attributed mode at create time when the context calls for it (e.g.
  // post-review pulse tied to a 1:1 follow-up).
  anonymous      Boolean         @default(true)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses      SurveyResponse[]
  createdAt      DateTime        @default(now())
  closedAt       DateTime?
  // Hard deadline for collecting responses. When set, the rotate cron
  // auto-closes the survey at this time and — if `frequency` is set —
  // spawns the next cycle. A reminder email to anyone in the audience
  // who hasn't responded goes out ~24h before.
  closesAt       DateTime?
  reminderSentAt DateTime?
  // When a survey was spawned by the rotate cron as the next cycle of
  // a recurring template, `parentSurveyId` points back to the most
  // recent prior cycle. Null for one-off surveys and for the first
  // cycle of any recurrence.
  parentSurveyId String?
  parent         PulseSurvey?    @relation("PulseSurveyRecurrence", fields: [parentSurveyId], references: [id], onDelete: SetNull)
  children       PulseSurvey[]   @relation("PulseSurveyRecurrence")

  @@index([organizationId])
  @@index([status])
  @@index([status, closesAt])
  @@index([parentSurveyId])
}

model SurveyResponse {
  id        String      @id @default(cuid())
  surveyId  String
  survey    PulseSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId    String
  answers   Json        // [{questionId, value}]
  createdAt DateTime    @default(now())

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ==========================================
// 1:1 MEETING TEMPLATES
// ==========================================

model MeetingTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?
  type           String   @default("ONE_ON_ONE")  // ONE_ON_ONE, TEAM_STANDUP, QUARTERLY_REVIEW
  agendaItems    Json     // [{title, description, timeMinutes, type: "discussion"|"action"|"review"}]
  isDefault      Boolean  @default(false)
  organizationId String?  // null = system template
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

// ==========================================
// TOOLS & APPLICATIONS
// ==========================================

model Tool {
  id             String       @id @default(cuid())
  name           String
  description    String?
  url            String?
  icon           String?      // emoji or URL
  category       String?      // "Communication", "Design", "Development", "Finance", "HR", "Marketing", "Sales", "Other"
  credentials    Json?        // { username, password, apiKey, notes } — encrypted at rest
  addedBy        String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shares         ToolShare[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model ToolShare {
  id        String   @id @default(cuid())
  toolId    String
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  userId    String
  sharedBy  String
  sharedAt  DateTime @default(now())

  @@unique([toolId, userId])
  @@index([userId])
  @@index([toolId])
}

model Asset {
  id             String       @id @default(cuid())
  name           String
  type           AssetType
  brand          String?
  model          String?
  serialNumber   String?
  imeiNumber     String?
  purchaseDate   DateTime?
  purchaseCost   Float?
  warrantyExpiry DateTime?
  condition      AssetCondition @default(GOOD)
  status         AssetStatus    @default(AVAILABLE)
  notes          String?

  assignedToId   String?
  assignedTo     User?        @relation("AssetAssignee", fields: [assignedToId], references: [id])
  assignedAt     DateTime?
  returnedAt     DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
}

enum AssetType {
  LAPTOP
  DESKTOP
  MONITOR
  PHONE
  TABLET
  KEYBOARD
  MOUSE
  HEADSET
  WEBCAM
  CHAIR
  DESK
  ID_CARD
  ACCESS_CARD
  VEHICLE
  OTHER
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  IN_REPAIR
  RETIRED
  LOST
}

// ============================================
// Candor Sessions — anonymous team feedback
// ============================================

model CandorSession {
  id             String           @id @default(cuid())
  title          String
  description    String?
  status         String           @default("DRAFT")  // DRAFT, ACTIVE, CLOSED
  prompts        Json             @default("[]")      // Array of { id, text, type: "text"|"rating"|"start_stop_continue" }
  departmentId   String?
  createdBy      String
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses      CandorResponse[]
  launchedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
  @@index([status])
}

model CandorResponse {
  id        String        @id @default(cuid())
  sessionId String
  session   CandorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers   Json          @default("[]")  // Array of { promptId, value }
  createdAt DateTime      @default(now())

  @@index([sessionId])
}

// ==========================================
// COMPLIANCE & CONSENT
// ==========================================

/// Records user consent for cookies/tracking. GDPR/UK-GDPR require proof
/// of consent including timestamp, method, scope, and text version.
/// Never delete records — retain per legal retention policy.
model ConsentRecord {
  id               String    @id @default(cuid())
  userId           String?   // null for pre-auth visitors
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?   // anonymous cookie identifier
  organizationId   String?   // when consent tied to a tenant

  // Consent scope
  necessary        Boolean   @default(true)   // always true, but logged for record
  preferences      Boolean   @default(false)
  analytics        Boolean   @default(false)
  marketing        Boolean   @default(false)
  doNotSell        Boolean   @default(false)  // CCPA/CPRA opt-out flag

  // Legal basis / region at time of consent
  region           String?   // e.g. "EU", "UK", "US-CA", "BR", "IN", "ROW"
  country          String?   // ISO 3166-1 alpha-2
  policyVersion    String    // ties to versioned policy text
  method           String    // "banner", "settings", "api", "withdrawn"

  // Evidence
  ipAddress        String?
  userAgent        String?

  withdrawnAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([organizationId])
  @@index([createdAt])
}

// ==========================================
// Public API — keys, webhooks, deliveries
// ==========================================

model ApiKey {
  id             String    @id @default(cuid())
  // Display name chosen by the admin — e.g. "Production · Backend"
  name           String
  // First 8 chars of the plaintext key, used for display + lookup hint.
  // Full key is only shown once at creation time.
  prefix         String
  // SHA-256 hash of the plaintext key. We never store the raw key.
  hashedKey      String    @unique
  // Scopes granted to this key. READ = GET endpoints only.
  // WRITE adds create/update. ADMIN is full control including key mgmt.
  scopes         ApiKeyScope[] @default([READ])
  // Windowed limits (requests / minute, day). Enforced in middleware.
  rateLimitPerMinute Int    @default(120)
  rateLimitPerDay    Int    @default(50000)
  // Usage telemetry
  lastUsedAt     DateTime?
  lastUsedIp     String?
  requestCount   Int       @default(0)
  revokedAt      DateTime?
  // Ownership
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  rateLimitBuckets ApiKeyRateBucket[]

  @@index([organizationId])
  @@index([hashedKey])
  @@index([prefix])
}

enum ApiKeyScope {
  READ
  WRITE
  ADMIN
}

/// Rolling-window rate limiter bucket. One row per (apiKey, windowKey).
/// windowKey is a compact epoch-minute or epoch-day string.
model ApiKeyRateBucket {
  id         String  @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  windowKind RateWindow
  windowKey  String
  count      Int     @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([apiKeyId, windowKind, windowKey])
  @@index([apiKeyId])
}

enum RateWindow {
  MINUTE
  DAY
}

/// Customer-registered webhook endpoint. Workwrk POSTs events to `url`
/// with an HMAC-SHA256 signature in X-Workwrk-Signature.
model WebhookSubscription {
  id             String    @id @default(cuid())
  url            String
  // Event types this subscription is interested in (e.g. "kudos.created",
  // "review.completed"). Wildcard "*" subscribes to everything.
  events         String[]
  // HMAC secret — generated at creation, shown once, hashed in storage.
  secretHash     String
  secretPrefix   String    // First 8 chars for identification (shown in UI).
  status         WebhookStatus @default(ACTIVE)
  // Rolling failure counter — deliveries auto-pause after too many 5xx.
  failureCount   Int       @default(0)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User      @relation("WebhookCreator", fields: [createdById], references: [id])
  deliveries     WebhookDelivery[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

/// Audit log + retry queue for individual webhook attempts.
model WebhookDelivery {
  id             String    @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         DeliveryStatus @default(PENDING)
  httpStatus     Int?
  responseBody   String?
  attemptCount   Int       @default(0)
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([status, nextAttemptAt])
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ==========================================
// DIMENSIONAL TAGS (Worktags equivalent)
// ==========================================
// Polymorphic tagging — any entity (User, Task, KRA, OKR, Expense…)
// can carry one or more tags. The intended use is for cost-center /
// business-unit / region / project slicing on reports and budgets,
// without bespoke schema per dimension. Modeled after Workday's
// Worktags: a single tag travels across HR, Finance, and Planning
// records so the CFO can drill down by region or project without
// schema gymnastics.
//
// `entityType` + `entityId` is intentionally polymorphic. We trade
// referential integrity for flexibility — adding a new taggable
// entity (e.g. Phase 2 ATS Candidate) just adds a new enum value.
// Cleanup of orphans is handled by a periodic cron, not the DB.

model Tag {
  id             String         @id @default(cuid())
  name           String
  type           TagType        @default(CUSTOM)
  color          String?        // hex, optional UX
  description    String?
  archived       Boolean        @default(false)

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignments    TagAssignment[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, type, name])
  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, archived])
}

model TagAssignment {
  id             String         @id @default(cuid())
  tagId          String
  tag            Tag            @relation(fields: [tagId], references: [id], onDelete: Cascade)

  entityType     TagEntityType
  entityId       String

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedById   String?        // User.id — null on system-applied tags

  createdAt      DateTime       @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([organizationId, entityType])
  @@index([tagId])
}

enum TagType {
  COST_CENTER
  BUSINESS_UNIT
  LOCATION
  REGION
  PROJECT
  FUNCTION
  CUSTOM
}

enum TagEntityType {
  USER
  TASK
  KRA
  KPI
  OKR
  SOP
  REVIEW
  REVIEW_CYCLE
  ASSET
  EXPENSE
  MEETING
}
