// ==========================================
// 🆕 PHASE E6 · WorkwrK Legal
// Contracts (CLM) + Privacy requests (DSARs) + IP records. General
// Counsel buyer surface. Distinct from /policies (internal company
// rules) — this is external-party contracts + compliance work.
// ==========================================

model Contract {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId       String? // nullable: legacy rows are workspace-agnostic
  title             String
  counterparty      String // the other party's name
  counterpartyType  String? // "Customer" | "Vendor" | "Partner" | "Investor" | "Employee" | ...
  type              String? // "MSA" | "DPA" | "NDA" | "SOW" | "Order Form" | ...
  status            ContractStatus @default(DRAFT)
  value             Decimal?       @db.Decimal(14, 2)
  currency          String         @default("USD")
  signedAt          DateTime?
  effectiveDate     DateTime?
  expiresAt         DateTime?
  // Auto-renew alert. Each contract has a renewal notice date; legal
  // gets pinged this many days before expiry.
  renewalNoticeDays Int?           @default(60)
  autoRenew         Boolean        @default(false)
  ownerId           String? // legal lead on this contract
  documentUrl       String?
  description       String?        @db.Text
  terms             Json           @default("{}") // key clauses / extracted terms
  customFields      Json           @default("{}")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, counterparty])
  @@index([organizationId, workspaceId])
  @@index([expiresAt])
}

enum ContractStatus {
  DRAFT
  IN_REVIEW
  IN_NEGOTIATION
  AWAITING_SIGNATURE
  SIGNED
  ACTIVE
  EXPIRED
  RENEWED
  TERMINATED
  CANCELLED
}

model PrivacyRequest {
