// ============================================
// Candor Sessions — anonymous team feedback
// ============================================

model CandorSession {
  id             String           @id @default(cuid())
  title          String
  description    String?
  status         String           @default("DRAFT") // DRAFT, ACTIVE, CLOSED
  prompts        Json             @default("[]") // Array of { id, text, type: "text"|"rating"|"start_stop_continue" }
  departmentId   String?
  createdBy      String
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses      CandorResponse[]
  launchedAt     DateTime?
  closedAt       DateTime?
