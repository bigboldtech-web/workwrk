// ==========================================
// COMPLIANCE & CONSENT
// ==========================================

/// Records user consent for cookies/tracking. GDPR/UK-GDPR require proof
/// of consent including timestamp, method, scope, and text version.
/// Never delete records — retain per legal retention policy.
model ConsentRecord {
  id             String  @id @default(cuid())
  userId         String? // null for pre-auth visitors
  user           User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId      String? // anonymous cookie identifier
  organizationId String? // when consent tied to a tenant

  // Consent scope
  necessary   Boolean @default(true) // always true, but logged for record
  preferences Boolean @default(false)
  analytics   Boolean @default(false)
  marketing   Boolean @default(false)
  doNotSell   Boolean @default(false) // CCPA/CPRA opt-out flag

  // Legal basis / region at time of consent
  region        String? // e.g. "EU", "UK", "US-CA", "BR", "IN", "ROW"
  country       String? // ISO 3166-1 alpha-2
  policyVersion String // ties to versioned policy text
  method        String // "banner", "settings", "api", "withdrawn"

  // Evidence
  ipAddress String?
  userAgent String?

  withdrawnAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([organizationId])
  @@index([createdAt])
}

// ==========================================
// Public API — keys, webhooks, deliveries
// ==========================================

model ApiKey {
  id                 String        @id @default(cuid())
  // Display name chosen by the admin — e.g. "Production · Backend"
  name               String
  // First 8 chars of the plaintext key, used for display + lookup hint.
  // Full key is only shown once at creation time.
  prefix             String
  // SHA-256 hash of the plaintext key. We never store the raw key.
  hashedKey          String        @unique
  // Scopes granted to this key. READ = GET endpoints only.
  // WRITE adds create/update. ADMIN is full control including key mgmt.
  scopes             ApiKeyScope[] @default([READ])
  // Windowed limits (requests / minute, day). Enforced in middleware.
  rateLimitPerMinute Int           @default(120)
  rateLimitPerDay    Int           @default(50000)
  // Usage telemetry
  lastUsedAt         DateTime?
  lastUsedIp         String?
  requestCount       Int           @default(0)
  revokedAt          DateTime?
  // Ownership
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById        String
  createdBy          User          @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  rateLimitBuckets ApiKeyRateBucket[]

  @@index([organizationId])
  @@index([hashedKey])
  @@index([prefix])
}

enum ApiKeyScope {
  READ
  WRITE
  ADMIN
}

/// Rolling-window rate limiter bucket. One row per (apiKey, windowKey).
/// windowKey is a compact epoch-minute or epoch-day string.
model ApiKeyRateBucket {
  id         String     @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey     @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  windowKind RateWindow
  windowKey  String
  count      Int        @default(0)
  updatedAt  DateTime   @updatedAt

  @@unique([apiKeyId, windowKind, windowKey])
  @@index([apiKeyId])
}

enum RateWindow {
  MINUTE
  DAY
}

/// Customer-registered webhook endpoint. Workwrk POSTs events to `url`
/// with an HMAC-SHA256 signature in X-Workwrk-Signature.
model WebhookSubscription {
  id             String            @id @default(cuid())
  url            String
  // Event types this subscription is interested in (e.g. "kudos.created",
  // "review.completed"). Wildcard "*" subscribes to everything.
  events         String[]
  // HMAC secret — generated at creation, shown once, hashed in storage.
  secretHash     String
  secretPrefix   String // First 8 chars for identification (shown in UI).
  status         WebhookStatus     @default(ACTIVE)
  // Rolling failure counter — deliveries auto-pause after too many 5xx.
  failureCount   Int               @default(0)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User              @relation("WebhookCreator", fields: [createdById], references: [id])
  deliveries     WebhookDelivery[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

/// Audit log + retry queue for individual webhook attempts.
model WebhookDelivery {
  id             String              @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         DeliveryStatus      @default(PENDING)
  httpStatus     Int?
  responseBody   String?
  attemptCount   Int                 @default(0)
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([status, nextAttemptAt])
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ==========================================
// DIMENSIONAL TAGS (Worktags equivalent)
// ==========================================
// Polymorphic tagging — any entity (User, Task, KRA, OKR, Expense…)
// can carry one or more tags. The intended use is for cost-center /
// business-unit / region / project slicing on reports and budgets,
// without bespoke schema per dimension. Modeled after Workday's
// Worktags: a single tag travels across HR, Finance, and Planning
// records so the CFO can drill down by region or project without
// schema gymnastics.
//
// `entityType` + `entityId` is intentionally polymorphic. We trade
// referential integrity for flexibility — adding a new taggable
// entity (e.g. Phase 2 ATS Candidate) just adds a new enum value.
// Cleanup of orphans is handled by a periodic cron, not the DB.

model Tag {
  id          String  @id @default(cuid())
  name        String
  type        TagType @default(CUSTOM)
  color       String? // hex, optional UX
  description String?
  archived    Boolean @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignments TagAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, type, name])
  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, archived])
}

model TagAssignment {
  id    String @id @default(cuid())
  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  entityType TagEntityType
  entityId   String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedById String? // User.id — null on system-applied tags

  createdAt DateTime @default(now())

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([organizationId, entityType])
  @@index([tagId])
}

enum TagType {
  COST_CENTER
  BUSINESS_UNIT
  LOCATION
  REGION
  PROJECT
  FUNCTION
  CUSTOM
}

enum TagEntityType {
  USER
  TASK
  KRA
  KPI
  OKR
  SOP
  REVIEW
  REVIEW_CYCLE
  ASSET
  EXPENSE
  MEETING
  TIME_OFF_REQUEST
  TIMESHEET
  POLICY
  PROCESS_RUN
  ANNOUNCEMENT
  DEPARTMENT
  ROLE
  VENDOR
  PURCHASE_ORDER
  INVOICE
  CANDIDATE
  JOB
  BOARD_ITEM
}

// ==========================================
// EXPENSES (Phase 2)
// ==========================================
// Employee expense submission + approval flow. Single-currency per
// org for v1 (reporting in `currency`). Multi-currency, FX rates,
// auto-routing, and OCR all sit behind this — schema doesn't preclude
// them. Cost-center / project attribution rides the polymorphic
// TagAssignment system rather than direct FKs, so adding a new
// dimension (e.g. Fund) doesn't require a schema change here.
//
// Decimal(12,2) for `amount`: 10 digits of dollars + 2 cents. Float
// is wrong for money — at Fortune-500 volume the rounding bites.

model Expense {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User   @relation("ExpenseReporter", fields: [reporterId], references: [id])

  description String // short headline visible in lists
  notes       String? // longer context, only on detail
  category    ExpenseCategory

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("USD") // ISO 4217

  expenseDate DateTime
  receiptUrl  String? // S3 URL after upload

  status      ExpenseStatus @default(DRAFT)
  submittedAt DateTime?

  approverId   String?
  approver     User?     @relation("ExpenseApprover", fields: [approverId], references: [id])
  decisionAt   DateTime?
  decisionNote String? // why approved / rejected

  reimbursedAt DateTime? // future: link to a Payment row when payroll lands

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, expenseDate])
  @@index([reporterId, status])
  @@index([approverId, status])
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  LODGING
  TRANSPORT
  SUPPLIES
  SUBSCRIPTION
  EQUIPMENT
  CLIENT_ENTERTAINMENT
  TRAINING
  OTHER
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

// ==========================================
// COMPENSATION CYCLES (Phase 2)
// ==========================================
// Annual / biannual comp review. Managers propose merit + bonus per
// direct report; HR finalizes. Salary bands and PDF letter generation
// land in v2. Equity grants are a separate v3 surface.
//
// Comp data is the single most sensitive record in the org —
// authorization on every read goes through CompensationDecision's
// (subjectId, proposedById, decidedById) triangle: subject sees their
// own row, proposer (manager) sees rows for their reports, HR sees
// everything.

model CompensationCycle {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      CompCycleStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime

  // Optional org-wide budget guidance for managers — e.g. "stay under
  // 5% across the team." Stored as percent, signed Decimal(5,2).
  budgetPct         Decimal? @db.Decimal(5, 2)
  reportingCurrency String   @default("USD")

  closedAt  DateTime?
  decisions CompensationDecision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, startDate])
}

model CompensationDecision {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  cycleId String
  cycle   CompensationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  subjectId    String
  subject      User    @relation("CompDecisionSubject", fields: [subjectId], references: [id])
  proposedById String?
  proposedBy   User?   @relation("CompDecisionProposer", fields: [proposedById], references: [id])

  currentSalary  Decimal? @db.Decimal(12, 2)
  proposedSalary Decimal? @db.Decimal(12, 2)
  currency       String   @default("USD")
  // Signed so we can encode pay cuts (rare but legal). Two decimals
  // avoids float surprises — 5.50% vs 5.499999%.
  changePct      Decimal? @db.Decimal(6, 2)
  bonusAmount    Decimal? @db.Decimal(12, 2)
  reasoning      String?

  status       CompDecisionStatus @default(DRAFT)
  decisionNote String?
  // Audit fields without relations — HR ops can swap who finalized
  // without rewiring rows. The id should resolve via User lookup.
  decidedById  String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cycleId, subjectId])
  @@index([organizationId, status])
  @@index([cycleId, status])
  @@index([subjectId])
  @@index([proposedById])
}

enum CompCycleStatus {
  DRAFT
  OPEN
  CLOSED
}

enum CompDecisionStatus {
  DRAFT
  PROPOSED
  APPROVED
  REJECTED
}

// ==========================================
// TIME OFF (Phase 2)
// ==========================================
// Org-defined leave policies (PTO, sick, parental, bereavement…) and
// per-employee requests. Balances are computed lazily from policy
// allowance minus approved/pending hours — no separate Balance table
// to drift out of sync. Carryover and accrual lookbacks live in the
// computation, not the schema.
//
// Timesheets (clock-in/out, hours per task) are a separate surface
// that lands in v2 — they need a different UX (calendar grid + timer)
// and different permission rules.

model TimeOffPolicy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  type        TimeOffType @default(PTO)
  color       String?
  description String?

  annualHours      Decimal @db.Decimal(8, 2)
  carryoverHours   Decimal @default(0) @db.Decimal(8, 2)
  requiresApproval Boolean @default(true)
  archived         Boolean @default(false)

  // Accrual config (Phase 2 v2). UPFRONT grants annualHours on
  // anniversary; ACCRUE drips hours each period. accrualRate is
  // computed from annualHours when null, otherwise overrides
  // (lets jurisdictions with hour-based laws use a fixed rate).
  accrualMode       AccrualMode      @default(UPFRONT)
  accrualFrequency  AccrualFrequency @default(MONTHLY)
  accrualRate       Decimal?         @db.Decimal(8, 4)
  waitingPeriodDays Int              @default(0)
  maxBalanceHours   Decimal?         @db.Decimal(8, 2)

  requests TimeOffRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, archived])
}

model TimeOffRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TimeOffSubject", fields: [userId], references: [id])

  policyId String
  policy   TimeOffPolicy @relation(fields: [policyId], references: [id], onDelete: Restrict)

  startDate DateTime
  endDate   DateTime
  // Explicit so partial-day requests (e.g. 4-hour afternoon doctor
  // visit) work — we don't infer days × 8 server-side.
  hours     Decimal  @db.Decimal(6, 2)
  reason    String?

  status       TimeOffStatus @default(PENDING)
  approverId   String?
  approver     User?         @relation("TimeOffApprover", fields: [approverId], references: [id])
  decisionAt   DateTime?
  decisionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([approverId, status])
  @@index([userId, startDate])
}

enum TimeOffType {
  PTO
  SICK
  PERSONAL
  BEREAVEMENT
  PARENTAL
  UNPAID
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ==========================================
// TIME TRACKING / TIMESHEETS (Phase 2)
// ==========================================
// Two-mode: knowledge workers fill a weekly grid (web entry); hybrid /
// hourly workers click clock-in/clock-out and the system computes the
// minutes. Both produce TimeEntry rows owned by a weekly Timesheet
// envelope that goes through manager approval.
//
// Cost-center / project attribution rides the polymorphic
// TagAssignment table (entityType=TIME_ENTRY would extend the enum
// later — for v1 we tag at the Timesheet level for weekly rollup, and
// optionally link individual entries to a Task).
//
// Mobile, kiosks, and jurisdictional overtime rules (CA daily OT,
// meal-break attestation, etc.) all sit behind this — schema doesn't
// preclude them but UX is v2/v3.

model Timesheet {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TimesheetSubject", fields: [userId], references: [id])

  // Week anchor — Monday 00:00 UTC of the week. Single canonical
  // representation; the UI handles display in user's locale.
  weekStartDate DateTime

  status      TimesheetStatus @default(DRAFT)
  submittedAt DateTime?

  approverId   String?
  approver     User?     @relation("TimesheetApprover", fields: [approverId], references: [id])
  decisionAt   DateTime?
  decisionNote String?

  entries TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStartDate])
  @@index([organizationId, status])
  @@index([userId, weekStartDate])
  @@index([approverId, status])
}

model TimeEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  // Denormalized for cheap "is user currently clocked in" lookups
  // without a join. Always equal to timesheet.userId.
  userId String
  user   User   @relation("TimeEntrySubject", fields: [userId], references: [id])

  // Day this entry counts toward — 00:00 UTC. An overnight shift may
  // straddle two days; v1 anchors to the day the punch *started*.
  day DateTime

  // Set on save. For active punches, hours is null until clockedOutAt
  // arrives, then computed.
  hours Decimal? @db.Decimal(5, 2)

  clockedInAt  DateTime?
  clockedOutAt DateTime?

  description String?
  source      TimeEntrySource @default(WEB)

  // Optional link to an existing Task (the "what was I working on").
  // Cost-center / business-unit / project tagging rides on the parent
  // Timesheet via TagAssignment.
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, day])
  @@index([userId, day])
  @@index([timesheetId])
  // Hot index for "is this user clocked in right now?" — used on
  // every page load by the topbar's active-punch widget.
  @@index([userId, clockedOutAt])
  @@index([taskId])
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimeEntrySource {
  WEB
  PUNCH
  MOBILE
  KIOSK
  IMPORT
}

// ==========================================
// ATS / RECRUITING (Phase 2)
// ==========================================
// Three core entities — Job (the requisition), Candidate (the person),
// Application (the pipeline state of one candidate against one job).
// Public career-page applications, structured scorecards, interview
// scheduling, and offer-letter generation all sit downstream of this
// minimal triangle.
//
// Email uniqueness on Candidate is org-scoped on purpose — Fortune
// 500 conglomerates run separate hiring orgs across regions / business
// units and the same person legitimately applies through more than
// one. Cross-org dedup happens at the user-account layer when they're
// hired, not at the candidate layer.

model Job {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String? // nullable: legacy rows are workspace-agnostic

  title          String
  description    String?
  status         JobStatus      @default(DRAFT)
  employmentType EmploymentType @default(FULL_TIME)
  // Location can be a city, "Remote", or "Hybrid - SF". v2 splits to
  // a structured location relation; for v1 free text is enough.
  location       String?

  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  hiringManagerId String?
  hiringManager   User?       @relation("JobHiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)

  // Optional posted salary range. Two separate Decimals so an "at
  // least" or "at most" range works without a sentinel.
  salaryMin      Decimal? @db.Decimal(12, 2)
  salaryMax      Decimal? @db.Decimal(12, 2)
  salaryCurrency String   @default("USD")

  openings    Int       @default(1)
  publishedAt DateTime?
  closedAt    DateTime?

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@index([organizationId, workspaceId])
  @@index([hiringManagerId])
}

model Candidate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String? // nullable: legacy rows are workspace-agnostic

  firstName String
  lastName  String
  email     String
  phone     String?
  resumeUrl String?
  source    String? // free text, e.g. "LinkedIn", "Referral - Mary G."
  notes     String?

  // Once a candidate is hired we link them to the User they became.
  // Set by the HIRED transition; null otherwise.
  hiredUserId String?
  hiredUser   User?   @relation("CandidateHiredUser", fields: [hiredUserId], references: [id], onDelete: SetNull)

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, workspaceId])
  @@index([hiredUserId])
}

model Application {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  stage           ApplicationStage @default(APPLIED)
  rejectionReason String?
  source          String? // optional, mirrors Candidate.source for per-app variation

  recruiterId String?
  recruiter   User?   @relation("ApplicationRecruiter", fields: [recruiterId], references: [id], onDelete: SetNull)

  notes String?

  interviews Interview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, candidateId])
  @@index([organizationId, stage])
  @@index([jobId, stage])
  @@index([recruiterId, stage])
  @@index([candidateId])
}

enum JobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

// ==========================================
// ENTERPRISE IDENTITY (SSO / SCIM)
// ==========================================
// One IdentityProvider row per (org, type). Multiple orgs can sit on
// the same vendor (Okta, Azure AD, Google Workspace, OneLogin) but
// each tenant's config is private. SCIM tokens are per-org bearer
// credentials that an IT admin pastes into their IdP — they auth all
// /scim/v2/* endpoints. The token bytes are hashed at rest;
// `tokenPrefix` (first 8 chars) is kept plaintext for UI display
// without enabling reuse.

model IdentityProvider {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type    IdpType @default(SAML)
  enabled Boolean @default(false)

  // SAML fields. OIDC support adds more columns later.
  issuer      String? // IdP entity ID
  ssoUrl      String? // IdP login endpoint (HTTP-Redirect or HTTP-POST)
  sloUrl      String? // logout endpoint
  certificate String? // base64-encoded x509, used to verify assertions

  // Attribute mapping — where to pull email / firstName / lastName /
  // (optional) department / accessLevel from the SAML assertion.
  // Defaults match Okta's standard mapping. Stored as JSON for
  // flexibility on per-tenant tweaks.
  attributeMap Json @default("{\"email\":\"NameID\",\"firstName\":\"firstName\",\"lastName\":\"lastName\"}")

  // Just-in-time provision: create User on first SAML login if email
  // doesn't exist in the org. Companies running SCIM usually disable
  // this so all account creation is centralized.
  jitProvision Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, type])
  @@index([organizationId])
}

model ScimToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String // human label, e.g. "Okta production"
  // sha-256 of the raw token bytes; the raw token is shown exactly
  // once at creation and never stored. Lookup on auth = hash incoming
  // bearer and find the row.
  tokenHash   String @unique
  // First 8 chars of the raw token, e.g. "wkw_a4b2…", so the UI can
  // disambiguate multiple tokens without exposing the full secret.
  tokenPrefix String

  createdById String? // User.id of the admin who minted it
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId, revokedAt])
  @@index([tokenHash])
}

enum IdpType {
  SAML
  OIDC
}

// ==========================================
// PROCUREMENT / AP (Phase 3)
// ==========================================
// Vendor → PurchaseOrder → Invoice triangle. Single-line POs in v1
// (one description, one amount, one cost-center tag); multi-line items
// + three-way matching (PO + Goods Receipt + Invoice) come in v2.
// Cost-center attribution via the polymorphic TagAssignment so
// finance can roll spend up by region / project / business unit.

model Vendor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String
  email            String?
  contactName      String?
  phone            String?
  taxId            String? // EIN / VAT / GSTIN — free text in v1
  paymentTermsDays Int     @default(30)
  archived         Boolean @default(false)

  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, archived])
}

model PurchaseOrder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Auto-generated, org-scoped sequential. The DB-side default makes
  // it cheap; we increment and fall back to cuid on collision.
  number String

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  requesterId String
  requester   User    @relation("POrequester", fields: [requesterId], references: [id])
  approverId  String?
  approver    User?   @relation("POapprover", fields: [approverId], references: [id])

  description String
  amount      Decimal @db.Decimal(12, 2)
  currency    String  @default("USD")

  status               PurchaseOrderStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  submittedAt          DateTime?
  decisionAt           DateTime?
  decisionNote         String?

  invoices Invoice[]
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([vendorId, status])
  @@index([requesterId, status])
  @@index([approverId, status])
}

model Invoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // Optional link to a PO. Some vendors (utilities, subscriptions) bill
  // without a matching PO — we accept that for v1.
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  invoiceNumber String // vendor-supplied identifier
  amount        Decimal @db.Decimal(12, 2)
  currency      String  @default("USD")

  issueDate    DateTime
  dueDate      DateTime
  status       InvoiceStatus @default(PENDING)
  paidAt       DateTime?
  decisionAt   DateTime?
  decisionNote String?

  approverId String?
  approver   User?   @relation("InvoiceApprover", fields: [approverId], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, vendorId, invoiceNumber])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([vendorId, status])
  @@index([purchaseOrderId])
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SENT
  RECEIVED
  CLOSED
}

enum InvoiceStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ==========================================
// WORKFORCE PLANNING (Phase 3)
// ==========================================
// Headcount + salary-budget planning per department per period.
// Compared at view-time against live User.departmentId counts and
// (when comp data is available) against the active comp cycle's
// proposed salaries. Multi-scenario plans (Optimistic / Tight) are
// v2 — add a `scenarioName` column when the time comes.

model HeadcountPlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Free-form period token. Org picks granularity: "2026", "2026-Q1",
  // "2026-H1", "FY27", etc. Treated opaquely server-side; the UI
  // sorts asciibetically which matches lexical year/quarter ordering.
  period String

  plannedHeadcount Int
  plannedBudget    Decimal? @db.Decimal(14, 2)
  budgetCurrency   String   @default("USD")
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, departmentId, period])
  @@index([organizationId, period])
}

// ==========================================
// INTERVIEW SCHEDULING (Phase 2 v2 — extends ATS)
// ==========================================
// One Interview row per scheduled session against an Application.
// Multi-interviewer rounds in v3; for v1 a single interviewer
// suffices for SMB/mid-market hiring loops. Scorecard is a numeric
// score + notes; structured per-competency rubric is v2.

model Interview {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  interviewerId String
  interviewer   User   @relation("InterviewInterviewer", fields: [interviewerId], references: [id])

  scheduledAt     DateTime
  durationMinutes Int           @default(30)
  type            InterviewType @default(SCREEN)
  // Free-text — meeting URL, room name, or on-site address. Linking
  // to the Meeting model is v2.
  location        String?

  status InterviewStatus @default(SCHEDULED)

  // Post-interview scorecard. 1-5 numeric; notes free-text. v2
  // expands to per-competency rubric.
  score Int?
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([applicationId, status])
  @@index([interviewerId, scheduledAt])
}

enum InterviewType {
  SCREEN
  TECHNICAL
  BEHAVIORAL
  ONSITE
  FINAL
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ==========================================
// Payroll (Phase 4)
//
// Two-layer design: native records here capture every pay-period
// fact (gross/net/taxes/deductions/GL postings) so the org keeps
// the source of truth even if the org switches payroll vendors.
// A pluggable provider adapter (CheckHQ today, Gusto/ADP/Rippling
// later) handles tax calc + filing + direct deposit and writes
// results back into Payslip / PayslipLine. This split means we
// can swap vendors without losing history.
// ==========================================

model PayGroup {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  country        String       @default("US")
  currency       String       @default("USD")
  frequency      PayFrequency @default(BIWEEKLY)
  // First-period anchor — every subsequent period start is derived
  // from this date plus N×frequency. Stored explicitly so DST and
  // calendar drift don't compound.
  anchorDate     DateTime
  // Days after period end that paychecks land. Bank cutoff buffer.
  payOffsetDays  Int          @default(3)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  payRuns  PayRun[]
  payslips Payslip[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum PayFrequency {
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
  MONTHLY
}

model PayRun {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payGroupId      String
  payGroup        PayGroup     @relation(fields: [payGroupId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  payDate         DateTime
  status          PayRunStatus @default(DRAFT)
  // Totals are derived from Payslip rows but cached here so list
  // views don't N+1. Recomputed on transition to CALCULATED.
  totalGross      Decimal      @default(0) @db.Decimal(14, 2)
  totalNet        Decimal      @default(0) @db.Decimal(14, 2)
  totalTax        Decimal      @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal      @default(0) @db.Decimal(14, 2)
  // Vendor reference — opaque id from the provider (CheckHQ run id,
  // etc.) so we can reconcile filings.
  providerRef     String?
  notes           String?
  calculatedAt    DateTime?
  postedAt        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  payslips Payslip[]

  @@unique([payGroupId, periodStart])
  @@index([organizationId, status])
  @@index([payDate])
}

enum PayRunStatus {
  DRAFT // open for adjustments
  CALCULATING // provider crunching numbers
  CALCULATED // ready for review
  POSTED // funds released; immutable
  CANCELLED
}

// Earnings catalog — regular hours, overtime, bonus, commission.
// Each org can extend with custom codes. taxable + W2 box mapping
// captured here so a payroll run knows how to classify each line.
model EarningCode {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String // e.g. "REG", "OT", "BONUS"
  name           String
  taxable        Boolean      @default(true)
  // GL account hint — final mapping lives in the integration adapter.
  glAccount      String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  payslipLines PayslipLine[] @relation("PayslipLineEarning")

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Deductions catalog — pre-tax (401k, medical, HSA) vs post-tax
// (Roth 401k, garnishment). preTax flag drives tax base calc.
model DeductionCode {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String // e.g. "401K", "MED", "DEN"
  name           String
  preTax         Boolean      @default(false)
  // Optional cap per pay period or per year — null means no cap.
  perPeriodCap   Decimal?     @db.Decimal(12, 2)
  annualCap      Decimal?     @db.Decimal(12, 2)
  glAccount      String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  payslipLines PayslipLine[] @relation("PayslipLineDeduction")

  @@unique([organizationId, code])
  @@index([organizationId])
}

// One paystub for one employee for one pay period. Lines roll up
// into the totals on the parent. Stored even after the run is
// POSTED so the employee can always reprint.
model Payslip {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payRunId       String
  payRun         PayRun       @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  payGroupId     String
  payGroup       PayGroup     @relation(fields: [payGroupId], references: [id], onDelete: Restrict)
  subjectId      String
  subject        User         @relation("PayslipSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  // Cached totals — sum of lines. Recomputed when lines change.
  gross          Decimal      @default(0) @db.Decimal(12, 2)
  net            Decimal      @default(0) @db.Decimal(12, 2)
  tax            Decimal      @default(0) @db.Decimal(12, 2)
  deductions     Decimal      @default(0) @db.Decimal(12, 2)
  hoursWorked    Decimal      @default(0) @db.Decimal(8, 2)
  // Provider reference (CheckHQ paystub id) — null until posted.
  providerRef    String?
  // Where the paid funds went — stored for the employee record. Last
  // 4 digits only; full account info lives at the provider.
  payMethod      PayMethod    @default(DIRECT_DEPOSIT)
  bankLast4      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines PayslipLine[]

  @@unique([payRunId, subjectId])
  @@index([organizationId, subjectId])
  @@index([payGroupId])
}

enum PayMethod {
  DIRECT_DEPOSIT
  CHECK
  WIRE
  MANUAL
}

// One line on a paystub. Either an earning OR a deduction OR a tax
// — exactly one of those three id columns is non-null. Discriminated
// by `kind` for fast filtering.
model PayslipLine {
  id              String          @id @default(cuid())
  payslipId       String
  payslip         Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  kind            PayslipLineKind
  // For EARNING lines:
  earningCodeId   String?
  earningCode     EarningCode?    @relation("PayslipLineEarning", fields: [earningCodeId], references: [id], onDelete: Restrict)
  hours           Decimal?        @db.Decimal(8, 2)
  rate            Decimal?        @db.Decimal(10, 4)
  // For DEDUCTION lines:
  deductionCodeId String?
  deductionCode   DeductionCode?  @relation("PayslipLineDeduction", fields: [deductionCodeId], references: [id], onDelete: Restrict)
  // For TAX lines: human-readable label only. Provider does the math.
  taxLabel        String?
  amount          Decimal         @db.Decimal(12, 2)
  // YTD running total at the moment this line was generated. Used
  // for cap enforcement + W-2 reconciliation.
  ytdAmount       Decimal?        @db.Decimal(12, 2)

  @@index([payslipId])
  @@index([earningCodeId])
  @@index([deductionCodeId])
}

enum PayslipLineKind {
  EARNING
  DEDUCTION
  TAX
}

// ==========================================
// Benefits (Phase 4)
//
// Plan catalog → open-enrollment windows → per-employee elections
// → pay-period deduction lines. Dependents and life events drive
// off-cycle changes (marriage, birth, qualifying event).
// ==========================================

model BenefitPlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           BenefitType
  name           String
  carrier        String?
  description    String?
  // Default tier costs per pay period — can be overridden per
  // BenefitTier row for richer plans.
  employeeCost   Decimal      @default(0) @db.Decimal(10, 2)
  employerCost   Decimal      @default(0) @db.Decimal(10, 2)
  // Effective window — outside this range the plan can't be elected.
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tiers             BenefitTier[]
  enrollments       BenefitEnrollment[]
  enrollmentsInOpen OpenEnrollmentPlan[]

  @@unique([organizationId, name])
  @@index([organizationId, type])
}

enum BenefitType {
  MEDICAL
  DENTAL
  VISION
  LIFE
  DISABILITY_SHORT
  DISABILITY_LONG
  RETIREMENT_401K
  RETIREMENT_ROTH
  HSA
  FSA
  COMMUTER
  OTHER
}

model BenefitTier {
  id            String      @id @default(cuid())
  benefitPlanId String
  benefitPlan   BenefitPlan @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)
  // Coverage tier label — "Employee", "Employee + Spouse",
  // "Employee + Children", "Family", or org-custom strings.
  tier          String
  employeeCost  Decimal     @db.Decimal(10, 2)
  employerCost  Decimal     @db.Decimal(10, 2)

  enrollments BenefitEnrollment[]

  @@unique([benefitPlanId, tier])
}

model OpenEnrollment {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Window during which employees can submit elections.
  startDate      DateTime
  endDate        DateTime
  // When the elections take effect (typically Jan 1).
  effectiveDate  DateTime
  status         OpenEnrollmentStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  plans       OpenEnrollmentPlan[]
  enrollments BenefitEnrollment[]

  @@index([organizationId, status])
}

enum OpenEnrollmentStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

// Junction — which plans are offered in a given OE window.
model OpenEnrollmentPlan {
  id               String         @id @default(cuid())
  openEnrollmentId String
  openEnrollment   OpenEnrollment @relation(fields: [openEnrollmentId], references: [id], onDelete: Cascade)
  benefitPlanId    String
  benefitPlan      BenefitPlan    @relation(fields: [benefitPlanId], references: [id], onDelete: Cascade)

  @@unique([openEnrollmentId, benefitPlanId])
}

// One employee's election for one plan. Always linked to the OE
// window that produced it (or the LifeEvent for off-cycle changes).
// Status moves DRAFT → SUBMITTED → ACTIVE → ENDED.
model BenefitEnrollment {
  id               String           @id @default(cuid())
  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          User             @relation("BenefitEnrollmentSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  benefitPlanId    String
  benefitPlan      BenefitPlan      @relation(fields: [benefitPlanId], references: [id], onDelete: Restrict)
  benefitTierId    String?
  benefitTier      BenefitTier?     @relation(fields: [benefitTierId], references: [id], onDelete: Restrict)
  openEnrollmentId String?
  openEnrollment   OpenEnrollment?  @relation(fields: [openEnrollmentId], references: [id], onDelete: SetNull)
  lifeEventId      String?
  lifeEvent        LifeEvent?       @relation(fields: [lifeEventId], references: [id], onDelete: SetNull)
  // Per-pay-period cost snapshot at time of election. Pulling from
  // BenefitTier directly would lose history when tier costs change.
  employeeCost     Decimal          @db.Decimal(10, 2)
  employerCost     Decimal          @db.Decimal(10, 2)
  effectiveStart   DateTime
  effectiveEnd     DateTime?
  status           EnrollmentStatus @default(DRAFT)
  notes            String?
  // Provider reference (carrier confirmation id) — null until the
  // adapter has acknowledged the election.
  providerRef      String?
  submittedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([organizationId, subjectId])
  @@index([benefitPlanId, status])
  @@index([openEnrollmentId])
  @@index([lifeEventId])
}

enum EnrollmentStatus {
  DRAFT
  SUBMITTED
  ACTIVE
  ENDED
  CANCELLED
}

model Dependent {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User                  @relation("DependentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  relationship   DependentRelationship
  dateOfBirth    DateTime?
  // Last 4 only — full SSN never stored at app layer; vendor handles.
  ssnLast4       String?
  // Whether this dependent currently appears on any benefit
  // election. Maintained by the adapter when carriers confirm.
  coveredOnPlan  Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId, ownerId])
}

enum DependentRelationship {
  SPOUSE
  DOMESTIC_PARTNER
  CHILD
  STEPCHILD
  OTHER
}

// Qualifying life event — opens an off-cycle election window for
// the affected employee. The benefits team approves before it
// becomes actionable.
model LifeEvent {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subjectId         String
  subject           User            @relation("LifeEventSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  type              LifeEventType
  eventDate         DateTime
  status            LifeEventStatus @default(REPORTED)
  // 60-day default window — adjustable per type / jurisdiction.
  electionWindowEnd DateTime?
  notes             String?
  approvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  enrollments BenefitEnrollment[]

  @@index([organizationId, subjectId])
  @@index([status])
}

enum LifeEventType {
  MARRIAGE
  DIVORCE
  BIRTH
  ADOPTION
  DEATH
  GAIN_COVERAGE
  LOSS_COVERAGE
  DEPENDENT_LOSS
  ADDRESS_CHANGE
  OTHER
}

enum LifeEventStatus {
  REPORTED
  APPROVED
  REJECTED
  ENROLLED
}

enum AccrualMode {
  UPFRONT // grant annualHours on hire / anniversary
  ACCRUE // drip hours per period
}

enum AccrualFrequency {
  PER_PAY_PERIOD
  MONTHLY
  QUARTERLY
}

// ==========================================
// Adaptive Planning (Phase 5 v3)
//
// Native budgeting + forecasting on top of the GL. A Plan is a
// container (budget, forecast, strategic plan); its lines live in
// PlanLine — one row per (account × period × cost center × scenario).
// PlanScenario lets the org compare base/upside/downside without
// duplicating the whole plan. Reports compare PlanLine.amount to
// JournalLine sums for variance views.
// ==========================================

model BudgetPlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fiscalYearId   String
  fiscalYear     FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  name           String
  type           PlanType     @default(BUDGET)
  status         PlanStatus   @default(DRAFT)
  // Plan versions — incrementing each time PUBLISH is hit. Lets the
  // org audit "what did we forecast last quarter?" without locking
  // editing on the active plan.
  version        Int          @default(1)
  baselineId     String? // pointer to the version this was branched from
  description    String?
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  scenarios PlanScenario[]
  lines     PlanLine[]

  @@unique([organizationId, fiscalYearId, name, version])
  @@index([organizationId, status])
  @@index([fiscalYearId])
}

enum PlanType {
  BUDGET // approved annual budget
  FORECAST // rolling re-forecast as actuals land
  STRATEGIC // 3-5 year outlook
  WHAT_IF // scratch scenario, never published
}

enum PlanStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Scenarios let one Plan contain Base / Upside / Downside views
// without copying every line three times. A line that doesn't
// reference a scenario falls under the Plan's default scenario,
// which the API auto-creates on Plan create.
model PlanScenario {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           BudgetPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  name           String
  // Quick-multiply factor applied to "Base" lines when the scenario
  // hasn't been edited line-by-line. Set null for hand-edited
  // scenarios.
  multiplier     Decimal?     @db.Decimal(8, 4)
  notes          String?
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  lines PlanLine[]

  @@unique([planId, name])
  @@index([planId])
}

model PlanLine {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           BudgetPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  scenarioId     String
  scenario       PlanScenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  accountId      String
  account        GlAccount        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenterId   String?
  costCenter     CostCenter?      @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  periodId       String
  period         AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  amount         Decimal          @db.Decimal(14, 2)
  driverId       String?
  driver         PlanDriver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([planId, scenarioId, accountId, costCenterId, periodId])
  @@index([planId, accountId])
  @@index([periodId])
  @@index([costCenterId])
}

// Driver = named assumption that justifies a number. "Headcount
// growth: 25% YoY". "Revenue per rep: $250k". The formula is free
// text for now — Studio v2 will parse + recompute.
model PlanDriver {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  formula        String? // human-readable for now
  assumptions    Json         @default("{}")
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lines PlanLine[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ==========================================
// Studio (Phase 5 v3) — custom workflows + custom fields.
//
// Workflow lets an admin define a multi-step approval flow that
// any Submittable record (PO, expense, comp decision, etc.) can
// run through. WorkflowRun is one execution against one record.
//
// CustomFieldDefinition + CustomFieldValue add per-org fields to
// any entity without schema migrations: definitions live in JSON,
// values are key-value rows. Trade-off: no enforced data type at
// the DB layer; the API validates against the definition.
// ==========================================

model Workflow {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // Polymorphic target — workflows attach to a record type, not
  // a specific instance. Same string used in TagEntityType where
  // applicable; free strings allowed for new types.
  targetType     String
  active         Boolean      @default(true)
  // What kind of workflow this is. APPROVAL = approval chain (legacy
  // step-based). AUTOMATION = event-driven Autopilot rule with
  // trigger + conditions + actions.
  kind           WorkflowKind @default(APPROVAL)
  // For AUTOMATION workflows: event name that fires this rule.
  // Format "domain.event" e.g. "lead.created" | "ticket.created" |
  // "opportunity.stage_changed". Null for APPROVAL.
  triggerEvent   String?
  // For AUTOMATION: JSON conditions evaluated against the trigger
  // payload. Shape: { field: "priority", op: "eq", value: "URGENT" }
  // (single condition for v1; AND-list later).
  conditions     Json         @default("{}")
  // Steps are stored as an ordered JSON array.
  //   APPROVAL: { id, name, approverRule, slaHours, requireNote }
  //   AUTOMATION: { id, type: "notify" | "create_task" | "run_agent",
  //                 config: { ... } }
  steps          Json         @default("[]")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  runs WorkflowRun[]

  @@unique([organizationId, name])
  @@index([organizationId, targetType, active])
  @@index([organizationId, kind, triggerEvent, active])
}

enum WorkflowKind {
  APPROVAL
  AUTOMATION
}

model WorkflowRun {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowId     String
  workflow       Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  // Polymorphic record reference — entityType + entityId.
  entityType     String
  entityId       String
  status         WorkflowRunStatus @default(IN_PROGRESS)
  currentStep    Int               @default(0)
  // Step-by-step decisions captured as JSON so the audit trail is
  // self-contained. Each entry: { step, decidedBy, decision, note,
  // at }.
  decisions      Json              @default("[]")
  startedAt      DateTime          @default(now())
  completedAt    DateTime?

  @@index([organizationId, status])
  @@index([entityType, entityId])
}

enum WorkflowRunStatus {
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  // 🆕 Phase D5 Autopilot — AUTOMATION workflow runs use these
  COMPLETED
  FAILED
}


// ==========================================
// Overtime engine (Phase 4 v3 / Mobile Clock-in)
//
// OvertimePolicy captures the jurisdictional rules an org needs:
// California: 8h daily / 40h weekly / 6th-day rules. Federal FLSA:
// 40h weekly. Customer can layer their own rules on top. The
// engine consumes TimeEntry rows + a policy and returns regular /
// overtime / double-time hour buckets.
// ==========================================

model OvertimePolicy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  jurisdiction   String // free text: "US-CA", "US-FED", "AU-NSW"
  // Daily threshold over which OT kicks in. Null = no daily rule.
  dailyOtAfter   Decimal?     @db.Decimal(4, 2) // e.g. 8.00
  dailyDtAfter   Decimal?     @db.Decimal(4, 2) // double-time threshold
  // Weekly threshold over which OT kicks in. Null = no weekly rule.
  weeklyOtAfter  Decimal?     @db.Decimal(5, 2) // e.g. 40.00
  // Optional 7th-consecutive-day rule (CA): first 8h are OT, beyond
  // 8h is DT. Null disables.
  seventhDayOt   Boolean      @default(false)
  active         Boolean      @default(true)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, active])
}

// Salary band — min / mid / max for a role within a location and
// (optionally) a level. Used during compensation cycles to flag
// out-of-band proposals before they're approved.
model SalaryBand {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Free-text role label and optional level (P3, M2, etc.) so
  // orgs without a formal job-architecture can still slot bands
  // against role names.
  role           String
  level          String?
  location       String?
  currency       String       @default("USD")
  minAmount      Decimal      @db.Decimal(12, 2)
  midAmount      Decimal      @db.Decimal(12, 2)
  maxAmount      Decimal      @db.Decimal(12, 2)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  active         Boolean      @default(true)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, role, level, location])
  @@index([organizationId, active])
}

// ==========================================
// Core Financials (Phase 5)
//
// Native double-entry GL. Chart of accounts is per-org so a
// scaling SaaS doesn't enforce a US-only hierarchy on a Dubai
// customer. Journal entries are immutable once posted; reversals
// happen via offsetting entries, never via mutation. Reports
// (P&L, balance sheet, trial balance) read from JournalLine
// aggregates; we never cache balances in a separate Account.balance
// column because they always drift.
// ==========================================

// Chart-of-accounts entry. type drives report classification:
//   ASSET / LIABILITY / EQUITY → balance sheet
//   REVENUE / EXPENSE          → P&L
// `parentId` lets the org build a hierarchy (e.g. Operating Expenses
// → Salaries → US Salaries → Engineering Salaries).
model GlAccount {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Account code — typically a 4-6 digit number (4000-Revenue,
  // 6000-Expense, etc). Unique per org.
  code           String
  name           String
  type           GlAccountType
  parentId       String?
  parent         GlAccount?    @relation("GlAccountParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       GlAccount[]   @relation("GlAccountParent")
  // Currency the account is denominated in. Multi-currency orgs run
  // separate accounts per currency and consolidate via FX entries.
  currency       String        @default("USD")
  description    String?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  debitLines  JournalLine[] @relation("JournalLineDebit")
  creditLines JournalLine[] @relation("JournalLineCredit")
  planLines   PlanLine[]

  @@unique([organizationId, code])
  @@index([organizationId, type])
  @@index([parentId])
}

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// Cost centers / business units. Optional dimension on every
// journal line so reports can filter by department, branch, etc.
model CostCenter {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  journalLines JournalLine[]
  planLines    PlanLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Fiscal year container — one per org per year. Some orgs run
// non-calendar years (Apr-Mar in India) so the start month is
// configurable.
model FiscalYear {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Human label — "FY2026", "FY27" — distinct from the date range.
  label          String
  startDate      DateTime
  endDate        DateTime
  status         FiscalYearStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime         @default(now())

  periods     AccountingPeriod[]
  budgetPlans BudgetPlan[]

  @@unique([organizationId, label])
  @@index([organizationId, status])
}

enum FiscalYearStatus {
  OPEN
  CLOSED
}

// Accounting period — usually monthly, sometimes 4-4-5 retail
// calendar. Posting to a CLOSED period is rejected at the API
// layer.
model AccountingPeriod {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fiscalYearId   String
  fiscalYear     FiscalYear             @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  label          String // "2026-01", "Jan 2026", etc.
  startDate      DateTime
  endDate        DateTime
  status         AccountingPeriodStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime               @default(now())

  journalEntries JournalEntry[]
  planLines      PlanLine[]

  @@unique([fiscalYearId, label])
  @@index([organizationId, status])
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

// One journal entry — a self-balancing set of debit/credit lines.
// Multiple sources auto-post here: payroll runs, AP invoices, AR
// invoices, expense reimbursements. Manual entries are also
// supported. Total debits MUST equal total credits — enforced at
// the API layer because Prisma can't express the constraint.
model JournalEntry {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodId       String
  period         AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  // Sequential per-org reference (JE-000123). Generated server-side.
  reference      String
  // Ledger date — drives which period the entry hits. Distinct from
  // createdAt (when the row was inserted) to handle back-dated
  // adjustments inside an open period.
  postedAt       DateTime
  description    String
  // Origin of the entry. Auto-posted entries record the upstream
  // entity in `sourceType` + `sourceId` so we can trace lineage.
  source         JournalSource    @default(MANUAL)
  sourceType     String?
  sourceId       String?
  status         JournalStatus    @default(DRAFT)
  // Manual entries above an org-defined threshold need a second
  // approver before posting. APPROVED → POSTED is irreversible.
  postedById     String?
  postedBy       User?            @relation("JournalEntryPostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  approvedById   String?
  approvedBy     User?            @relation("JournalEntryApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  lines JournalLine[]

  @@unique([organizationId, reference])
  @@index([organizationId, postedAt])
  @@index([periodId, status])
  @@index([sourceType, sourceId])
}

enum JournalSource {
  MANUAL
  PAYROLL
  AP_INVOICE // bills from vendors (Procurement.Invoice)
  AR_INVOICE // customer invoices (future Sales module)
  EXPENSE
  PURCHASE_ORDER
  ADJUSTMENT // period close adjustments
  OPENING_BALANCE
  REVERSAL
}

enum JournalStatus {
  DRAFT
  PENDING // submitted, awaiting approval
  APPROVED
  POSTED // immutable
  REVERSED // a reversal entry exists referencing this one
  VOIDED // never posted; cancelled while still in draft/pending
}

// One side of a balanced entry. A line is EITHER a debit OR a
// credit — both columns nullable, but the API enforces exactly one
// non-null. amount is always positive; the side is in the column
// choice.
model JournalLine {
  id              String       @id @default(cuid())
  entryId         String
  entry           JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  debitAccountId  String?
  debitAccount    GlAccount?   @relation("JournalLineDebit", fields: [debitAccountId], references: [id], onDelete: Restrict)
  creditAccountId String?
  creditAccount   GlAccount?   @relation("JournalLineCredit", fields: [creditAccountId], references: [id], onDelete: Restrict)
  amount          Decimal      @db.Decimal(14, 2)
  // Optional dimensions for reporting.
  costCenterId    String?
  costCenter      CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  description     String?
  // Multi-currency: amount is in the entry's reporting currency;
  // these capture the original transaction currency + rate.
  txnCurrency     String?
  txnAmount       Decimal?     @db.Decimal(14, 2)
  txnFxRate       Decimal?     @db.Decimal(14, 8)

  @@index([entryId])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([costCenterId])
}

// ==========================================
// 🆕 PHASE A · UNIVERSAL PRIMITIVES (Modular Work OS)
// Product Store + Spaces + Boards + Items + Views + Agents + Apps.
// Polymorphic Item indexes the typed module rows (Task, Candidate,
// Lead, Ticket, ...) so cross-board queries + a single ListPage
// renderer work without union types. Native modules implicitly own a
// "default" Board per org so they keep working with no migration.
// ==========================================

// Global product catalog. One row per installable product (People,
// CRM, ITSM, Marketing, Dev, Legal, Support, Finance, Ops). NOT
// org-scoped — every org sees the same catalog and picks what to
// install (ProductInstallation).
model Product {
  id                 String        @id @default(cuid())
  slug               String        @unique
  name               String
  tagline            String?
  description        String        @db.Text
  iconKey            String?
  hue                String?
  suite              ProductSuite  @default(CROSS)
  tier               ProductTier   @default(CORE)
  status             ProductStatus @default(LIVE)
  defaultEnabled     Boolean       @default(false)
  displayOrder       Int           @default(0)
  legacyModuleKey    String?
  pathPrefix         String?
  seededAgents       Json          @default("[]")
  seededTemplates    Json          @default("[]")
  seededIntegrations Json          @default("[]")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  installations ProductInstallation[]

  @@index([suite])
  @@index([status])
  @@index([displayOrder])
}

enum ProductSuite {
  PEOPLE
  SALES
  OPERATIONS
  IT
  MARKETING
  FINANCE
  ENGINEERING
  LEGAL
  SUPPORT
  CROSS
}

enum ProductTier {
  CORE
  PLUS
  SUITE
  ENTERPRISE
}

enum ProductStatus {
  LIVE
  PREVIEW
  COMING_SOON
  DEPRECATED
}

model ProductInstallation {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String
  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  status         ProductInstallStatus @default(ACTIVE)
  installedById  String?
  installedAt    DateTime             @default(now())
  pausedAt       DateTime?
  removedAt      DateTime?
  settings       Json                 @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, productId])
  @@index([organizationId, status])
}

enum ProductInstallStatus {
  ACTIVE
  PAUSED
  REMOVED
}

model Space {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  description    String?
  icon           String?
  color          String?
  parentSpaceId  String?
  parentSpace    Space?       @relation("SpaceTree", fields: [parentSpaceId], references: [id], onDelete: SetNull)
  childSpaces    Space[]      @relation("SpaceTree")
  ownerId        String?
  displayOrder   Int          @default(0)
  archivedAt     DateTime?
  settings       Json         @default("{}")
  // 🆕 Phase 1 shell — who can see this Space. Defaults to WORKSPACE
  // (visible to SpaceMembers + org admins), can be widened to ORG
  // (anyone in the org) or narrowed to PRIVATE (members only).
  visibility     Visibility   @default(WORKSPACE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  boards  Board[]
  folders Folder[]
  members SpaceMember[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, archivedAt])
  @@index([parentSpaceId])
}

model Board {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spaceId        String?
  space          Space?       @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  // 🆕 Phase 1 shell — Boards can sit inside a Folder for the
  // Space > Folder > Board nesting the ClickUp shell expects. Nullable
  // so a Board can still hang directly off a Space (no folder).
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  slug           String
  name           String
  description    String?
  icon           String?
  color          String?
  itemType       String
  productSlug    String?
  ownerId        String?
  isDefault      Boolean      @default(false)
  archivedAt     DateTime?
  schema         Json         @default("{}")
  settings       Json         @default("{}")
  // Per-List statuses (ClickUp parity backbone #1) — array of
  // { value, label, color, group: ACTIVE|DONE|CLOSED }. null = use the
  // canonical default trio. Read via getBoardStatuses().
  statuses       Json?
  // 🆕 Phase 1 shell — Board-level visibility. Resolver in Phase 6
  // composes this with Space.visibility + SpaceMember + reporting
  // line + org role to decide whether the viewer can read/edit.
  visibility     Visibility   @default(WORKSPACE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  views   View[]
  items   Item[]
  members BoardMember[]

  @@unique([organizationId, slug])
  @@index([organizationId, productSlug])
  @@index([organizationId, archivedAt])
  @@index([spaceId])
  @@index([folderId])
  @@index([itemType])
}

// 🆕 Phase 23 — Per-Board access overrides. Layered on top of Space:
//   - When Board.visibility = WORKSPACE (default), the resolver defers
//     to Space access entirely. No BoardMember rows needed.
//   - When Board.visibility = PRIVATE, only listed BoardMembers + the
//     Board's ownerId + Space OWNERs + org admins can read. Tightens
//     a board below its Space's visibility.
//   - When Board.visibility = ORG, anyone in the org can read regardless
//     of Space membership. Loosens above its Space.
//
// Role semantics mirror SpaceRole. OWNER + ADMIN can mutate; MEMBER/GUEST
// are read-only at the API gate (UI may grant comment access).
model BoardMember {
  id        String    @id @default(cuid())
  boardId   String
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation("BoardMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  role      SpaceRole @default(MEMBER)
  invitedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([boardId, userId])
  @@index([userId])
  @@index([boardId, role])
}

model View {
  id           String   @id @default(cuid())
  boardId      String
  board        Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name         String
  type         ViewType
  config       Json     @default("{}")
  isShared     Boolean  @default(false)
  isDefault    Boolean  @default(false)
  ownerId      String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([boardId])
  @@index([ownerId])
}

enum ViewType {
  TABLE
  KANBAN
  GANTT
  CALENDAR
  TIMELINE
  CHART
  DOC
  FORM
  DASHBOARD
  MAP
  WORKLOAD
  WHITEBOARD
  FILE_GALLERY
  // Views-catalog additions — genuinely new renderers (the rest of the
  // catalog rides on existing types via View.config).
  CARDS
  PIVOT
  HIERARCHY
  ACTIVITY
}

model Item {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  boardId        String
  board          Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  itemType       String
  itemId         String
  title          String
  status         String?
  ownerId        String?
  groupKey       String?
  position       Float        @default(0)
  archivedAt     DateTime?
  // 🆕 Phase 58 — first-class date columns. Pre-Phase 58 dates lived
  // in metadata under user-defined keys (per-board DATE field). The
  // Calendar + Gantt views still project metadata as a fallback, but
  // these columns let new items set their schedule directly without
  // needing a board-level field shelf entry. startAt is the optional
  // beginning of a duration; dueAt is the deadline / single-day date.
  startAt        DateTime?
  dueAt          DateTime?
  // 🆕 Task-system — hoisted priority so cross-board queries can
  // filter/order without JSON-path gymnastics (same rationale as the
  // Phase 58 date hoist). Values: URGENT | HIGH | NORMAL | LOW;
  // null = no priority (ClickUp default). Plain string like `status`.
  priority       String?
  // 🆕 Task Types — presentational re-skin (Task/Milestone/Bug/Deal…).
  // null = the org's default type. Migrated from metadata.taskType.
  itemTypeId     String?
  metadata       Json         @default("{}")
  // 🆕 Phase 72 — subtask self-relation. Top-level items have parentItemId
  // = null; subtasks point to their parent. Cascade delete so removing
  // the parent drops the whole tree (ClickUp + Linear pattern).
  parentItemId   String?
  parentItem     Item?        @relation("ItemSubtasks", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItems     Item[]       @relation("ItemSubtasks")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([itemType, itemId])
  @@index([organizationId, boardId])
  @@index([boardId, position])
  @@index([boardId, dueAt])
  @@index([boardId, priority])
  @@index([boardId, parentItemId])
  @@index([itemType])
  @@index([itemTypeId])
  @@index([ownerId])
}

// ==========================================
// 🆕 PHASE 1 SHELL — ClickUp parity substrate
// Folders inside Spaces; per-Space membership; per-user + per-org
// shell preferences; matrix reporting (dotted lines) + HR segment
// ownership. Strictly schema additions — no UI consumes these yet;
// Phase 2 wires the customize panel + sidebar tree on top.
// ==========================================

// Visibility — the three-tier read scope used by Space and Board.
// PRIVATE: only explicit members can see.
// WORKSPACE: visible to SpaceMembers + org admins (the default;
//            keeps things scoped without ceremony).
// ORG: visible to every member of the organization.
// The Phase 6 access resolver composes this with reporting-line
// and role checks for the final read/edit decision.
enum Visibility {
  PRIVATE
  WORKSPACE
  ORG
}

// Folder — Space > Folder > Board nesting. Folders can nest inside
// other Folders (parentFolderId), capped at 6 levels in app code.
// Soft-deletable via archivedAt; deletedAt-style hard delete is
// out of scope for Phase 1 (Phase 2 ships a trash bin UI).
model Folder {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spaceId        String
  space          Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parentFolderId String?
  parentFolder   Folder?      @relation("FolderTree", fields: [parentFolderId], references: [id], onDelete: SetNull)
  childFolders   Folder[]     @relation("FolderTree")
  name           String
  description    String?
  icon           String?
  color          String?
  ownerId        String?
  position       Float        @default(0) // fractional ordering — Linear pattern, no renumber on drop
  archivedAt     DateTime?
  settings       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  boards Board[]

  @@index([organizationId, archivedAt])
  @@index([spaceId, parentFolderId, position])
  @@index([parentFolderId])
}

// SpaceMember — per-Space ACL. Org admins implicitly access every
// Space without a row here; explicit rows are the membership grant
// for non-admin users. role is a coarse OWNER/ADMIN/MEMBER/GUEST;
// fine-grained per-Board permissions land in Phase 6 (BoardACL).
model SpaceMember {
  id        String    @id @default(cuid())
  spaceId   String
  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      SpaceRole @default(MEMBER)
  invitedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([spaceId, userId])
  @@index([userId])
  @@index([spaceId, role])
}

enum SpaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

// UserPreference — per-user shell state. One row per user. JSON
// blobs for now (sidebar/home/theme); typed columns extracted in
// Phase 2 once we know the exact shape we want to query on.
//
// Resolver merges this with OrgPreference defaults and clamps
// against OrgPreference.lockedKeys so admin-locked keys can't be
// overridden by individual users.
model UserPreference {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sidebar   Json? // { pinned:[], hidden:[], order:[], iconsOnly:false, sectionsOrder:[] }
  home      Json? // { cards:[], order:[] }
  theme     Json? // { appearance:'LIGHT'|'DARK'|'AUTO', accent:'mint' }
  density   String? // 'compact' | 'cozy'
  updatedAt DateTime @updatedAt
}

// OrgPreference — org-level defaults for the customize panel. Admin
// can also freeze specific dot-paths via lockedKeys so users can't
// hide compliance-critical surfaces (e.g. "sidebar.pinned.kra-kpi").
model OrgPreference {
  organizationId String       @id
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sidebarDefault Json?
  homeDefault    Json?
  themeDefault   Json?
  densityDefault String?
  lockedKeys     String[]     @default([]) // dot-paths admin has frozen
  updatedAt      DateTime     @updatedAt
}

// UserDottedLine — matrix reporting. Beyond the solid managerId on
// User, a person can have any number of dotted-line managers (project
// leads, matrix managers, regional dotted-lines). The reporting-line
// helper unions solid + dotted for "everyone I report to" queries.
model UserDottedLine {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("DottedLineFromUser", fields: [userId], references: [id], onDelete: Cascade)
  managerId String
  manager   User      @relation("DottedLineToManager", fields: [managerId], references: [id], onDelete: Cascade)
  role      String? // free-form note: "project lead", "matrix manager", "skip-level"
  weight    Float? // optional weight for partial reporting (e.g. 0.5 = half-time on this line)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, managerId])
  @@index([managerId])
  @@index([userId])
}

// HRSegment — which slice of the org an HR user owns. HR people in
// large companies own specific business units, regions, role tiers,
// or departments rather than the whole org. The access resolver
// uses these rows to scope HR's read access at query time.
model HRSegment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String // the HR user
  name           String // "APAC HR", "Engineering HR", ...
  scope          Json         @default("{}") // { departmentIds?:[], businessUnitIds?:[], regionIds?:[], roleLevels?:[] }
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, ownerId])
  @@index([organizationId, isActive])
}

model Agent {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug              String
  name              String
  persona           String?
  avatar            String?
  description       String       @db.Text
  systemPrompt      String       @db.Text
  productSlug       String?
  tools             Json         @default("[]")
  modelOverride     String?
  isPrebuilt        Boolean      @default(false)
  prebuiltSlug      String?
  status            AgentStatus  @default(ENABLED)
  // Autonomous-run config — the "AI controls the people" vision pillar.
  // When `autonomousEnabled = true` and `scheduleCron` is set, the
  // cron-tickable endpoint /api/cron/run-due-agents fires this agent
  // every cycle without a user prompt. Output is captured as an
  // AgentRun row and surfaced on /dashboard.
  autonomousEnabled Boolean      @default(false)
  // Cron-style expression OR a coarse interval ("hourly", "daily",
  // "weekly"). Keeping it a free-form string for v1 so we don't lock
  // ourselves into a cron lib choice yet — `nextRunAt` is recomputed
  // on save / after each run by the scheduler lib.
  scheduleCron      String?
  // The prompt the autonomous loop feeds in as the user message on
  // each scheduled run. Without this the agent has no "what should
  // you do every hour?" instruction; with it, the agent has a recurring
  // brief (e.g. "Review yesterday's deals and flag anything stuck >5
  // days in the same stage").
  autonomousPrompt  String?      @db.Text
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  createdById       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  runs         AgentRun[]
  memories     AgentMemory[]
  chatSessions ChatSession[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([productSlug])
  @@index([autonomousEnabled, nextRunAt])
}

enum AgentStatus {
  ENABLED
  DISABLED
  ARCHIVED
}

model AgentRun {
  id          String    @id @default(cuid())
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  triggeredBy String?
  input       Json
  output      Json?
  status      String    @default("PENDING")
  error       String?   @db.Text
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  tokensIn    Int?
  tokensOut   Int?
  costCents   Int?

  @@index([agentId, startedAt])
  @@index([status])
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  scope     String   @default("agent")
  scopeId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, scope, scopeId, key])
  @@index([agentId])
}

model App {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  description    String?      @db.Text
  iconKey        String?
  hue            String?
  prompt         String?      @db.Text
  schema         Json         @default("{}")
  ui             Json         @default("{}")
  isStandalone   Boolean      @default(true)
  status         AppStatus    @default(DRAFT)
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

enum AppStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ==========================================
// 🆕 PHASE E2 · WorkwrK CRM
// First showcase product beyond HR. Validates the Product Store
// architecture with a brand-new buyer story (Sales VP). 4 core models:
// Lead (top-of-funnel), Account (customer org), Opportunity (deal),
// PipelineStage (per-org configurable workflow). Activities/calls/
// emails leverage the existing ActivityLog rather than a new model.
// ==========================================

model Lead {
  id                       String       @id @default(cuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Workspace this lead belongs to — Sales Team A vs Sales Team B
  // inside the same CRM. Nullable so legacy rows (pre-workspaces)
  // show up under every workspace's view (org-wide visibility). New
  // leads default to the active workspace at creation time.
  workspaceId              String?
  firstName                String
  lastName                 String?
  email                    String?
  phone                    String?
  company                  String?
  title                    String?
  source                   String? // "website" | "referral" | "outbound" | "linkedin" | "event" | "import"
  status                   LeadStatus   @default(NEW)
  score                    Int          @default(0)
  notes                    String?      @db.Text
  ownerId                  String? // assigned SDR/AE
  convertedAt              DateTime?
  convertedToAccountId     String?
  convertedToOpportunityId String?
  customFields             Json         @default("{}")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, ownerId])
  @@index([organizationId, workspaceId])
  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  DISQUALIFIED
}

model Account {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Workspace this account belongs to — see Lead.workspaceId for the
  // nullable-for-back-compat rationale.
  workspaceId    String?
  name           String
  domain         String?
  industry       String?
  size           String? // "1-10", "11-50", etc.
  website        String?
  phone          String?
  description    String?      @db.Text
  type           AccountType  @default(PROSPECT)
  ownerId        String?
  customFields   Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  opportunities Opportunity[]

  @@unique([organizationId, name])
  @@index([organizationId, type])
  @@index([organizationId, ownerId])
  @@index([organizationId, workspaceId])
}

enum AccountType {
  PROSPECT
  CUSTOMER
  PARTNER
  CHURNED
  COMPETITOR
}

model PipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  position       Int          @default(0)
  // Default % chance the deal closes when in this stage. Drives weighted
  // forecast on the kanban board.
  probability    Int          @default(50)
  color          String?
  isWon          Boolean      @default(false)
  isLost         Boolean      @default(false)
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  opportunities Opportunity[]

  @@unique([organizationId, name])
  @@index([organizationId, position])
}

model Opportunity {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Workspace this deal belongs to — see Lead.workspaceId for the
  // nullable-for-back-compat rationale.
  workspaceId       String?
  name              String
  accountId         String?
  account           Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  pipelineStageId   String?
  pipelineStage     PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  amount            Decimal?       @db.Decimal(14, 2)
  currency          String         @default("USD")
  // Expected close date drives quarter buckets + age-in-stage alerts.
  expectedCloseDate DateTime?
  closedAt          DateTime? // set by the Won/Lost transition
  isWon             Boolean? // null = open
  lossReason        String?
  description       String?        @db.Text
  ownerId           String? // assigned AE
  customFields      Json           @default("{}")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([organizationId, pipelineStageId])
  @@index([organizationId, ownerId])
  @@index([organizationId, accountId])
  @@index([organizationId, workspaceId])
  @@index([expectedCloseDate])
}

// ==========================================
// 🆕 PHASE E3 · WorkwrK ITSM
// IT Service Management — internal IT tickets, incidents, knowledge
// base. Distinct from /helpdesk (external customer support) which lives
// under the SUPPORT suite. ITSM is for the IT team handling employee
// requests + production incidents.
// ==========================================

model Ticket {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId     String? // nullable: legacy rows are workspace-agnostic
  title           String
  description     String?        @db.Text
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(NORMAL)
  category        String? // "Access" | "Hardware" | "Software" | "Network" | ...
  source          TicketSource   @default(PORTAL)
  requesterId     String? // user who filed it (usually employee)
  assigneeId      String? // IT staff handling it
  slaTier         String? // "P1" | "Standard" | "VIP"
  dueAt           DateTime?
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  resolutionNotes String?        @db.Text
  customFields    Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, assigneeId])
  @@index([organizationId, priority])
  @@index([organizationId, workspaceId])
  @@index([requesterId])
  @@index([dueAt])
}

enum TicketStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  WAITING_ON_USER
  WAITING_ON_VENDOR
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum TicketSource {
  PORTAL
  EMAIL
  CHAT
  PHONE
  API
  AGENT
}

model Incident {
  id               String           @id @default(cuid())
  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId      String? // nullable: legacy rows are workspace-agnostic
  title            String
  summary          String?          @db.Text
  severity         IncidentSeverity @default(SEV3)
  status           IncidentStatus   @default(DETECTED)
  commanderId      String? // incident commander
  affectedServices Json             @default("[]") // string[] of service names
  startedAt        DateTime         @default(now())
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  postmortemUrl    String?
  rootCause        String?          @db.Text
  customFields     Json             @default("{}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, workspaceId])
  @@index([startedAt])
}

enum IncidentSeverity {
  SEV1
  SEV2
  SEV3
  SEV4
  SEV5
}

enum IncidentStatus {
  DETECTED
  ACKNOWLEDGED
  INVESTIGATING
  MITIGATING
  RESOLVED
  POSTMORTEM
  CLOSED
}

model KbArticle {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId     String? // nullable: legacy rows are workspace-agnostic
  slug            String
  title           String
  body            String       @db.Text
  excerpt         String?
  category        String?
  tags            Json         @default("[]")
  authorId        String?
  publishedAt     DateTime?
  viewCount       Int          @default(0)
  helpfulCount    Int          @default(0)
  notHelpfulCount Int          @default(0)
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, category])
  @@index([organizationId, workspaceId])
  @@index([publishedAt])
}

// ==========================================
// 🆕 PHASE E4 · WorkwrK Marketing
// Campaigns + Content calendar + Events. Distinct from /announcements
// (internal company comms) — this is external go-to-market work
// owned by the CMO + marketing managers.
// ==========================================

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String? // nullable: legacy rows are workspace-agnostic
  name           String
  description    String?        @db.Text
  status         CampaignStatus @default(PLANNING)
  channel        String? // "Email" | "Paid Search" | "Social" | "Outbound" | "Event" | "Content" | "Webinar"
  budget         Decimal?       @db.Decimal(12, 2)
  spent          Decimal?       @db.Decimal(12, 2)
  currency       String         @default("USD")
  startDate      DateTime?
  endDate        DateTime?
  ownerId        String?
  goalMetric     String? // "Leads" | "MQLs" | "Pipeline" | "Brand"
  goalTarget     Int?
  goalActual     Int?
  utmCampaign    String?
  customFields   Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, ownerId])
  @@index([organizationId, workspaceId])
  @@index([startDate])
}

enum CampaignStatus {
  PLANNING
  APPROVED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model ContentItem {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceId    String? // nullable: legacy rows are workspace-agnostic
  title          String
  type           ContentType   @default(BLOG_POST)
  status         ContentStatus @default(IDEA)
  channel        String? // "Blog" | "LinkedIn" | "Twitter" | "Email" | "YouTube" | "TikTok"
